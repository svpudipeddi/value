<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gainsight CS O2 Workflow Finder</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --gs-navy: #0a1628;
    --gs-blue: #0057ff;
    --gs-teal: #00c2cb;
    --bg: #f4f6fb;
    --surface: #ffffff;
    --surface2: #f0f4ff;
    --border: #e2e8f0;
    --text: #0a1628;
    --text-muted: #64748b;
    --crawl: #f97316;
    --walk: #3b82f6;
    --run: #22c55e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "DM Sans", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  .header {
    background: var(--gs-navy); padding: 18px 40px;
    display: flex; align-items: center; gap: 14px;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .header-title { font-family: "Syne",sans-serif; font-weight: 700; font-size: 17px; color: white; letter-spacing: -0.2px; }
  .header-sub { color: var(--gs-teal); font-size: 13px; margin-left: auto; opacity: 0.9; }

  .container { max-width: 920px; margin: 0 auto; padding: 36px 24px; }

  .step-bar { display: flex; align-items: center; margin-bottom: 36px; }
  .step-item { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; color: var(--text-muted); white-space: nowrap; }
  .step-item.active { color: var(--gs-blue); }
  .step-item.done { color: var(--run); }
  .step-num { width: 26px; height: 26px; border-radius: 50%; background: var(--border); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; transition: all 0.3s; flex-shrink: 0; }
  .step-item.active .step-num { background: var(--gs-blue); color: white; }
  .step-item.done .step-num { background: var(--run); color: white; }
  .step-line { flex: 1; height: 2px; background: var(--border); margin: 0 10px; transition: background 0.3s; }
  .step-line.done { background: var(--run); }

  .card { background: var(--surface); border-radius: 16px; padding: 36px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); margin-bottom: 24px; border: 1px solid var(--border); }
  .card-title { font-family: "Syne",sans-serif; font-weight: 700; font-size: 22px; margin-bottom: 6px; color: var(--gs-navy); }
  .card-sub { font-size: 14px; color: var(--text-muted); margin-bottom: 28px; line-height: 1.6; }

  .path-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .path-card { border: 2px solid var(--border); border-radius: 14px; padding: 28px 22px; cursor: pointer; transition: all 0.2s; }
  .path-card:hover { border-color: var(--gs-blue); background: var(--surface2); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,87,255,0.1); }
  .path-card.selected { border-color: var(--gs-blue); background: var(--surface2); box-shadow: 0 0 0 4px rgba(0,87,255,0.1); }
  .path-icon { font-size: 34px; margin-bottom: 10px; }
  .path-label { font-family: "Syne",sans-serif; font-weight: 700; font-size: 17px; margin-bottom: 5px; }
  .path-desc { font-size: 13px; color: var(--text-muted); line-height: 1.5; }

  .q-label { font-family: "Syne",sans-serif; font-weight: 600; font-size: 15px; margin-bottom: 4px; color: var(--gs-navy); }
  .q-hint { font-size: 12px; color: var(--text-muted); margin-bottom: 14px; }
  .options-grid { display: flex; flex-wrap: wrap; gap: 10px; }

  .opt-chip { border: 2px solid var(--border); border-radius: 12px; padding: 12px 16px; font-size: 14px; cursor: pointer; transition: all 0.15s; background: white; color: var(--text); font-weight: 500; user-select: none; text-align: left; min-width: 140px; }
  .opt-chip:hover { border-color: var(--gs-blue); background: var(--surface2); }
  .opt-chip.selected { background: var(--gs-blue); border-color: var(--gs-blue); color: white; }
  .opt-chip.crawl.selected { background: var(--crawl); border-color: var(--crawl); }
  .opt-chip.walk.selected { background: var(--walk); border-color: var(--walk); }
  .opt-chip.run.selected { background: var(--run); border-color: var(--run); }
  .opt-chip-label { font-weight: 600; font-size: 14px; margin-bottom: 3px; }
  .opt-chip-desc { font-size: 12px; color: var(--text-muted); line-height: 1.4; font-weight: 400; }
  .opt-chip.selected .opt-chip-desc { color: rgba(255,255,255,0.75); }
  .opt-chip.crawl.selected .opt-chip-desc { color: rgba(255,255,255,0.75); }
  .opt-chip.walk.selected .opt-chip-desc { color: rgba(255,255,255,0.75); }
  .opt-chip.run.selected .opt-chip-desc { color: rgba(255,255,255,0.75); }

  .comp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(176px, 1fr)); gap: 8px; }
  .comp-chip { border: 2px solid var(--border); border-radius: 10px; padding: 11px 14px; font-size: 13px; cursor: pointer; transition: all 0.15s; background: white; text-align: left; color: var(--text); }
  .comp-chip:hover { border-color: var(--gs-blue); background: var(--surface2); }
  .comp-chip.selected { background: var(--gs-blue); border-color: var(--gs-blue); color: white; }
  .comp-chip-label { font-weight: 600; font-size: 13px; margin-bottom: 2px; }
  .comp-chip-desc { font-size: 11px; color: var(--text-muted); line-height: 1.3; }
  .comp-chip.selected .comp-chip-desc { color: rgba(255,255,255,0.75); }

  .btn { padding: 11px 26px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: all 0.2s; font-family: "DM Sans",sans-serif; }
  .btn-primary { background: var(--gs-blue); color: white; }
  .btn-primary:hover:not(:disabled) { background: #0046cc; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,87,255,0.3); }
  .btn-primary:disabled { background: var(--border); color: var(--text-muted); cursor: not-allowed; }
  .btn-ghost { background: transparent; color: var(--text-muted); border: 2px solid var(--border); }
  .btn-ghost:hover { border-color: var(--gs-blue); color: var(--gs-blue); }
  .btn-row { display: flex; justify-content: space-between; align-items: center; margin-top: 28px; }

  /* RESULTS */
  .results-header { background: var(--gs-navy); border-radius: 16px; padding: 32px 36px; margin-bottom: 20px; color: white; }
  .results-header h2 { font-family: "Syne",sans-serif; font-weight: 800; font-size: 26px; margin-bottom: 6px; }
  .results-header .sub { color: rgba(255,255,255,0.55); font-size: 14px; margin-bottom: 16px; }
  .meta-pills { display: flex; gap: 10px; flex-wrap: wrap; }
  .meta-pill { background: rgba(255,255,255,0.1); border-radius: 100px; padding: 5px 14px; font-size: 12px; }
  .meta-pill strong { color: var(--gs-teal); }

  .filter-bar { background: var(--surface); border-radius: 12px; padding: 14px 18px; margin-bottom: 18px; border: 1px solid var(--border); display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .filter-bar input { flex: 1; min-width: 180px; border: 1px solid var(--border); border-radius: 8px; padding: 7px 12px; font-size: 14px; font-family: "DM Sans",sans-serif; outline: none; }
  .filter-bar input:focus { border-color: var(--gs-blue); }
  .filter-label { font-size: 13px; color: var(--text-muted); font-weight: 500; }
  .sort-select { border: 1px solid var(--border); border-radius: 8px; padding: 7px 11px; font-size: 13px; font-family: "DM Sans",sans-serif; cursor: pointer; outline: none; }

  /* VALUE DRIVER SECTIONS */
  .vd-section { background: var(--surface); border-radius: 14px; border: 1px solid var(--border); margin-bottom: 14px; overflow: hidden; }
  .vd-header { padding: 18px 22px; display: flex; align-items: center; gap: 12px; cursor: pointer; user-select: none; transition: background 0.15s; }
  .vd-header:hover { background: var(--surface2); }
  .vd-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .vd-title { font-family: "Syne",sans-serif; font-weight: 700; font-size: 16px; flex: 1; }
  .vd-count { background: var(--surface2); border-radius: 100px; padding: 3px 11px; font-size: 12px; font-weight: 600; color: var(--gs-blue); }
  .vd-chevron { font-size: 13px; color: var(--text-muted); transition: transform 0.22s; }
  .vd-chevron.open { transform: rotate(180deg); }
  .vd-body { display: none; padding: 0 20px 18px; }
  .vd-body.open { display: block; }

  /* WORKFLOW ITEM */
  .wf-item { border: 1px solid var(--border); border-radius: 12px; margin-bottom: 8px; overflow: hidden; background: white; transition: box-shadow 0.18s; }
  .wf-item:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.08); }
  .wf-row { padding: 14px 16px; display: flex; align-items: center; gap: 10px; cursor: pointer; }
  .wf-id { font-size: 10px; font-weight: 700; color: var(--text-muted); background: var(--bg); border-radius: 5px; padding: 3px 7px; flex-shrink: 0; font-family: monospace; }
  .wf-name { flex: 1; font-weight: 500; font-size: 14px; }
  .maturity-badge { padding: 3px 9px; border-radius: 100px; font-size: 11px; font-weight: 700; flex-shrink: 0; }
  .maturity-badge.Crawl { background: #fff3e8; color: var(--crawl); }
  .maturity-badge.Walk { background: #eff6ff; color: var(--walk); }
  .maturity-badge.Run { background: #f0fdf4; color: var(--run); }
  .effort-badge { font-size: 11px; padding: 3px 8px; border-radius: 6px; background: var(--bg); color: var(--text-muted); font-weight: 500; flex-shrink: 0; }
  .expand-arrow { font-size: 12px; color: var(--text-muted); transition: transform 0.2s; flex-shrink: 0; }
  .expand-arrow.open { transform: rotate(90deg); }

  /* WF DETAIL — all sections stacked, no tabs */
  .wf-detail { display: none; border-top: 1px solid var(--border); background: #fafbff; padding: 0; }
  .wf-detail.open { display: block; }

  .detail-section { padding: 20px 22px; border-bottom: 1px solid var(--border); }
  .detail-section:last-child { border-bottom: none; }
  .detail-section-title { font-family: "Syne",sans-serif; font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--gs-blue); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
  .detail-section-title span { background: var(--surface2); border-radius: 6px; padding: 2px 8px; }

  .detail-meta-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; margin-bottom: 14px; }
  .detail-meta-item { background: white; border: 1px solid var(--border); border-radius: 10px; padding: 12px; }
  .detail-meta-item label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 4px; }
  .detail-meta-item .val { font-size: 13px; font-weight: 600; color: var(--gs-navy); }

  .comp-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .comp-tag { font-size: 12px; background: var(--surface2); border-radius: 6px; padding: 4px 9px; color: var(--gs-blue); font-weight: 500; }

  .detail-text { font-size: 13.5px; line-height: 1.75; color: var(--text); white-space: pre-wrap; }
  .detail-empty { font-size: 13px; color: var(--text-muted); font-style: italic; }

  .empty { text-align: center; padding: 60px 24px; color: var(--text-muted); }
  .empty-icon { font-size: 48px; margin-bottom: 12px; }
  .hidden { display: none !important; }

  /* STAR / FAVOURITE */
  .star-btn { background: none; border: none; cursor: pointer; font-size: 18px; line-height: 1; padding: 2px 4px; flex-shrink: 0; transition: transform 0.15s; color: #cbd5e1; }
  .star-btn:hover { transform: scale(1.2); }
  .star-btn.starred { color: #f59e0b; }

  /* FAVOURITES BAR */
  .fav-bar { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; }
  .fav-tab { padding: 8px 18px; border-radius: 100px; font-size: 13px; font-weight: 600; cursor: pointer; border: 2px solid var(--border); background: white; color: var(--text-muted); transition: all 0.15s; display: flex; align-items: center; gap: 6px; }
  .fav-tab:hover { border-color: var(--gs-blue); color: var(--gs-blue); }
  .fav-tab.active { background: var(--gs-blue); border-color: var(--gs-blue); color: white; }
  .fav-tab .fav-count { background: rgba(255,255,255,0.25); border-radius: 100px; padding: 1px 7px; font-size: 11px; }
  .fav-tab:not(.active) .fav-count { background: var(--surface2); color: var(--gs-blue); }

  /* EMPTY FAVOURITES */
  .fav-empty { text-align: center; padding: 48px 24px; color: var(--text-muted); background: white; border-radius: 14px; border: 2px dashed var(--border); }
  .fav-empty-icon { font-size: 40px; margin-bottom: 10px; }
  .fav-empty-title { font-family: "Syne", sans-serif; font-weight: 700; font-size: 16px; color: var(--gs-navy); margin-bottom: 6px; }
  .fav-empty-sub { font-size: 13px; line-height: 1.6; }

  @media (max-width: 600px) {
    .path-grid { grid-template-columns: 1fr; }
    .container { padding: 20px 14px; }
    .card { padding: 22px 16px; }
    .header { padding: 14px 18px; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-title">Path to Value Realization</div>
  <div class="header-sub">Let&#39;s check some outcomes ✦</div>
</div>

<div class="container">

  <div class="step-bar" id="stepBar">
    <div class="step-item active" id="step1"><div class="step-num">1</div>&nbsp;Approach</div>
    <div class="step-line" id="line1"></div>
    <div class="step-item" id="step2"><div class="step-num">2</div>&nbsp;Drivers / Features</div>
    <div class="step-line" id="line2"></div>
    <div class="step-item" id="step3"><div class="step-num">3</div>&nbsp;Maturity & Effort</div>
    <div class="step-line" id="line3"></div>
    <div class="step-item" id="step4"><div class="step-num">4</div>&nbsp;Results</div>
  </div>

  <!-- STEP 1: PATH -->
  <div id="screen1">
    <div class="card">
      <div class="card-title">How do you want to explore outcomes you can achieve with Gainsight?</div>
      <div class="card-sub">Here is a quick survey, we&#39;ll ask 3–4 questions about your Gainsight usage, then suggest outcomes you can achieve, whether through quick wins that need minimal lifting, or strategic wins that unlock deeper value.</div>
      <div class="card-sub" style="margin-top:-14px">Choose your starting point: explore by the business outcomes you want to drive, or by the Gainsight features your team uses today.</div>
      <div class="path-grid">
        <div class="path-card" id="pathValue" onclick="selectPath('value')">
          <div class="path-icon">🎯</div>
          <div class="path-label">Value Oriented</div>
          <div class="path-desc">Start with the business outcomes that matter most — retention, adoption, scale, or expansion — and we&#39;ll match you to the right workflows.</div>
        </div>
        <div class="path-card" id="pathFeature" onclick="selectPath('feature')">
          <div class="path-icon">⚙️</div>
          <div class="path-label">Feature Oriented</div>
          <div class="path-desc">Start with the Gainsight features your team already uses today — we&#39;ll show you what more value you can unlock from them.</div>
        </div>
      </div>
      <div class="btn-row">
        <div></div>
        <button class="btn btn-primary" id="btn1" disabled onclick="goToStep2()">Continue →</button>
      </div>
    </div>
  </div>

  <!-- STEP 2A: VALUE DRIVERS -->
  <div id="screen2value" class="hidden">
    <div class="card">
      <div class="card-title">What outcomes matter most to you?</div>
      <div class="card-sub">Select all the value drivers that apply — we'll surface workflows aligned to your goals.</div>
      <div class="q-label">Value Drivers</div>
      <div class="q-hint">Select one or more</div>
      <div class="options-grid">
        <div class="opt-chip" onclick="toggle(this,'vd','Retention')">🔒 Retention</div>
        <div class="opt-chip" onclick="toggle(this,'vd','Adoption')">📈 Adoption</div>
        <div class="opt-chip" onclick="toggle(this,'vd','Scale')">🚀 Scale</div>
        <div class="opt-chip" onclick="toggle(this,'vd','Expansion')">🌱 Expansion</div>
      </div>
      <div class="btn-row">
        <button class="btn btn-ghost" onclick="goToStep1()">← Back</button>
        <button class="btn btn-primary" id="btn2v" disabled onclick="goToStep3()">Continue →</button>
      </div>
    </div>
  </div>

  <!-- STEP 2B: FEATURE SELECTION -->
  <div id="screen2feature" class="hidden">
    <div class="card">
      <div class="card-title">Which Gainsight features does your team use today?</div>
      <div class="card-sub">Select all components your team currently has set up or actively uses.</div>
      <div class="q-label">Gainsight Components</div>
      <div class="q-hint">Select one or more</div>
      <div class="comp-grid" id="compGrid"></div>
      <div class="btn-row">
        <button class="btn btn-ghost" onclick="goToStep1()">← Back</button>
        <button class="btn btn-primary" id="btn2f" disabled onclick="goToStep3()">Continue →</button>
      </div>
    </div>
  </div>

  <!-- STEP 3: MATURITY + EFFORT -->
  <div id="screen3" class="hidden">
    <div class="card">
      <div class="card-title">Tell us about your team's context</div>
      <div class="card-sub">This helps us surface the most relevant and achievable workflows for where your team is today. All fields are optional — leave blank to see all.</div>

      <div class="q-label" style="margin-bottom:4px">Gainsight Maturity Level</div>
      <div class="q-hint">How mature is your Gainsight implementation?</div>
      <div class="options-grid" style="margin-bottom:26px">
        <div class="opt-chip crawl" onclick="toggle(this,'maturity','Crawl')"><div class="opt-chip-label">🐛 Crawl</div><div class="opt-chip-desc">Just getting started with Gainsight</div></div>
        <div class="opt-chip walk" onclick="toggle(this,'maturity','Walk')"><div class="opt-chip-label">🚶 Walk</div><div class="opt-chip-desc">Some workflows already active</div></div>
        <div class="opt-chip run" onclick="toggle(this,'maturity','Run')"><div class="opt-chip-label">🏃 Run</div><div class="opt-chip-desc">Advanced usage, looking to scale</div></div>
      </div>

      <div class="q-label" style="margin-bottom:4px">Admin Building Investment</div>
      <div class="q-hint">How much admin setup effort can you invest?</div>
      <div class="options-grid" style="margin-bottom:26px">
        <div class="opt-chip" onclick="toggle(this,'setup','Low')"><div class="opt-chip-label">🟢 Low</div><div class="opt-chip-desc">Light config; a few hours of admin time</div></div>
        <div class="opt-chip" onclick="toggle(this,'setup','Medium')"><div class="opt-chip-label">🟡 Medium</div><div class="opt-chip-desc">A few days of admin setup work</div></div>
        <div class="opt-chip" onclick="toggle(this,'setup','High')"><div class="opt-chip-label">🔴 High</div><div class="opt-chip-desc">Dedicated admin for complex setup</div></div>
      </div>

      <div class="q-label" style="margin-bottom:4px">CS Team Enablement Effort</div>
      <div class="q-hint">How much training & change management can your CS team handle?</div>
      <div class="options-grid">
        <div class="opt-chip" onclick="toggle(this,'enable','Low')"><div class="opt-chip-label">🟢 Low</div><div class="opt-chip-desc">Minimal training; mostly self-serve</div></div>
        <div class="opt-chip" onclick="toggle(this,'enable','Medium')"><div class="opt-chip-label">🟡 Medium</div><div class="opt-chip-desc">Some team enablement sessions</div></div>
        <div class="opt-chip" onclick="toggle(this,'enable','High')"><div class="opt-chip-label">🔴 High</div><div class="opt-chip-desc">Dedicated enablement capacity</div></div>
      </div>

      <div class="btn-row">
        <button class="btn btn-ghost" onclick="goToStep2()">← Back</button>
        <button class="btn btn-primary" onclick="showResults()">View Workflows →</button>
      </div>
    </div>
  </div>

  <!-- STEP 4: RESULTS -->
  <div id="screen4" class="hidden">
    <div class="results-header" id="resultsHeader"></div>
    <div class="filter-bar">
      <input type="text" placeholder="🔍 Search workflows..." id="searchInput" oninput="renderResults()">
      <span class="filter-label">Sort:</span>
      <select class="sort-select" onchange="renderResults()" id="sortSelect">
        <option value="maturity">Maturity (Crawl → Run)</option>
        <option value="name">Name A–Z</option>
        <option value="setup">Setup Effort</option>
        <option value="enable">Enablement Effort</option>
      </select>
    </div>
    <div class="fav-bar">
      <div class="fav-tab active" id="tabAll" onclick="switchFavTab('all')">All Workflows</div>
      <div class="fav-tab" id="tabFav" onclick="switchFavTab('fav')">⭐ My Favourites <span class="fav-count" id="favCount">0</span></div>
    </div>
    <div id="resultsContainer"></div>
    <div style="text-align:center;margin-top:24px">
      <button class="btn btn-ghost" onclick="startOver()">← Start Over</button>
    </div>
  </div>

</div>

<script>
const WORKFLOW_DATA=[{"id":"WF-100","name":"Basic Risk Tracking with Playbooks","maturity":"Crawl","components":["CTAs (Manual)","Playbooks","CTA Reasons"],"valueDrivers":["Retention","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Common types of risk are defined with specific playbooks to consistently address risk.","discoveryQuestions":"How do you manage customers at risk?\nWhat are the common reasons for risk?\nWhat processes/technology do you use to monitor/mitigate risks?","workflowUserStories":"* As a CSM, I can track and manage customer risks easier by utilizing the predefined playbooks. This allows me to create a repeatable, scalable process, which I can adjust by customer where necessary.","gettingStartedGuide":"Top Risk Playbook Recommendations:\n\n \u2022 Adoption Risk Playbook\n\n \u2022 Loss of Power User Playbook (Sponsor/Exec/Admin Risk)\n\n \u2022 Product Risk Playbook\n\n* Support Risk Playbook (Too many, too little support tickets within a timeframe, escalated support risk, multiple bugs)\n* Company Risk Playbook: M & A, Bankruptcy, Layoffs\n* Sentiment Risk Playbook\n* Engagement Risk Playbook: Customer hasn\u2019t been responsive\n* Value Risk Playbook: Customer Expressed they aren\u2019t seeing value\n\nRisk CTA\n\n \u2022 Create a risk CTA to have eyes on it and deal with it, flag as necessary\n\nTimeline Updates\n\n \u2022 Update timeline frequently and include executives using the @mention\n\nGhost Email\n\n \u2022 Send ghost email to executives when customer is non-responsive\n\nRisk Dashboards/Reports\n\n \u2022 Create a risk dashboard that illustrates trends, road blocks, open risks by type, risks with renewal within 90 or 120 days, time to close, open risks without weekly update, ARR at risk\n\nWeekly Digest to Execs with Open Risks + Updates\n\n\n\n","outcome":"Reduce Risk / Churn,Increase Customer Facing Teams Impact","stream":"Identify and Manage Risk"},{"id":"WF-101","name":"Automated Risk Alerts with Playbooks","maturity":"Walk","components":["Rules Engine","CTAs (Automated)","Playbooks","Email Assist"],"valueDrivers":["Retention","Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Proactively use the data from your CRM, Scorecard, Timeline, and more, to automatically trigger Risk alerts.","discoveryQuestions":"* Describe your current risk process today. How confident are you in your ability to identify accounts at risk?\n* Who needs to be involved in mitigating and solving risk? Do all of those people have access to GS?","workflowUserStories":"* As a CSM, I can track and manage customer risks easier by automatically triggering CTAs for Risk based on Timeline Entries.","gettingStartedGuide":"* Define Risk and Escalation. When risk happens, capture it using the risk activity type on Timeline. \n* Create a rule that triggers when a risk activity has been added and generates the correct risk CTA, using the correct risk Playbook based on the timeline entry.\n* Showcase the Risk CTA on risk Dashboards and utilize notification and emails as needed.\n* Risk Escalation Process\n\n","outcome":"Reduce Risk / Churn,Improve Adoption Depth and Breadth","stream":"Digital Led Signals and Resolution Programs"},{"id":"WF-102","name":"Automatic Alerts about Customers and Stakeholders","maturity":"Run","components":["Company Intelligence","Sponsor Tracking","CTAs (Automated)"],"valueDrivers":["Retention","Scale","Expansion"],"setupEffort":"Low","enablementEffort":"Low","description":"To provision alerts for key personnel changes and important company updates","discoveryQuestions":"1. Thinking about the process today, how are users alerted to important organisational changes affecting your customers? Is much manual effort involved and could it be more streamlined?\n2. How do you monitor stakeholder alignment? Are you aware of stakeholder changes before or after the event, or perhaps not at all?\n3. What type of automated alerts about your customers and their key stakeholders, would be important for you to know about?","workflowUserStories":"* As a CSM, I want to be proactively alerted about specific happenings with my customers and associated stakeholders.","gettingStartedGuide":"1. Have your Gainsight admin review the following support articles: -\n  1. Company Intelligence Overview\n  2. Configure Company Intelligence\n  3. Company Intelligence Usage Data in Reporting and Dashboards\n  4. Sponsor Tracking Overview\n  5. Configure 360 Sponsor Tracking Section\n2. Have your CSM team provide a shortlist of information that would be important to them to know about in terms of company updates and stakeholder changes.\n3. Start thinking about how you could use playbooks and CTAs to automatically alert users.","outcome":"Reduce Risk / Churn,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Digital Led Signals and Resolution Programs"},{"id":"WF-103","name":"Red Accounts Process for Top Accounts","maturity":"Crawl","components":["Scorecard","Timeline","Scorecard Mass Edit","CTA Reasons","Rules Engine"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Regular process to provide risk updates, discuss status and align on next steps with prioritized accounts.","discoveryQuestions":"What is the process to escalate risks to management?\nIs there a clear understanding of what risks should be escalated?\nWhat processes/technology do you use to monitor and mitigate risks?","workflowUserStories":"* As a CSM, I want to review the health score of customers in my portfolio that are in Red and develop a mitigation plan for the at-risk customers.\n* As a CS Leader, I want to review the health score of At-Risk customers managed by CSMs in my team and coach the assigned CSM.\n* As a CS Executive I want to see how our ARR is distributed across the customer base, so I can rank customers by ARR and know which CSM and CSM Managers are accountable for securing the ARR of our hightest and lowest paying cusotmers.","gettingStartedGuide":"Use Flagged Risk CTAs to identify top at-risk customers\n \u2022 CSM creates a Risk CTA in Cockpit, selects appropriate Reason and flags those to be escalated to for visibility\nCreate \"CX Risk Status\" Scorecard Measure\n \u2022 Configure rule to change CX Risk Status measure Red and exclusion rule to change overall customer health score to Red in Scorecard, when a Risk CTA is flagged\nEstablish status update process\n \u2022 Require regular Timeline updates via Scorecard measure or flagged CTA, including status & next steps\nCreate Risk Dashboard\n \u2022 Configure Reports with trend, revenue, status\nImplement Weekly Business Review (WBR) process for risk escalation\n \u2022 Add updates to Timeline during WBR; use @mention for collaboration","outcome":"Reduce Risk / Churn","stream":"Identify and Manage Risk"},{"id":"WF-104","name":"Post-Churn Root-Cause Analysis","maturity":"Walk","components":["CTA Reasons","Surveys"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Low","description":"Analyze each customer churn to understand the trends around why your customers leave.","discoveryQuestions":"* Do you understand top reasons customers churn?\n* Are you able to report on why customers churn?\n* If you are recording why customers churn, how are you doing so? Differences in segment?","workflowUserStories":"* As a CSM, I want to be able to analyze each customer churn to understand the trends around why customers have left.\n* As a CS leader, I want to be able to analyze each customer churn to understand the trends around why customers have left.","gettingStartedGuide":"* Design a Survey which collects reason for churn details and consider aptitude to re-engage in future from the CSM or Primary Account Owner\n* Reason Codes: Define both Primary Churn Reason Codes and Contributing Factor Codes to be used for consistency and for purposes of analyzing trends through\n* Target survey to be sent when a customer stage updates to \u201cChurn\u201d or similar\n* You may also leverage an external Post churn survey to send to customer to gather their feedback as well","outcome":"Reduce Risk / Churn","stream":"Post Churn Analysis and Insights"},{"id":"WF-105","name":"Risk Management Across Your Portfolio","maturity":"Walk","components":["CTA Reasons","Timeline"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Low","description":"CSMs consistently track status and note help needed for at-risk accounts, engaging with managers and executives in a regular risk review process.","discoveryQuestions":"* What is your current risk management process?\n* Would this new workflow increase visibility and cross-functional collaboration or decrease it?\n* What would be the risk of not implementing this workflow?\n* What would your team need to do over the coming weeks to launch this new workflow?\n* Who else needs to be included in this process to ensure its successful execution?","workflowUserStories":"* As a CSM, I can easily identify and quickly address risks across my portfolio or book of business by apply the necessary Playbook and making the necessary adjustments, if needed, by customer.","gettingStartedGuide":"* Set up a standard risk CTA object that can be manually triggered by CSMs\n* Agree to a standard protocol of what information should be included in CTA\n* Have CSM tag key internal stakeholders (managers/executives) for visibility\n* Set up a standard, recurring risk review meeting for at-risk accounts to be discussed\n* Agree to action plan and document next steps\n* Have CSM monitor and communicate risk status until closed","outcome":"Reduce Risk / Churn","stream":"Identify and Manage Risk"},{"id":"WF-106","name":"Cross-Functional Risk Programs","maturity":"Run","components":["CTA Reasons","Timeline","Viewer Licenses","Journey Orchestrator"],"valueDrivers":["Retention"],"setupEffort":"High","enablementEffort":"Medium","description":"Improve risk resolution by enabling other teams to be notified and to actively manage risks.","discoveryQuestions":"* What are the common types of risks our customer\u2019s experience? (EX: low adoption, lack of ROI, loss of exec stakeholder)\n* What other teams would provide value via collaboration to mitigate risks? (EX: product team for product risk, support team for support risk)\n* How are we operationalizing the risk management process today?","workflowUserStories":"* As a CSM, I can work across departments to meet the needs of different risks identified by customers to work towards resolution for customers.","gettingStartedGuide":"* Automated and/or manual CTAs should be triggered to identify common at-risk situations.  Depending on the CTA Risk Reason the Owner may be the CSM or a member of another team (EX: Product risk can be assigned to a product manager, support risk assigned to support rep). Specific tasks within a playbook may be assigned to members of other teams to own, again depending on risk reason and tasks necessary to mitigate the risk\n* Viewer or Viewer + Licenses can be assigned to members of other teams to provide visibility into customer information via the Team View SFDC widget\n* Journey Orchestrator programs can be created to proactively notify other team members of customers that may be at-risk. Reports can be shared with other teams via Journey Orchestrator to provide a comprehensive overview of all at-risk accounts in a shared book of business.  For example, all accounts in red overall health, or low depth and/or breadth of adoption, accounts with an open risk CTA, etc.\n* Targeted Journey Orchestrator programs can notify members of other teams that a specific account of theirs is at-risk as well based on a variety of factors identifying the risk","outcome":"Reduce Risk / Churn","stream":"Identify and Manage Risk"},{"id":"WF-107","name":"Establish a Channel for Exec-to-Exec Feedback","maturity":"Walk","components":["Email Assist","Journey Orchestrator"],"valueDrivers":["Adoption","Scale","Expansion"],"setupEffort":"Low","enablementEffort":"Low","description":"Automatically check in with key stakeholders with a direct channel back to CS leadership (via the \u201cReply To\u201d address).","discoveryQuestions":"* Do you have a process to determine key executive stakeholders?\n* What is your current Exec to Exec process?","workflowUserStories":"* As a CSM, I can direct my customers to engage in exec-to-exec conversations by replying to an automated email.","gettingStartedGuide":"1. Create a journey: Create a new journey in Gainsight's Journey Orchestrator feature. You can use a pre-built template or create a custom journey.\n2. Define the journey steps: Define the steps in the journey, including the check-in message, the timing of the message, and the recipients of the message. You can use Gainsight's segmentation features to target specific groups of stakeholders.\n3. Add the \"Reply To\" address: In the message step of the journey, add the CS leadership email address to the \"Reply To\" field. This will allow stakeholders to reply directly to CS leadership if they have any feedback or concerns.\n4. Test and launch the journey: Test the journey to ensure that it is working correctly, and then launch it to start sending messages to stakeholders.\n5. Monitor feedback and respond: Monitor the replies that come in and respond to any feedback or concerns that stakeholders have. This will help to build trust and strengthen the relationship between CS leadership and stakeholders.","outcome":"Optimize Customer Journey,Increase Lifecycle Automation,Increase Expansion Velocity","stream":"Gather and Manage Customer Feedback"},{"id":"WF-108","name":"Programmatic Executive Engagement and Alignment","maturity":"Run","components":["Custom Fields","Email Assist","CTA Reasons","Timeline"],"valueDrivers":["Adoption","Scale","Expansion"],"setupEffort":"High","enablementEffort":"High","description":"Ensure you engage regularly with the right stakeholders to understand goals and address issues.","discoveryQuestions":"1. Tell me about your engagement model: who are the key personas you want CSMs to engage & in what frequency?\n2. How are your CS leaders currently monitoring stakeholder alignment across CSM\u2019s assigned accounts?\n3. How do CSMs track/document meeting notes, attendees, and sentiment currently?","workflowUserStories":"* As a CSM, I want to be able to engage regularly with the right stakeholders to understand goals and address issues.\n* As a CS leader, I want to have visibility into the right stakeholders to be able to regularly engage, understand goals and address issues.","gettingStartedGuide":"1. Identify key stakeholders across accounts that CS teams must continuously engage\n2. Assign personas to key stakeholders in Gainsight (similar to what we have with Pam/Sally/Olivia etc.) & establish engagement cadences \n3. Create dashboards to track stakeholder alignment across CSM BoBs, consider making SA a KPI for CS teams","outcome":"Optimize Customer Journey,Increase Lifecycle Automation,Increase Expansion Velocity","stream":"Identify Potential Advocates"},{"id":"WF-111","name":"Manually Collect and Review Customer Goals","maturity":"Crawl","components":["Custom Fields"],"valueDrivers":["Retention","Expansion"],"setupEffort":"Low","enablementEffort":"Medium","description":"Document customer goals and the date of last goal review in the Customer 360 view.","discoveryQuestions":"What key goals are your customers trying to achieve?\nWhere do you currently document customer goals?","workflowUserStories":"* As a CSM , I can use it as a single place to get customer goals set and review it with them . I can also add success plans towards the goals and share the details and efforts and plancs with customer on regular basis.\n* As a CS Leader , i can use this information to allign goals and standardize plan accordingly","gettingStartedGuide":"Goal Collection\n \u2022 Understand and document customers' desired business outcomes, goals, & pain points they are trying to solve\n \u2022 This will eliminate working backwards in the hand-off from PS and will lead to faster adoption\n \u2022 Use Surveys to collect these goals at scale\n \u2022 Standardize survey questions to address your common customer goals/business challenges to control variance\nRecording Goals\n \u2022 Ensure a record of collected customer goals are visible and accessible in GS for all to access\n \u2022 Document customer goals in Success Plan info, C360, Timeline\n \u2022 Create custom fields in Success Plan info, attributes section, or Timeline to match your standardized survey questions\n","outcome":"Improve Customer ROI,Increase Expansion Velocity","stream":"Collect + Confirm Goals"},{"id":"WF-112","name":"Automate the Sales to Post-Sales Info Transfer","maturity":"Crawl","components":["Custom Fields","Rules Engine"],"valueDrivers":["Retention","Adoption","Scale","Expansion"],"setupEffort":"Low","enablementEffort":"High","description":"Bring key details from the Opportunity (CRM) into Gainsight to assist with the transition from Sales to Post-Sales.","discoveryQuestions":"What does your hand-off process from sales to post-sales entail?\nHow is relevant information shared between teams involved in the hand-off process?\nAre roles/expectations clearly defined for internal teams?","workflowUserStories":"* As a CSM, I want to automate the sales to post-sales knowledge transfer from cross functional teams to help provide the best experience for my customer\n* As a CS Leader, I want to utilize automation for my teams to become more efficient and ensure that all information from pre-sales is passed on to post-sales teams.","gettingStartedGuide":"Automate key information in the Handoff\n\n \u2022 Capture Pre-Sales goals, metrics, and/or value drivers in Salesforce (Opportunity)\n\n \u2022 Utilize pre-sales info captured anywhere in SFDC or other systems and send to Gainsight via available connectors\n\n \u2022 When a deal is Closed/Won, automatically create a Customer Goal and Success Plan in Gainsight with those goals/metrics/value drivers using Rules Engine & Success Plan templates\n\n \u2022 Assign the Success Plan to a CSM\n\n* Automate Milestone on Customer Journey widget on C360\n\nCapture & Publish Additional Pre-Sales Details\n\n \u2022 In a Survey + JO Program, query the pre-sales team for info the Post-Sales team needs that wasn't captured already. This will be accessible via the Company record in perpetuity.\n\n \u2022 Create a JO Program that takes the details mentioned above and send it all to the internal Onboarding Team and CSM via email\n\n \u2022 Expose the survey on C360 for future reference\n\n","outcome":"Improve Customer ROI,Optimize Customer Journey,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Standardize Best Practices"},{"id":"WF-113","name":"Automatically Collect Customer Goals","maturity":"Walk","components":["Surveys","Journey Orchestrator","Rules Engine","Custom Fields"],"valueDrivers":["Retention","Scale","Expansion"],"setupEffort":"Medium","enablementEffort":"High","description":"Survey customers to understand their top goals and definitions of success, and review progress towards those goals on a regular basis.","discoveryQuestions":"* Do you have a value realization plan or framework?\n* How are you currently capturing customer goals and or achieving outcomes?\n* How do you currently measure progress towards goals?","workflowUserStories":"* As a CSM, I want to be able to define the goals for a customer and track progress towards those goals in a consistant way across my book of business.\n* As a CS Leader, I want to undertand how consistent goals are defined for each customer in a CSMs portfolio as well as the efficiency in which goals are achieved.","gettingStartedGuide":"* Outline value realization plan with internal stakeholders\n* Create and map survey questions back to value realization plan\n* Create execution plan involving success plans and workflow","outcome":"Improve Customer ROI,Increase Lifecycle Automation,Increase Expansion Velocity","stream":"Collect + Confirm Goals"},{"id":"WF-114","name":"Document Verified Outcome or Value Acheived","maturity":"Crawl","components":["Timeline"],"valueDrivers":["Retention","Expansion"],"setupEffort":"Low","enablementEffort":"Medium","description":"Use Timeline to document customer value / ROI realized as part of using your solution.","discoveryQuestions":"1. What are the top-line metrics that matter most to your customers? These would be considered \u201cend goal\u201d lagging types of metrics. \n2. Are there supporting metrics that help your customers achieve value incrementally? These are called \u201cleading indicator\u201d metrics and typically are achieved more quickly (and in advance of) the \u201cend goal\u201d metrics. \n3. In addition to enabling your team on how to capture VOs in Gainsight, you also need to enable them on how to discuss the value of your platform, along with the types of metrics that customers are most likely to achieve (#\u2019s 1 & 2 above).  ","workflowUserStories":"* As a CSM, I want to create outcomes of my customer and track the progress against it .\n* As a CS Leader , I can use this information of how well the progress is done by CSMs using a report on outcomes and tasks.","gettingStartedGuide":"1. Create a \u201cVerified Outcome\u201d timeline activity type.\n2. Templatize \u201cVO\u201d timeline activity type fields for consistency and easy reporting. Examples include:  Type of VO (quantitative or qualitative), % improvement, before and after metric, Type of Metric (GRR, NRR, Efficiency Improvement, Expansion $ Closed/Won, etc.).\n3. Consider process changes needed to support collection of Verified Outcomes. Examples include: VOs discussed in EBRs (and slideware to support), VO achievement as part of CSM incentive compensation. \n","outcome":"Improve Customer ROI,Increase Expansion Velocity","stream":"Track Goals and Communicate Value"},{"id":"WF-115","name":"Customer Success Planning","maturity":"Walk","components":["Success Plans","Timeline","Success Plan Templates","Playbooks"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Low","description":"Use Success Plans to create a roadmap and track progress towards achieving your customer's strategic objectives.","discoveryQuestions":"* What does Success mean to you?\n* How does a customer achieve value with your product?\n* What are your specific goals and objectives for the upcoming period? (include metrics and KPIs)\n* What are the challenges you anticipate?\n* What kind of support and accountability do you need to ensure you stay on track towards your goals?","workflowUserStories":"* As a CSM, I want to use Success Plans to create a roadmap and track progress towards achieving my customer's strategic objectives.","gettingStartedGuide":"*  Define SMART goals with Customer\n*  Identify key stakeholders responsible for executing success plan\n* Define Success Milestones/Key Moments of Truth\n*  Develop action plans and tasks\n*  Assign responsibilities and deadlines\n*  Constantly review progress and make changes","outcome":"Improve Customer ROI","stream":"Track Goals and Communicate Value"},{"id":"WF-116","name":"Cross-Functional Customer Success Planning","maturity":"Run","components":["Success Plans","CTA Reasons"],"valueDrivers":["Retention","Scale","Expansion"],"setupEffort":"Low","enablementEffort":"Medium","description":"Enable disparate teams to collaborate on a single set of customer goals for shared success.","discoveryQuestions":"* Do all customer facing roles have a view license or higher in Gainsight.\n* Do you have multiple customer facing roles.","workflowUserStories":"* As a CSM, I need the ability to collaborate with disparate teams on a single set of customer goals for shared success, track progress and measure success.","gettingStartedGuide":"* Set customer goals: Use Gainsight's Customer Goals feature to set customer-specific goals that are aligned with their business objectives. This might include goals related to revenue, customer satisfaction, or other key performance indicators (KPIs). \n* Assign goals to specific users: Assign goals to specific users or teams within your organization who are responsible for achieving them. This will help to ensure accountability and drive action towards achieving the goals. \n* Track progress: Use Gainsight's reporting and analytics features to track progress towards customer goals. This will allow you to see how well your customers are doing in achieving their goals and identify areas for improvement. \n* Collaborate with customers: Use Gainsight's collaboration features, such as comments and chat, to facilitate communication and collaboration with your customers. Encourage them to share their progress, concerns, and feedback on the goals. \n* Measure success: Use Gainsight's reporting and analytics features to measure the success of your customer goals. This will help you determine whether you are achieving your desired outcomes and make data-driven decisions.","outcome":"Improve Customer ROI,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Collect + Confirm Goals"},{"id":"WF-117","name":"Joint Success Planning","maturity":"Run","components":["Success Plans","CTA Reasons"],"valueDrivers":["Retention"],"setupEffort":"High","enablementEffort":"High","description":"Enable direct collaboration with customers towards a shared set of goals.","discoveryQuestions":"How do you measure Value delivered for your customers? \nAre CSMs tracking and measuring outcomes for their customers? \nHow do you show ROI? ","workflowUserStories":"* As a CSM, I need the ability to directly collaborate with customers towards a shared set of goals.","gettingStartedGuide":"1. Defining the desired outcomes and objectives of the Success Planning strategy, such as increasing customer satisfaction, reducing churn, or increasing revenue.\n2. Identifying the key metrics that will be used to measure progress towards these goals\n3. Establishing a baseline for these metrics, so that progress can be tracked and evaluated over time.\n4. Identifying the customer segments that will be targeted by the Success Planning strategy, based on factors such as their needs, goals, and level of engagement with the product or service.\n5. Developing a plan for communicating the Success Planning strategy to relevant stakeholders, such as customer success teams, sales teams, and senior management.\n\n\n","outcome":"Improve Customer ROI","stream":"Collect + Confirm Goals"},{"id":"WF-118","name":"Establish a Consistent Renewal Process","maturity":"Crawl","components":["Rules Engine","CTA Reasons","Playbooks","Email Assist"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Automatically alert a CSM when a renewal is upcoming, with a defined set of steps and templates to complete the renewal consistently and on time.","discoveryQuestions":"* Do you have visibility of all your renewals?\n* Does your organization require paperwork or confirmation of renewals, or are they automatic (are renewals passive or active?)\n* Are there standard price increases each renewal period\n* Do your CSM\u2019s know what to do with upcoming renewals\n* Do you have a process today that your CSM\u2019s follow for upcoming renewals\n* Are notifications to your clients automated or manually created\n* ","workflowUserStories":"* As a CSM, I want to be automatically alerted when a renewal is upcoming, with a defined set of steps and templates to complete the renewal consistently and on time.","gettingStartedGuide":"*  Set up Reports to identify upcoming renewals\n* Create Widgets on Home/Dashboards\n* Creating CTA\u2019s to be assigned to CSM\u2019s for notification of upcoming renewals\n* Application of Playbooks/tasks for steps on how to address the renewal\n  * include email automation for simple surveying of client on whether they expect to renew\n  * include notifications for Sales partners if there are expansion opportunities (if applicable)\n  * include steps for Risk Remediation if notification is provided that there will not be a renewal\n* ","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-119","name":"Track Key Renewal Interactions","maturity":"Crawl","components":["Timeline","Email to Timeline","Gainsight Assist","Sally Slackbot"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Low","description":"Ensure all communications related to renewals, including emails and internal chats, are logged and tracked to maintain a comprehensive record of each renewal process.","discoveryQuestions":"* How does your organization currently track communications related to renewals?\n* What challenges have you faced in maintaining visibility into the renewal process?\n* Are there any existing tools or processes in place that can be leveraged or improved upon for tracking renewal interactions?","workflowUserStories":"* As a CSM, I want to ensure all communications related to renewals, including emails and internal chats, are logged and tracked to maintain a comprehensive record of each renewal process.","gettingStartedGuide":"* implement a system for logging all renewal-related communications, including emails and internal chats\n* Train team members on the importance of logging communications and using tools such as Timeline, Gainsight Assist, and Sally Slackbot\n* Regularly review and update logged interactions to ensure accuracy and completeness","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-120","name":"Manage Commercial Approvals in Gainsight","maturity":"Walk","components":["Timeline"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Low","description":"Bring approvals for special asks during renewal out of email inboxes and into Gainsight where everyone can see them.","discoveryQuestions":"How are you monitoring special asks from clients during the renewal process? What IS your renewal process? \nWhat visibility do you have into key risk signals at your clients that tell you who may not renew?  \nDo you often have surprise churn and/or low GRR? ","workflowUserStories":"* As a CSM, when I notice an upsell opportunity, I want to make sure that all the right parties are involved and provide visibility into that proces.\n* As a CS Leader, I want to review and approve any special requests regarding upsell opportunities identified from my csms.","gettingStartedGuide":"Develop a systematic renewal and forecasting process, via playbooks, CTAs, or other and track compliance via reports/dashboards \n\n\n\nUse Required fields or timeline created tasks to capture customer\u2019s desired renewal/commercial requests via Timeline or in a CTA\n\n\n\nIntegration with CRM or other core customer data systems to send signals or approval notifications to key approvers \n\n\n\nExample - at Gainsight, we have configured a CTA type called Approval to obtain approval for new processes from CSMs. The CTA would contain custom fields for -\n\n* Approval Status (checkbox)\n* Approved By\n* Approval Date\n* Approval Comments\n\nOnce the CTA is assigned to the CSM or Approval Manager, he/she would approve/reject the process, update the relevant fields and close the CTA. A rule can be used to load approval status from the CTA to the corresponding field on the Opportunity object. ","outcome":"Increase Renewal Forecast Accuracy","stream":""},{"id":"WF-121","name":"Prioritize Risky or Slow Renewals","maturity":"Run","components":["Renewal Center"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Low","description":"Use Renewal Center to take advantage of powerful machine learning to identify individual renewals that need more attention.","discoveryQuestions":"* What information is currently shared between CSM\u2019s, Sales Reps and both group\u2019s management teams that allow for collaboration on shared opportunities? \n* How are historical factors currently being reviewed to know what actions taken by your team will make the biggest impact on successfully winning renewals/upsells?\n* How are you reviewing renewal metrics across different customer segments or key attributes to ensure the right process is in place for different customers? ","workflowUserStories":"* As a CSM, I need to be made aware of at risk Renewal Opportunities in a clear and reliable way, so that I can focus my attention on mitigating risky situations to minimize the risk of customer churn.\n* As a Renewals CS Leader, I want to leverage data and historical pattern driven metrics to highlight specific Renewal Opportunities that present the highest risk of churning, so that I can spend less time \"predicting\" the potential outcome of a renewal and more time (and more quickly) focus my attention on the riskiest ones.","gettingStartedGuide":"* Have your organization\u2019s CRM data integrated with Gainsight (specifically, Opportunities)\n* Have past opportunity data integrated into Gainsight to help provide better data for historical trends and identify the factors that most impact opportunities\n* Make sure pre-req workflow is in place and that opportunity roles have been clearly defined (who does what as part of a renewal or upsell)","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-122","name":"Holistic View of your Renewal Pipeline","maturity":"Crawl","components":["Dashboards"],"valueDrivers":["Retention"],"setupEffort":"Low","enablementEffort":"Medium","description":"Dashboard that pulls together the most important details about upcoming Renewals from Gainsight, your CRM and other systems into one view. Visibility across all renewals drives prioritization and escalations across customers for at risk renewals.","discoveryQuestions":"* Tell me about your renewal process. How do you ensure accurate forecasting?\n* Tell me about how you forecast renewals today. How confident are you in its predictability?\n* How does your process today affect employee satisfaction/attrition? \n* What process improvements would benefit teams or reduce friction? ","workflowUserStories":"* As a CSM, I want visibility across all my renewals to guide prioritization and to highlight at risk renewals.\n* As a CS Leader, I want to review the renewal pipeline for my managed CSMs to ensure at risk customers are being prioritized.","gettingStartedGuide":"* Establish a consistent renewal process - Automatically alert a CSM when a renewal is upcoming ,with a defined set of steps and templates to complete the renewal consistently on time.\n* Integrate with core data","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-123","name":"Improve Forecasting with CSM Insights","maturity":"Walk","components":["Custom Fields","CTAs (Automated)","Renewal Center"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Improve renewal forecasts by asking for an input to indicate likelihood to renew from an internal perspective.","discoveryQuestions":"* How surprised are you by churn today?\n* How involved are CSMs today to help forecast?","workflowUserStories":"* As a CSM, I want to easily determine update my C360 and Scorecards to provide insight into upcoming forecasts for renewal and expansions\n* As a CS Leader, I want to easily determine our potential forecasting broken down by each CSM on my team","gettingStartedGuide":"1. Create a custom field in the Account object called \u201cInternal Renewal Likelihood.\u201d This field should be a picklist with values ranging from \u201cVery Unlikely\u201d to \u201cVery Likely.\u201d\n2. Add this field to your Renewal Opportunity page layout in Gainsight.\n3. Train your internal teams to fill out this field when they have conversations with customers. Encourage them to be honest and accurate in their assessment of the customer\u2019s likelihood to renew.\n4. Use this data to supplement your existing renewal forecasting models. For example, you can create a report that shows the percentage of accounts that are \u201cVery Likely\u201d to renew, and use this data to adjust your renewal forecast accordingly.","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-124","name":"Improve Forecasting with Customer Input","maturity":"Walk","components":["Journey Orchestrator","Surveys","Custom Fields","Renewal Center","CTAs (Automated)"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Low","description":"Survey the economic buyer ahead of renewal to gauge likelihood to renew from the customer\u2019s perspective.","discoveryQuestions":"* How are your teams forecasting renewals today?\n* How accurate has your forecasting been over the last 2 years?\n* Are you collecting customer input to help with forecasting?","workflowUserStories":"* As a CSM, I'd want to know which customer is up for a renewal and gauge likelihood of renewing from customer's POV via scorecard or other field that can be closed out once renewal is closed.","gettingStartedGuide":"* Use a Survey to kick off the pre-renewal workflow, asking your customers if they intend to renew: Refer to \u201cLikelihood to Renew Survey\u201d Solution in Sightline Vault for best practices and downloadable assets\n* Journey Orchestrator emails the survey to customers 135 days ahead of renewal date, and triggers a CTA for the CSM when there is no response or if the customer responds that they are unlikely to renew\n* Create likelihood to renew reports based on customer responses & CTA follow-up data","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-125","name":"Centralize Renewals for Accurate Forecasting","maturity":"Run","components":["Renewal Center","CTAs (Automated)","Timeline"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Centralize renewal operations into Renewal Center to access the most up-to-date renewal data, even while collaborating across teams.","discoveryQuestions":"* Do you have a clear understanding of upcoming renewals?\n* Do you have clearly defined roles across departments for your renewal process?\n* Are at-risk renewals handled differently than healthy renewals? If so, how? ","workflowUserStories":"* As a CSM, I want an easy way to see the most up to date renewal information for my accounts.","gettingStartedGuide":"* Configure Renewal Center\n* Create a custom forecast field in RC for CS to quantify renewal likelihood with a numeric confidence level\n* For any and all renewal update notes, have all departments leverage the Timeline Tab within a customer\u2019s forecasted renewal and @ mention all teammates that need visibility","outcome":"Increase Renewal Forecast Accuracy","stream":"Identify and Manage Risk"},{"id":"WF-126","name":"Validate Renewal Stakeholders","maturity":"Walk","components":["Surveys","Journey Orchestrator","CTAs (Automated)"],"valueDrivers":["Retention","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Survey your customers ahead of renewal to confirm the correct audience before starting the next renewal conversation.","discoveryQuestions":"* What does your renewal process entail?\n* Who are the typical stakeholders involved?\n* How do you make sure you are engaging with the right stakeholders?\n* What steps do you follow to keep stakeholder information up to date?","workflowUserStories":"* As a CSM, I want to have confidence that my Stakeholder information is accurate and up to date. Furthermore, if it is not, I want a way to endure that it is updated.\n* As a CS Leader, I need assurance that my team is having conversations with the customer at the correct level. Additionally, I want to be able to see if my CSMs are on top of any changes in leadership that have occurred at the customer.","gettingStartedGuide":"* Build program that sends survey to core customer contacts\n* In program, include automated CTAs based on client responses. I.e. prompt additional personalized outreach should a change in stakeholders be identified\n* Include responses on C360 as related list for easy reference","outcome":"Increase Renewal Forecast Accuracy,Increase Lifecycle Automation","stream":"Digital Led Signals and Resolution Programs"},{"id":"WF-127","name":"Manage Multiple Renewals at Scale","maturity":"Walk","components":["Renewal Center"],"valueDrivers":["Retention","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Efficiently manage a larger book by using Renewal Center's in-line editing to make changes to multiple renewals at a time, in real-time.","discoveryQuestions":"1. How do Renewal Managers organize the renewals they need to work on? What fields do they need to sort the renewal pipeline by?  Do they need to sort by renewal date, risk, size, amount, type, customer health?\n2. What fields do Renewal Managers update frequently that should be available for in-line editing? ","workflowUserStories":"* As someone who owns and manages renewals for multiple customers, I need to quickly and easily make changes to multiple renewals at one time to keep our renewal forecast accurate.\n* As a Renewals CS Leader, I need to quickly and easily make changes to many renewals at one time to keep our renewal forecast accurate.","gettingStartedGuide":"1. Evaluate what fields a Renewal Manager would need the ability to quickly update en masse with just a few clicks.\n2. Evaluate how a Renewal Manager might want to sort or filter their book of business to group renewals together easily to update. ","outcome":"Increase Renewal Forecast Accuracy,Increase Lifecycle Automation","stream":"Identify and Manage Risk"},{"id":"WF-128","name":"Automated Quote Generation","maturity":"Run","components":["Reports","Journey Orchestrator"],"valueDrivers":["Retention","Scale"],"setupEffort":"Medium","enablementEffort":"High","description":"Automatically send Customers a list of their current entitlements ahead of renewal, with instructions for how to finalize an official quote.","discoveryQuestions":"* How much time do your users spend drafting up quotes for customers during their renewal cycle?\n* How regimented are your users at sending out quotes to renewal customers ahead of the renewal?","workflowUserStories":"* As a CSM, I want to let my Customers know what their current entitlements are ahead of renewal automatically. The communication should include instructions for how to finalize an official quote.","gettingStartedGuide":"1. Create a custom email template that includes a list of the customer\u2019s current entitlements and instructions for how to finalize an official quote. Make sure the email template is personalized with the customer\u2019s name and relevant account information.\n2. Set up an automated email campaign in Gainsight that is triggered a certain number of days before the customer\u2019s renewal date. For example, you could set the campaign to trigger 30 days before the renewal date.\n3. Add the custom email template to the email campaign, and set it to be sent to the customer\u2019s primary contact or decision maker.\n4. Include a call-to-action in the email template that encourages the customer to finalize their official quote in Gainsight. This could include a link to a specific page in your Gainsight instance where the customer can complete their quote.\n5. Test the email campaign to make sure it is working as intended, and make any necessary adjustments.","outcome":"Increase Renewal Forecast Accuracy,Increase Lifecycle Automation","stream":""},{"id":"WF-129","name":"Automated Renewal Reminders","maturity":"Run","components":["Journey Orchestrator"],"valueDrivers":["Retention","Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"For \u201copt out\u201d renewals, automatically notify customers that their renewal is upcoming, and the date by which changes can be made or offer an easy one-button-click renewal option with no further discussions. ","discoveryQuestions":"1. When do your opt-out customers typically need to give you notice for contract changes - 30 days before renewal? 60, 90? Do you have a clean renewal date data?\n2. Can some of your customers be offered a simple one-button-click renewal vs a longer conversation regarding pricing and terms? \n3. How do you track customer buyer personas today? What processes do you need to change to make sure you have the right email address for the person who should receive the renewal notification email?\n4. Consider what opt-out customers you would not want to receive an automatic renewal notice and build logic to exclude them from your email process (examples: unhealthy customers, or customers with an open sentiment or product risk). \n5. Consider a value-led approach for the renewal message. Are there certain easy-to-obtain value metrics that could be automatically inserted into the renewal message?","workflowUserStories":"* As someone who owns and manages renewals for multiple customers, I need my customers to be informed about their expiring contracts automatically.\n* As a Renewals CS Leader, I want to give for some of my customers an easy one-button-click renewal option if their contract is not complicated (same terms/conditions and pricing).","gettingStartedGuide":"1. Identify and familiarize yourself with the \u201cstandard\u201d opt-out language in your contracts. This information should be used to help craft the renewal email message. \n2. Identify & track account \u201cbuyer\u201d personas. They will be the recipients of your renewal reminders.\n3. Consult your Account Management teams on the message and \u201cvalue received\u201d information they would like to convey to opt-out renewal customers.","outcome":"Increase Renewal Forecast Accuracy,Increase Lifecycle Automation","stream":"Digital Led Signals and Resolution Programs"},{"id":"WF-130","name":"Automate the Renewal Journey","maturity":"Run","components":["Journey Orchestrator","Renewal Center"],"valueDrivers":["Retention","Scale"],"setupEffort":"","enablementEffort":"","description":"Deploy an automated renewal journey for the majority of customers, allowing more time for renewals that need hands on support.","discoveryQuestions":"","workflowUserStories":"*","gettingStartedGuide":"","outcome":"Increase Renewal Forecast Accuracy,Increase Lifecycle Automation","stream":"Digital Led Signals and Resolution Programs"},{"id":"WF-131","name":"Access and Update CRM Account Records from Gainsight","maturity":"Crawl","components":["Connectors","Rules Engine","Custom Fields","C360"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Make near real-time updates to CRM Account records from the C360.","discoveryQuestions":"What CRM tool do you currently use?\nWhat challenges do CSMs or other teams encounter navigating between systems?\nHow do you ensure data accuracy between multiple systems?","workflowUserStories":"* As a CSM, I want to be able update certain fields/attributes on the Account in Gainsight and have that flow back to the account in SFDC without having to enter the information twice in two separate systems.","gettingStartedGuide":"CRM Connector \n\n \u2022 Pull key customer data into GS from your CRM \n\n \u2022 Identify data inputs to bring over \u2022 not recommended to bring all data over at once. Use CSM feedback to iterate on which data should be pulled into Gainsight \n\n \u2022 Usage data: Pull in behavioral client data\n\n \u2022 Support ticket data: Pull in support ticket data\n\nReports \n\n \u2022 Centralize CRM, Support, and Usage data and reports at the account level in C360, and across multiple accounts on the CSM Dashboard\n\nBi-Directional Data\n\n* Identify Company data field(s) in Gainsight that should update field(s) on the Account Object in CRM\n  * Work with CRM Admin to review field(s) to make sure there is no issue with the updates flowing back to CRM from Gainsight.","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-132","name":"View Supporting Customer Data in Gainsight","maturity":"Crawl","components":["Connectors","Reports","C360"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"C360 sections can centralize information from other systems and teams, like Cases from Support, or Contacts from your CRM.","discoveryQuestions":"What tools and systems do you currently use?\nWhat challenges do CSMs or other teams encounter navigating between systems?\nHow do you ensure data accuracy between multiple systems?\nWhat data insights, reports, and dashboards do you use (outside of your CRM) that are the most important and insightful while either preparing for a customer meeting or simply gathering key customer information. ","workflowUserStories":"* As a CSM, I want to review deeper-level customer insights that are not presented on the c360 Summary page so that I can gain a deeper understanding of my customer's status or experience, so I can best prepare myself prior to enaging with the customer\n* As a Support Analyst, I want to quickly view current and/or open support case details for a customer, so that I can prioritize and/or escalate to the appropriate parties if need be.","gettingStartedGuide":"CRM Connector\n\n \u2022 Identify key customer data stored your CRM (Accounts, Contacts, Opportunities, etc) and include in the CRM connector data mapping to Gainsight MDA. \n\n* Elicit feedback from CSM team to ensure the identified data points are valuable and iterate design if needed. \n\nExternal Data Connections\n\n* Identify key customer data stored in external data source and include data sets to be ingested into Gainsight via the most efficient, alternative integration method (Productized Connector, S3, API, etc). \n* Elicit feedback from CSM team to ensure the identified data points are valuable and iterate design if needed. \n\nReports\n\n \u2022 Create custom reporting and displays to be added to either Customer360 layout or Dashboards. Elicit feedback from CSM team to ensure the data being presented and the visualization type (Tabular report, graph, charts, etc) is meaningful and intuitive. Iterate as needed. ","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-133","name":"Access Other Teams\u2019 Workflows from Gainsight","maturity":"Walk","components":["Connectors","CTAs w/ Linked Objects"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Hook into existing workflows in your CRM without leaving Gainsight.","discoveryQuestions":"* What other systems do your CSMs have to interact with today in order to complete their daily workflows for Customers?\n* What key Customer data is relevant to both pre and post sales teams and where does this data live today?\n* Are there reports that live in your CRM that would ideally be accessible in your Gainsight instance?","workflowUserStories":"* As a CSM, I want to review the product usage data of my clients, and define next steps for my low-usage clients to migiate churn.\n* As a CS Leader, I want to review low product usage to prepare for my meetings with my CSMs and help idenitfy next steps","gettingStartedGuide":"* Recommendation 1\n\n  CRM Connector: Pull in key Customer Data \n\n  Support Ticket Data: Pull in Support ticket \n\n  Usage Data: Pull in key behavioral client data\n\n* Recommendation 2 \n\n  Identify data inputs generated from CS to Push to CRM\n\n  Utilize Report Builder to visualize support or usage data\n\n  Centralize CRM, Support and Usage data and reports at the account level in the C360, and across multiple accounts on a CSM Dashboard \n\n\n* Recommendation 3\n\n  Don\u2019t bring over all data at once, use CSM feedback to iterate on which data should be pulled into Gainsight \n\n  Cross Functional Collaboration- what data from CS should be pushed to other company systems\n\n\n","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-134","name":"View Product Data Trends in Gainsight","maturity":"Walk","components":["Connectors","Adoption Explorer","C360"],"valueDrivers":["Scale"],"setupEffort":"High","enablementEffort":"Medium","description":"An Adoption Explorer C360 section brings rich product usage reporting into the customer view.","discoveryQuestions":"1. Where do you go to pull usage data today?\n2. What insights are most important to your CS teams?\n3. How would you like to see adoption data be leveraged for CS workflows?","workflowUserStories":"* As a CSM, I need to be able to view product data trends to get visibility into adoption risk for CS teams, automate risk mitigation workflows to CSM based on adoption drops and identify advocates, enable process for elevating advocates to community","gettingStartedGuide":"1. Uncover current usage data process (possible PX cross-sell motion)\n2. Demonstrate adoption explorer capabilities via live demo\n3. Establish what reports are needed in AE to obtain valuable insights for CS team","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-135","name":"Define Your Default Customer 360 View","maturity":"Crawl","components":["C360"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"A basic C360 that organizes key customer data and Gainsight applications your team uses for customer management.","discoveryQuestions":"Do you need to regularly access data from other tools or systems?\nAre insights organized in the C360 to quickly understand a customer situation and take action?","workflowUserStories":"* As a CSM, I want to get specific information about a customer in my portfolio so I can be prepared for customer meetings.","gettingStartedGuide":"","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-136","name":"CSM Dashboard for 1:1 Meetings","maturity":"Crawl","components":["CSM Dashboard","Sightline Vault"],"valueDrivers":["Scale","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Gainsight Dashboard filtered to a single CSM\u2019s portfolio to review CSM portfolio metrics and to prioritize customer actions.","discoveryQuestions":"What percentage of CS leaders' time is spent gathering data for CSM 1:1 meetings?\nHow effective are your 1:1 meetings at identifying risks/opportunities?\nWhat specific metrics or data is reviewed in your CSM 1:1 meetings?\nHow are CS leaders gathering data for CSM 1:1 meetings today? ","workflowUserStories":"* As a CS Leader, I want to review my portfolio to easily review metrics, prioritize risks and opportunities, and spend less time preparing for 1:1 meetings.","gettingStartedGuide":"Dashboards\n \u2022 Have a CSM dashboard to get a quick view of your portfolio to prioritize actions\n \u2022 Set-up customized reports to be viewable on Dashboard","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-137","name":"Executive Visibility of the CS Program","maturity":"Walk","components":["Executive Dashboard","Sightline Vault"],"valueDrivers":["Scale","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Board-level insights into customer trends, team performance, and CS team activities.","discoveryQuestions":"How do you currently track data for CSM performance?\nWhere do you capture information about performance against team KPIs/Metrics?\nHow do you collate and distribute information for your board on your CSM team?","workflowUserStories":"* As an executive, I want to be able to track high-level KPIs for my success team and their clients, especially in regards to trend-over-time data\n* As a CS leader, I want to have a quick, accurate, one-stop-shop for all my KPI tracking, both for presenting to executives but also to keep my team informed of performance","gettingStartedGuide":"Define the metrics the board are tracking against\n\n* CS Team KPIs\n* Company KPIs\n* Key Customer trends\n\nIdentify the key CS-driven customer engagements/touchpoints to surface\n\n* EBRs, Stakeholder engagement, NPS\n\nReview Sightline Vault Solutions for Dashboards","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-138","name":"Team and Portfolio Visibility for Managers","maturity":"Walk","components":["CSM Management Dashboard","Sightline Vault"],"valueDrivers":["Scale","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Give managers unparalleled visibility into portfolio and team activities and performance through a CSM Management Dashboard.","discoveryQuestions":"* What are the metrics that the team is responsible for?\n* What is the book of business/segmentation/ARR for CSM\u2019s? ","workflowUserStories":"* As a CSM I need a dashboard showing me the customers who are assigned to me, the ARR of each customer, as well as a set of reports showing any actions that should be taken to address risk or guide the customer through their lifecycle.\n* As CS leader, to lead an informative and relevant discussion in 1:1s with my CSMs, I need to know the specific customers that are assigned to each CSM, the ARR of each customer, as well as a series of reports that show risks, CTAs, and key actions that my CSMs need to be focused on to bring about a successful outcome.","gettingStartedGuide":"* Pre-requisite: Ensure that the user record in Gainsight for each CSM has the name of their manager accurately populated in the Manager field (If Gainsight users are synced from Salesforce, this is handled in the User Sync SFDC connector job, in the derived mapping section)\n* Refer to sightline vault, manager dashboards (See screenshot)\n* Install the three 3 dashboards: exec dashboard, CSM management dashboard, CSM dashboard. (It\u2019s the \u201cExec Dashboard\u201d specifically that has a report showing a list of CSMs by ARR and # of customers. report name: \u201cCustomers and ARR by CSM)\n* Configure a Global Filter: Add a \u201cCSM Manager\u201d global filter to the \u2018CSM Management Dashboard\u2019 and the \u2018Exec Dashboard\u2019.  This filter will have the following click path when defining the configuration: Company ID > CSM ID > Manager ID > then click on the fiield: \u201cName\u201d (see screenshot)","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-139","name":"Specialized Customer Views","maturity":"Run","components":["C360"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Create specialized C360 layouts based on the customer\u2019s business information as required for different entities or users. Layouts can be applied to Companies and users based on criteria such as Company Type or Industry, User Role, etc. For example, you may want to create different layouts for your executives and your CSMs; or you may want to have different layouts for your Enterprise customers, and your SMB customers.","discoveryQuestions":"1. Are there different details that are needed for your different types of customers (either by segment, industry, expertise, etc.)?\n2. Are there users who would benefit from a simplified layout view? \n3. What actions do each of your user types take daily/weekly/monthly? (Prioritize information needed to support more frequent action that needs to be taken). ","workflowUserStories":"* As a CSM, I want to review my customer information using customized views to ensure I have all of the information readily available to maximize time and be more efficient.","gettingStartedGuide":"1. Begin by reviewing the Default Layout and determining what information, tabs, widgets, etc. should be the \u201cdefault\u201d \n2. Audit your users to determine if it makes sense to create multiple layouts based on user persona.\n3. Work with your CS leaders to understand the customer base. Determine if there are different needs for different segments or company industries. ","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-140","name":"Log Key Customer Interactions in Gainsight","maturity":"Crawl","components":["Timeline","Gainsight Assist","Email to Timeline","Sally Slackbot"],"valueDrivers":["Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Make sure all emails, meetings, and interactions are logged so that anyone can access the full history of a customer relationship.","discoveryQuestions":"How do CSMs currently keep track of their book of business?\nHow do CSMs get up to speed about new customers that transition to them?\nWhere are notes about customer meetings stored?","workflowUserStories":"* As a CSM, I want to capture all customer interactions, communications, notes, and activities in one place. I want to be able to easily navigate and locate all key details of past engagements I and or other team members had with the customer.\n* As a CS Leader, I want to be able to understand and review what all activities my CSM has had with the Customer without needing to ask my team to pull their notes together for me. I will have all the details needed to quickly prepare for meetings with my team or with the customer.","gettingStartedGuide":"Track all customer communication (internal/external) in Timeline for global visibility\n \u2022 Use Gainsight Assist or BCC to Timeline to log every customer interaction\n \u2022 Include important attachments when logging activities to document the full scope of communication\nAssign Ownership of Tasks\n \u2022 Use Tasks associated with Timeline entries to assign related action items\nShare Important Notes\n \u2022 @mention and comment from within Timeline to share notes, follow-up, and collaborate","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-141","name":"Visualize Customer Org Hierarchies","maturity":"Run","components":["People Maps"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Use People Maps to configure an org chart to clarify and visualize the hierarchy of stakeholders at a company.","discoveryQuestions":"* How are you currently tracking your hierarchy of stakeholders \n* Do you have a visual chart today on your customer hierarchy and who reports to who?\n* How do you track who owns what products?\n* Do you have visibility into who your champions are and who their influencers are?","workflowUserStories":"* As a CSM, I can visualize my contacts by the role they play within their company.\n* As a CS Executive, I want to provide my team consistent guidance on how to prepare for new customer assignments and create a consistent customer experience for engagement, so that I can reliably review high level healthscore/metrics accross my portfolio and minimize the variability in each customer's experience.","gettingStartedGuide":"* Sync up your CRM data to Gainsight\n* Confirm that contact data going into Gainsight is clean and up to date\n* If data from CRM is using a manager field, then we can use that field to build the structure\n* If they don\u2019t have that structure, then that can be manually created in GS by dragging an dropping people in place","outcome":"Increase Expansion Velocity","stream":"Centralize Customer Data"},{"id":"WF-142","name":"Foundational Health Scoring","maturity":"Crawl","components":["Scorecard","Rules Engine"],"valueDrivers":["Retention"],"setupEffort":"High","enablementEffort":"Medium","description":"Begin benchmarking customer health with a basic scorecard comprised of two measures, Outcomes and Customer Experience.","discoveryQuestions":"Do you have a sense of the health of your customers?\nWhat factors do you use to measure customer health?","workflowUserStories":"* As a CSM, I want to be able to monitor my customer's health and gain visibility to risks as well as opportunities for expansion","gettingStartedGuide":"Data Import\n \u2022 Bring in the relevant data using Connectors, Rules, or Gainsight PX\nDefine Scorecard Schema & Configuration\n \u2022 Identify & assign relevant scoring schema\n \u2022 In the scoring schema, the thresholds have to be set in every perspective\n \u2022 Add appropriate weightage to the measures\n \u2022 Put them into measure groups with relevant weightage to configure a scorecard\nDerive Insights & Provide Visibility\n \u2022 Use the Report builder or the Data Designer-Advanced reporting to derive insights\n \u2022 Build Dashboards with relevant reports for each audience (CSMs, Leadership, Executive)\nDesigning & Layout\n \u2022 Create & embed the apt reports and widgets while editing dashboard layouts\n \u2022 Provide global filters to show processed information\n \u2022 Design dashboards per the targeted user's role and customer segments/stages\n \u2022 Apply filters to assign the right scorecard to the right company at the right stage\n","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-143","name":"Data-Driven Health Scoring","maturity":"Walk","components":["Scorecard","Rules Engine","Connectors"],"valueDrivers":["Retention"],"setupEffort":"High","enablementEffort":"High","description":"Follow the guidance of Gainsight's best-practice health score framework to intelligently include more live data in your score calculations.","discoveryQuestions":"Do you have access to customer data? - How do you know the way your customers are adopting or using your product?","workflowUserStories":"* As a CSM, I want to have more objective ways of measuring a customers health based on their usage of our product.\n* As a CS leader, I want to better understand usage trends and how they align to health so I can work with our product team to get ahead of product risks that lead to churn.","gettingStartedGuide":"Get in touch with your internal data team, assess the top datapoints that are important to have visibility into (like top 3 sticky features), load usage data into Gainsight, then load into a health measure ","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-144","name":"Health Score Overrides","maturity":"Walk","components":["Scorecard Overrides"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Low","description":"Make sure Risks get the attention they deserve by changing the overall score to Red if certain individual measures are Red.","discoveryQuestions":"* What are the key risk factors that could significantly impact your customers' success?\n* How do your current Health Scores account for these critical risks?\n* Are there any instances where the overall Health Score failed to identify urgent issues in a timely manner?","workflowUserStories":"* As a CSM, I want the Overall Health Score to have the ability to be impacted by critical risk factors outside of the standard logic for overall score calculation.\n* As a CS leader, I want to be able to evaluate the actual health and risk associated with my customer accounts to diagnose and correct any systemic issues including critical risk factors.","gettingStartedGuide":"* Identify critical risk factors that warrant an overall score adjustment\n* Configure Scorecard Overrides to change the overall score based on the identified risk factors\n* Monitor and evaluate the effectiveness of the overrides to continuously improve Health Score Predictiveness","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-146","name":"Segment-Based Health Scoring","maturity":"Run","components":["Scorecard","Rules Engine"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Low","description":"Assign special custom measures or scoring criteria to customers based on their revenue segment or strategic value.","discoveryQuestions":"1. How do you currently segment your customer base and what criteria are used?\n2. Do you have an accurate view of customer health across all segments?\n3. How do you share customer health trends across the organisation?","workflowUserStories":"* As a CSM I can better use the scorecard for each segment and that will be more accurate an information than having 1 generic scorecard.","gettingStartedGuide":"Lifecycle Management\n\n* Identify customer segments & lifecycle stages to create a consistent customer journey\n* Assign a scorecard which captures every Measure(dimension) for an account.\n\n\nHolistic Measure of Customer Success\n\n* Alongside the outcomes metrics the CSM\u2019s Assessments, Sentiment & Level of effort responses do play an important role for holistic measurement\n\n\nCustomise the Scorecard Config\n\n* Identify & Assign relevant scoring schema.\n* Add appropriate weightage to the measures which aligns to the best standards.\n* Assign a relevant scorecard based on the stage & segment by choosing the right criteria.\n\n\n\nLayouts & Designing\n\n* Create and embed apt reports, widgets while editing the dashboard layout.\n* Provide global filters to depict processed information.\n* Design the dashboards as per the user\u2019s requirements & Customer Segments/Stages.\n\n","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-147","name":"Partner Health Scoring","maturity":"Run","components":["Scorecard","Rules Engine"],"valueDrivers":["Retention"],"setupEffort":"High","enablementEffort":"Medium","description":"Understand the health of customers managed by your partners based on criteria or measures specific to your partner model.","discoveryQuestions":"Do you/your partners have a view of the health of partner led accounts?\nDoes the existing scorecard accurately reflect measures for your partner?\nIs there data missing from the scorecard which would be useful for partner led accounts?\nWhat insights from health could be used by your partners? (eg surfacing risk or opportunity)\n","workflowUserStories":"* As a CSM, I work with Partners who don't have access to GS and need to visualize key metrics about their Customers.","gettingStartedGuide":"Review the Gainsight DEAR framework for health scoring to understand if a partner scorecard is needed\n\n* What measures are different for your partner framework?\n* Do thresholds need to differ for existing measures?\n* Do new measures need to be introduced?\n* Is data available for automated scorecard updates or do they need to be manually kept?\n* Do partners need to view this scorecard? Do they also need to update it?","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-148","name":"Onboarding Health Scores","maturity":"Run","components":["Scorecard","Rules Engine"],"valueDrivers":["Retention"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Closely monitor the health of net-new customers with custom measures or scoring criteria to better understand customer time-to-value.","discoveryQuestions":"* How important is successful onboarding to your customers and your business?\n* How are you currently tracking metrics around your customer onboarding?\n* Is there cross-functional consensus on how to improve ","workflowUserStories":"* As a CSM, I want to be able to closely monitor the health of net-new customers with custom measures or scoring criteria to better understand customer time-to-value.","gettingStartedGuide":"* Document your onboarding stages/tasks/milestones\n* Gather consensus around success metrics (e.g., completing design review in 2 days, your customer completing training right after kickoff, etc.)\n* Define your metrics and design your dashboard and rules around calls-to-action","outcome":"Improve Health Score Predictiveness","stream":"Identify and Manage Risk"},{"id":"WF-149","name":"Sync Valuable Gainsight Metrics back to your CRM","maturity":"Crawl","components":["Rules Engine","Connectors"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Push valuable datapoints from Gainsight, like Overall Health Score, back to your CRM for use in additional workflows and views.","discoveryQuestions":"* (If applicable) do you have the Gainsight NXT widget enabled already?\n* What is your current workflow for getting this data to people who do not have GS licenses?\n* Which teams will be using the data in their CRM and how will it be used?","workflowUserStories":"* As a CSM, I work with stakeholders who don't have access to GS and need access to see key metrics about my Customers that come out of GS.","gettingStartedGuide":"* Internal stakeholders meet to determine which data points should be pushed to CRM\n* GS admin to meet with CRM admin to map objects correctly from GS to CRM and to determine how often data will sync to CRM\n* Prepare a training for the folks who will have visibility into GS data in the CRM before launch","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-150","name":"Give Other Teams Actionable Insights from Gainsight","maturity":"Walk","components":["Team View Widget","Sally Slackbot","Zendesk Widget","Viewer Licenses"],"valueDrivers":["Scale","Scale","Expansion"],"setupEffort":"High","enablementEffort":"Medium","description":"Share a dynamic view into Gainsight from other collaboration tools with pre-built widgets and apps for Salesforce, Slack, and Zendesk.","discoveryQuestions":"* As a CSM, what tools or data points do you need access to on a daily basis? \n* Which tools outside of Gainsight are important to you (e.g support data)? \n* How do you currently collaborate with other departments across your business to gain insightful customer information? \n* Which teams currently collaborate on customer activities? How do they do this? ","workflowUserStories":"* As a CSM, I can update and track the Customer\ufffds status and note when additional assistance may be needed for at-risk accounts. This allows me to quickly and easily engage with and keep key stakeholders informed throughout the customer lifecycle.","gettingStartedGuide":"* Identification of important data tools needed to undertake work currently outside of Gainsight\n* Identify who is the owner of these tools? What is their purpose? (E.g Zendesk owned by support to handle customer support tickets)\n* Map important data needed from these tools / important information from GS to surface within these tools (e.g Slack) \n* Visualise this data within a widget within the Gainsight C360\n* For Slack, configure Sally to surface important information from Gainsight ","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Enhance Productivity"},{"id":"WF-151","name":"Share Customer Insights with Leadership","maturity":"Walk","components":["Journey Orchestrator"],"valueDrivers":["Scale","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Send scheduled digests of insights from your Portfolio (like Top Risks, Strategic Renewals, and Survey Responses) to key internal stakeholders.","discoveryQuestions":"* Which portion of your job do you think it\u2019s manual / reactive versus automated and high-value oriented?\n* What parts of your job do you think could be automated / streamlined to allow you to focus on high impact activities?\n* Where do you get an aggregated view of your portfolio and of its health? \n* How can your manager / leader view your clients\u2019 health, ARR, renewal dates, risks, etc?\n* What KPIs should have recurring visibility to a greater audience?","workflowUserStories":"* As a CSM, I want to automate my reoccuring reporting of customer KPIs to leadership\n* As a CS leader, I need to see customer KPIs on a reoccuring basis from my CSMs and automating a report with this information will help my team become more efficient while keep leadership up to date on changes to KPIs.","gettingStartedGuide":"1. Identify team and portfolio-related KPIs that execs and managers usually look at;\n2. Build Reports and Dashboards to be shared internally - make sure data is high quality and reliable\n3. Automate subscription to relevant dashboards and reports for the relevant stakeholders","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-152","name":"Export Gainsight Data to an External System","maturity":"Walk","components":["Rules Engine","Gainsight API"],"valueDrivers":["Scale"],"setupEffort":"High","enablementEffort":"Medium","description":"Pull rich Gainsight metadata into external systems for further analysis or historical backup.","discoveryQuestions":"* What are you trying to accomplish by leveraging Gainsight data externally?\n* What data specifically are you hoping to leverage externally and is there a Gainsight API available for the information you are hoping to use?\n* Do you have the development/engineering team resources available to assist with configuration of the APIs?","workflowUserStories":"* As a CSM , i can use this to export data to any external system if we need gainsight data outside to share with customer or with other stakeholder , who do not have GS access\n* As a CS leader, I need to export data to share with other stakeholders or even myself , without having to login.","gettingStartedGuide":"* Identify what data from Gainsight you are hoping to leverage in external tools\n* Secure development/engineering team resources to assist with set up of API scripts","outcome":"Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-153","name":"Share Key Data with Customers","maturity":"Walk","components":["Shared360","Journey Orchestrator"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Drive alignment by giving Customers limited visibility into the same metrics and data your CSMs use as their source of truth.","discoveryQuestions":"1. What usage insights do your CS teams leverage today?\n2. What are your current blockers for sharing externally (legal, technical limitations, CSM enablement)?\n3. How do you want CSMs to share? What motions do you want them to drive with your customers?","workflowUserStories":"* As a CSM, I want to be able to share key data with customers to drive alignment by giving Customers limited visibility into the same metrics and data we use as their source of truth.","gettingStartedGuide":"1. Establish the data needed prior to taking any step toward this workflow\n2. Stand-up Adoption Explorer project to visualize adoption data for CSMs\n3. Establish a workflow for sharing with customers: don\u2019t just share, drive action! ","outcome":"Increase Lifecycle Automation","stream":"Increase User Engagement"},{"id":"WF-154","name":"Basic Lifecycle Stages","maturity":"Crawl","components":["Customer Stages","Reports","Playbooks","CTAs"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"Medium","description":"Track customers through 5 basic lifecycle stages: Onboarding, Adopting, Renewal, Will Churn, and Churned.","discoveryQuestions":"What customer lifecycle stages do you track currently?\nWhere/how do you track this info?\nDo you have a good understanding of average time per stage?\nDo you have defined touch-points/Key Moments of Truth for each stage?","workflowUserStories":"* As a CSM, I need to quickly see and understand what stage my customer is in so I can tailor my services to better serve their specific needs.\n* As a CS leader, I need to have visibility and insights to our customer base's lifecycle stage with my company to better forecast renewals, expansion, and potential churn.","gettingStartedGuide":"-Segment your customers to determine the right Customer Journey for each segment\n \u2022 Clearly identify the \"Key Moments of Truth\" for each segment \u2022 those things that you want to make sure you're delivering on with every customer\n \u2022 Operationalize the \"Key Moments of Truth\" through Lifecycle CTAs, Surveys to capture customer feedback, and Journey Orchestrator to scale\n \u2022 Report on performance around Key Moments of Truth through Reporting & Dashboards\nRecommended Key Moments of Truth to start with:\n \u2022 Sales to Onboarding Handoff\n \u2022 Welcome\n \u2022 Onboarding Kick-Off\n \u2022 Launch\n \u2022 New Executive\n \u2022 Executive Business Review (EBR)\n \u2022 Confirm Value for Renewal\n \u2022 Post-Renewal","outcome":"Optimize Customer Journey","stream":"Identify and Manage Lifecycle Activities"},{"id":"WF-155","name":"Use Stages to Highlight Recently Launched Customers","maturity":"Walk","components":["Customer Stages","Reports","Playbooks","CTAs","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Better track customers coming out of onboarding by layering in a \u201cLaunched\u201d stage that automatically moves to \u201cAdopting\u201d after a pre-determined amount of time that is suitable to your business.","discoveryQuestions":"1) What is the handoff process like at your organization? \n2) Do you have a customer journey defined? How is this displayed in Gainsight?\n3) Do you have different expectations for customer in different stages? ","workflowUserStories":"* As a CSM, I need to track my customers lifecycle journey and specifically identify customers coming out of onboarding.","gettingStartedGuide":"1) Establish a typical Customer Lifecycle (Stages)\n2) Determine proper timing for each stage\n3) Develop rule that updates stage that follows the typical lifecycle(stage) progression ","outcome":"Optimize Customer Journey","stream":"Identify and Manage Lifecycle Activities"},{"id":"WF-156","name":"Advanced Lifecycle Stage Automation","maturity":"Run","components":["Customer Stages","Reports","Playbooks","CTAs","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Automate customer stages to better track customer lifecycle progress, or higher tiers of customer maturity.","discoveryQuestions":"1. How do you know where a customer is in their lifecycle with your product?\n2. What signals do you receive to know if a customer is stalled in a stage with your product?\n3. How do you classify where a customer is at in their customer journey?","workflowUserStories":"* As a CSM, I want to automate customer stages to better track customer lifecycle progress, or higher tiers of customer maturity.","gettingStartedGuide":"1.  Map the stages of your customer lifecycle.\n  * Common stages include\n    * Onboarding\n    * Launched\n    * Adopting\n    * Expanding\n    * Renewing\n    * Churned\n  * Customers should only be able to be in one stage at any given time. One general misconception is that a customer should move from adopting to renewal and then back to adopting post renewal. \n\n2.  Determine the criteria for a customer to move from one stage to another\n\n3.  Map customers to the appropriate stages\n\n  * It is expected not to have an even distribution across stages. Most customers will fall into an \u201cadopting\u201d stage and will stay in that stage the longest.","outcome":"Optimize Customer Journey","stream":"Identify and Manage Lifecycle Activities"},{"id":"WF-157","name":"\u201cWill Churn\u201d Automation","maturity":"Walk","components":["Customer Stages","Rules Engine","CTAs","Playbooks"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Fire a CTA with the playbook to debook a customer when their Stage is manually changed to Will Churn in Gainsight.","discoveryQuestions":"What is your churn process?","workflowUserStories":"* As a CSM, I want to automate the process to debook an at risk customer to better support retention initiatives and immediately improve the customer experience.","gettingStartedGuide":"1. Create a rule: Create a new rule in Gainsight's Rules Engine that triggers when a customer's stage is changed to Will Churn. This rule should include the customer and stage fields as the trigger criteria.\n2. Add a playbook action: Add a playbook action to the rule that will fire when the trigger criteria are met. The playbook action should include the debooking CTA action, which will remove any future CTAs associated with the customer.\n3. Test the rule: Test the rule to ensure that it is working correctly by manually changing a customer's stage to Will Churn and confirming that the debooking CTA is fired.\n4. Launch the rule: Once you have confirmed that the rule is working correctly, launch it to start automatically firing the debooking CTA when a customer's stage is changed to Will Churn.","outcome":"Optimize Customer Journey","stream":"Identify and Manage Lifecycle Activities"},{"id":"WF-158","name":"Post-Offboarding Survey","maturity":"Run","components":["Customer Stages","Journey Orchestrator","Surveys","CTAs","Playbooks"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Automatically survey customers via email after all close-out activities are completed to better understand why they churned.","discoveryQuestions":"* Do you have a strong understanding of why customers churn?\n* How do you use churn data to improve customer experience for active customers and drive internal processes to prevent future churn","workflowUserStories":"* As a CSM, I want to automatically survey customers via email after all close-out activities are completed to better understand why they churned.","gettingStartedGuide":"* Refer to \u201cPost-Churn Feedback Survey\u201d Solution in Sightline Vault for downloadable assets\n* Use a Survey to kick off the Churn Feedback workflow, asking your customers main reasons for churn, highest churn influencers, and additional comments & recommendations\n* Journey Orchestrator emails the survey to customers when customer is moved to stage \u201cWill Churn\u201d and triggers a CTA for the CSM when there is no response","outcome":"Optimize Customer Journey,Increase Lifecycle Automation","stream":"Post Churn Analysis and Insights"},{"id":"WF-159","name":"Lifecycle Compliance Visibility","maturity":"Walk","components":["Data Designer","Reports"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Provide managers with a quick view of out-of-compliance lifecycle activities.","discoveryQuestions":"1. What are the key stages of the customer journey that are most important to your business? How do you define these stages?\n2. What are the goals and objectives for each stage of the customer journey? How do you measure success at each stage?\n3. What are the key touchpoints and interactions that a customer has with your business at each stage of the journey? How do you ensure a consistent and positive customer experience across all touchpoints?\n4. What are the pain points or challenges that customers may experience at each stage of the journey? How do you address these challenges and improve the customer experience?\n5. How do you onboard new customers and ensure they are successful with your product or service? What resources or support do you provide to help customers achieve their goals?","workflowUserStories":"* As a CSM, I want to be able to quickly identify which customers are not meeting their expected cadence of touchpoints and activities so I can focus my attention on the accounts that are at risk and work to minimize any further impact on the consistency of the customer's experience.\n* As a CS leader, I want visibility into which accounts in my team's portfolio are falling out of timeline/touchpoint compliance so that I can more effectively drive attention and focus to these accounts during 1:1 conversations with my team, ultimately minimizing the impact to the customer's experience and mitigating any further risk.","gettingStartedGuide":"* Define the stages of the customer journey: Identify the different touchpoints and interactions that a customer has with your business, from the first point of contact to ongoing engagement and loyalty. This may involve researching and mapping out the customer journey from the customer's perspective.\n1. Define the goals and objectives for each stage: Define what you want the customer to achieve or experience at each stage of their journey, and how you will measure success. This may involve identifying key performance indicators (KPIs) such as conversion rates, customer satisfaction scores, and retention rates.\n2. Develop a strategy for each stage: Define the tactics and activities that will help you achieve the goals and objectives for each stage. This may involve creating a plan for lead generation and acquisition, onboarding and activation, engagement and retention, and advocacy and loyalty.\n3. Leverage Timeline, CTAs, Success Plans and Milestones to ensure that customer journey is being followed. Build out reporting to show customers out of compliance","outcome":"Optimize Customer Journey","stream":"Identify and Manage Lifecycle Activities"},{"id":"WF-160","name":"Conduct EBRs on the Right Cadence","maturity":"Crawl","components":["Timeline","CTAs","Email Assist"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Ensure EBRs happen according to their segment-defined cadence and include the right participants by logging the meetings in Timeline, and firing a CTA when an EBR is over due or sponsors are consistently not present.","discoveryQuestions":"What is your cadence for EBRs?\nIs cadence determined by customer segment?\nWhere/how are these tracked to ensure compliance?","workflowUserStories":"* As a CSM, I want tools to create consistent EBRs across my book of business.  The tools should include guidance for EBR preparation, templates for the EBR presentation, as well as automated reminders for when steps in the EBRs creation and delivery are due.\n* As a CS leader, I want to have visibility into the frequency of EBR delivery, customer KPIs such as the health score of the customer at the time of the EBR, and other measures to gauge the effectiveness of my team.","gettingStartedGuide":"ROI Success Plans to Drive EBR Creation\n\n \u2022 CTA & Playbook to alert CSM of upcoming EBR to be scheduled\n\n \u2022 ROI Success Plans to be deployed to track ongoing objectives & activities performed toward the objectives\n\n \u2022 EBRs to be centered around progress on each Objective, highlighting wins, identifying areas lacking in progress, and identifying risks\n\nUtilize Success Snapshots\n\n \u2022 Use Success Sanpshots to scale EBR creation\n\n \u2022 Send via Journey Orchestrator for low-touch segment\n\nPre-EBR\n\n \u2022 Collect customer data via Survey prior to EBR and help identify goals, progress, and overall sentiment\n\n \u2022 Pre-EBR call with Champion  \u2022 Playbook Task to review EBR content for validation/alignment\n\nPost EBR Info Gathering\n\n \u2022 Confirm during EBR the value delivered and track via Timeline while identifying new Objectives, Goals, Success Metrics\n\n \u2022 Return to ROI Success Plan and update new customer objectives\n\n \u2022 Update any \"To do\" CTA risks with correct level or urgency and apply the correct Playbook\n\n \u2022 Share updated Success Plan with customer for approval\n\nHealth Score Measure for Engagement\n\n* EBR Cadence as it is recorded in Timeline can be evaluated for consistency across the organization.\n* A health measure can surface customer trends toward a lack of engagement.\n* The health measure can be used to identify risk related to a customer\u2019s engagement.","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-161","name":"Hold EBRs on the Right Cadence with the Right People","maturity":"Walk","components":["Timeline","CTAs","Email Assist"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Ensure EBRs happen on the right cadence with the right stakeholders by logging them in Timeline, and tracking compliance via Scorecard.","discoveryQuestions":"* How is your team ensuring EBR\u2019s are being held with your customers?\n* What steps are you taking to help CSM\u2019s set up their EBR\u2019s?\n* How do you review notes from EBR\u2019s that were conducted in the past?\n* What is the manual effort needed from your CSM\u2019s to set up an EBR?\n* How are you making sure the right people from your customers are joining the EBR?","workflowUserStories":"* As a CSM, I want to make sure that I establish an agreed upon cadence for a business review with my customer that includes the decision makers.\n* As a CS leader, I want to make sure that my csms are conducting business reviews at the right cadence and with the right people.","gettingStartedGuide":"* Determine EBR frequency with your customer\n  * < = 1:10 we recommend quarterly EBRs\n  * 1:20 to 1:30 we recommend yearly EBRs\n  * 1:40 to 1:50 we recommend once in 18 months\n  * >= 1:50 we recommend Digital EBRs\n\n\n\n* Contact Management\n  * Define Personas to track, and update Contact Record with Custom Field.\n  * Define & name standardized personas with pick list on the Contact Record.\n\n\n\n* Create EBR Specific CTA in while utilizing Email Assist\n  * Have CTA\u2019s automatically be created either if an EBR has not been completed after 30 days have past from the defined cadence or based on how frequently an EBR should be conducted with the customer.\n  * Assign a Playbook with designated tasks to be completed for the EBR, such as emailing key participants to request an EBR, prep and notes that must be completed prior to holding the EBR, management/stakeholder alignment notifications, and follow up communication. \n  * Use Designated task for requesting the EBR along with Email Assist to streamline the outbound communication and keep it easily tracked within the CTA. A template within Email Assist focusing on the EBR request should already be created/assigned prior to the CSM sending out the email. Recipients of the email should be key persona\u2019s/contacts as tracked above, with strong focus on \n\n\n\n* Timeline Update\n  * Log Meeting Activity with internal and external participants identified, notes, sentiment, and date EBR was held\n  * Utilize Templates to make sure there is consistency in data collected from the EBR\n  * Create Tasks based on Take aways and follow ups that will need to be completed\n  * Attach copy of slide deck to timeline entry \n\n\n\n* Manage Scorecard\n  * Create Scorecard that tracks engagement with key persona\u2019s and/or that the EBR cadence is in compliance\n  * Use Timeline Entries to automatically update the Scorecard, removing manual interactions from end users\n  * Automatically update the scorecard if an EBR has not been completed in defined cadence period to help bring attention to determining next steps to get back on track","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-162","name":"Simplify EBR Prep with Success Snapshots","maturity":"Walk","components":["Success Snapshots"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"High","description":"Define a templatized deck that can be exported from Gainsight with key metrics and details already populated.","discoveryQuestions":"* How many EBRs do your CSMs have a quarter?\n* How long does it take CSMs to prepare for EBRs?\n* What is the process for creating an EBR deck at your organization?","workflowUserStories":"* As a CSM, I want to be able to quickly prepare for an upcoming EBR by exporting an up today Success Snapshot of each of my customers.","gettingStartedGuide":"* Create a standard EBR Deck tailored to your organization\n* Download Success Snapshots from C360 with data from Gainsight\n* Adjust content as needed for your customer","outcome":"Optimize Customer Journey,Increase Customer Facing Teams Impact","stream":"Standardize Best Practices"},{"id":"WF-163","name":"Automated Business Review Email","maturity":"Run","components":["Journey Orchestrator","Reports"],"valueDrivers":["Adoption","Scale"],"setupEffort":"","enablementEffort":"","description":"Automatically send \"low touch\" customers a periodic email digest embedded with usage statistics, support history, and relevant links.","discoveryQuestions":"","workflowUserStories":"* As a CSM managing multiple accounts, I'd want accurate reporting on revenue and retention as well as the customer journey to date 6 months in advance so we can start planning towards continued retention and get ahead of any possible risks and in return, reduce possible churn.","gettingStartedGuide":"","outcome":"Optimize Customer Journey,Increase Lifecycle Automation","stream":"Personalize Digital Experiences"},{"id":"WF-164","name":"Pre-EBR Survey","maturity":"Walk","components":["Surveys","Journey Orchestrator","Email Assist","CTAs","Playbooks"],"valueDrivers":["Adoption","Scale"],"setupEffort":"High","enablementEffort":"High","description":"Survey customers before their Business Review to ensure their most pressing topics and priorities are discussed as part of their EBR.","discoveryQuestions":"* How often are CSMs surprised with topics brought up during the business review from the customer?","workflowUserStories":"* As a CSM, I want to ensure we are covering the most relevant topics for the customer during our EBR.","gettingStartedGuide":"1. Determine survey need by segment.\n2. Create a survey template in Gainsight via a CTA playbook that asks customers about their priorities and goals for the upcoming year, as well as any specific topics they would like to cover during their EBR.\n3. Use the CTA to send the survey via Email Assist to customers a few weeks before their EBR. Make sure to include a clear deadline for completing the survey.\n4. Set up a process for reviewing the survey responses and incorporating them into the EBR agenda. For example, you could create a report that shows the most common topics and priorities mentioned in the survey, and use this information to structure the EBR agenda.\n5. Share the survey results with the customer ahead of the EBR to ensure that they are aware of the topics and priorities that will be discussed during the meeting.\n6. Use the survey results to guide the EBR discussion and ensure that the customer\u2019s most pressing topics and priorities are addressed.","outcome":"Optimize Customer Journey,Increase Lifecycle Automation","stream":"Collect + Confirm Goals"},{"id":"WF-165","name":"Post-EBR Survey","maturity":"Run","components":["Surveys","Journey Orchestrator","Email Assist","CTAs","Playbooks"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Survey customers after each EBR to confirm and track the perceived value of the activity and to ensure all important topics were discussed.","discoveryQuestions":"* How consistent is your team in the delivery of EBRs?\n* Have you added any automation to support the scheduling and lead up to your CSMs\u2019 EBRs?\n* What does your current follow-up post-EBR look like?","workflowUserStories":"* As a CSM, I need to understand and track customer sentiment related to the EBR process.","gettingStartedGuide":"1. Build out your Post-EBR sentiment survey\n  1. Scale of 1-10 question:  Quality of the EBR content & discussion\n  2. Content coverage Yes/No question   ie. Do you feel your EBR covered the topics you wanted to have addressed? \n    1. If no, what else would you like to have discussed during the EBR?\n  3. Scale of 1-10 question: Customer Sentiment with your product & services\n    1. What feedback would you like us to be aware of at this time?\n  4. If you had to renew tomorrow, would you renew?\n2. Create an Email Template with Post-EBR language and the Survey Link\n  1. Post EBR Language: Thank you for joining us for an Executive Business Review of the relationship between (Company Name) and (Your Company Name). We want to make sure that we understand and are meeting your needs. Will you take 5 minutes to answer a few questions honestly with your feedback?\n  2. Survey Question 1\n3. Create an EBR Playbook with Post-EBR Survey email assist or a Post-EBR Journey Orchestrator Campaign (bring in people who attended an EBR timeline event in the last 24 hours or rule trigger by the closing of an EBR CTA)","outcome":"Optimize Customer Journey,Increase Lifecycle Automation","stream":"Track Goals and Communicate Value"},{"id":"WF-166","name":"Conduct Exec Engagement on the Right Cadence","maturity":"Crawl","components":["Timeline","CTAs","Email Assist"],"valueDrivers":["Adoption","Expansion"],"setupEffort":"Low","enablementEffort":"Medium","description":"Ensure Exec Engagement happens according to segment-defined cadence by logging the meetings in Timeline, and firing a CTA when Exec Engagement is over due.","discoveryQuestions":"What is your cadence for Exec Enagagement with customers?\nIs cadence determined by customer segment?\nWhere/how are these tracked to ensure compliance?","workflowUserStories":"* As a CSM I want to make sure I am meeting with my customer on a regular cadence and be able to track those engagements.\n* As a CS leader, I want to be able to track the engagements my team is having to make sure we are meeting with our customers on a regular cadence when needed.","gettingStartedGuide":"Contact Management\n \u2022 Define Personas to track, and update Contact Record with Custom Field\n \u2022 Define & name standardized personas with picklist on the Contact Record\n \u2022 Define cadence frequency for each persona\n \u2022 Assign internal leaders to match personas for \"Buddy System\"\nTimeline Update\n \u2022 Log Call Activity with Custom Persona and sentiment fields\n \u2022 Checkbox fields for all Personas\n \u2022 Picklist field for Sentiment\n \u2022 Picklist field for Sentiment Trend\nCTA w/Playbook including Email Assist\n \u2022 \"Ghost\" email template for internal peer/buddy to send to unengaged customer exec requesting call\n \u2022 Customize email templates to cover all possible scenarios","outcome":"Optimize Customer Journey,Increase Expansion Velocity","stream":"Standardize Best Practices"},{"id":"WF-167","name":"Standardize the Stakeholder Change Process","maturity":"Walk","components":["CTAs","Playbooks","Email Assist"],"valueDrivers":["Adoption","Scale","Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Create a standardized process for customer Executive Stakeholder changes.","discoveryQuestions":"1. Who is your buyer\u2014the individual who was ultimately responsible for purchasing your product or service? \n2. Who are the executive stakeholders involved in championing the purchase and supporting your product\u2019s use?\n3. What does each persona need to know about the value your platform has delivered? Create a checklist for each persona\u2019s need to know information. ","workflowUserStories":"* As a CSM, I want to have surefire guidelines on how to best mitigate any risks associated with stakeholder turnover and identify my new stakeholder(s) at my customer.\n* As a CS leader, I want to have confidence that my team is following best practices should a customer's stakeholder change. Additionally, I will want reporting on when and how well this process is being followed.","gettingStartedGuide":"1.   Identify your stakeholders and key contacts.\n\n2.  Create a checklist of \u201cneed-to-know\u201d info for each key persona. This information should be included in the \u201cIntro\u201d deck with the new stakeholder. \n\n3.  Create a CTA \u201cplaybook\u201d for each persona that includes:\n\n* A \u201cwelcome email\u201d template to send a ghost peer-to-peer networking email (example: CEO to CEO)\n* An outreach to their Exec Assistant to obtain address information for where to send a \u201cWelcome to the \u201cyour company name\u201d family\u201d gift. \n* A request for a meeting to align on their goals & give an overview of partnership to date.\n\n4.  Create a Stakeholder Alignment deck to be used to give an overview of the partnership to date, and align on the new stakeholder\u2019s key goals.","outcome":"Optimize Customer Journey,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Standardize Best Practices"},{"id":"WF-168","name":"Conduct CSM Meetings on the Right Cadence","maturity":"Crawl","components":["Timeline","CTAs","Email Assist"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Ensure CSM Meetings happen according to segment-defined cadence by logging the meetings in Timeline, and firing a CTA when CSM meetings are over due.","discoveryQuestions":"What is your cadence for regular CSM touchpoints with customers?\nIs cadence determined by customer segment?\nWhere/how are these tracked to ensure compliance?\nWhat are the key customer personas that you aim to drive and ensure regular engagement with? ","workflowUserStories":"* As a CSM, I want Gainsight to notify me in the event I am out of compliance with my regularly scheduled/cadenced customer engagements, so that I can quickly engage and minimize potential sentiment risk.\n* As a CS leader, I want to know that my CSMs are engaging with customers in accordance with our CS strategy, so that I can ensure our customers are recieving the level of care and service they are purchasing.","gettingStartedGuide":"Contact Management\n \u2022 Define Personas to track, and update Contact Record with Custom Field\n \u2022 Define & name standardized personas with picklist on the Contact Record\n \u2022 Define cadence frequency for CSM touchpoints\nTimeline Update\n \u2022 Log Call Activity with Custom Persona and sentiment fields\n \u2022 Checkbox fields for all Personas\n \u2022 Picklist field for Sentiment\n \u2022 Picklist field for Sentiment Trend\n","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-169","name":"Scale Best Practice Guidance with Webinars & Office Hours","maturity":"Walk","components":["Milestones","Rules Engine"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Share strategic guidance with customers without an assigned CSM by holding focused Office Hours sessions and best practice webinars.","discoveryQuestions":"* What are some high-value features in your product that are also challenging for customers to set up and use without guidance? \n* What topics are your pooled CSMs commonly addressing with the customers in their segment that would be helpful to address at scale? \n* How much time do your pooled CSMs spend per week/month answering questions or helping customers through these topics? \n* What stage in the journey would customers find these topics most helpful? ","workflowUserStories":"* As a CSM, especially if I am a program manager over a pooled CSM customer segment, I need a way to address important, high-value, complex, or common questions for customers at scale.  This workflow allows me and my team to spend less time overall meeting the needs of our customers, while also delivering a sense of community and positive experiences.\n* As a CS Leader, I need to ensure that our customers are taken care of even when they do not have an assigned CSM. I have to be wise with resources, and use this as a key part in our DCS (Digital Customer Success) model.","gettingStartedGuide":"* List and prioritize the webinar topics that would be most helpful to the customers in the pooled CS segment\n* Select the dates for upcoming webinars and office hours\n* Draft email templates that copy to invite key customer stakeholders to the next upcoming webinar and office hours session\n* Create a Journey Orchestrator program that delivers email invitations to register and attend the webinar\n* If you use Digital Hub, consider other ways to announce the webinar using digital hub\n* If you use Gainsight PX, consider using an engagement to announce the webinar to key customer contacts","outcome":"Optimize Customer Journey,Increase Lifecycle Automation","stream":"Increase User Engagement"},{"id":"WF-170","name":"Standardize Team-to-Team Handoffs","maturity":"Walk","components":["Timeline","CTAs","Playbooks"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Streamline and standardize the process of handing off customers between internal teams, such as Onboarding to Training, using CTAs and playbooks to ensure seamless transitions and maintain customer satisfaction.","discoveryQuestions":"* How do you currently manage handoffs between different internal teams?\n* Are there any pain points or challenges in your current team-to-team handoff process that you\u2019d like to address?\n* What are the key handoff points between different departments in your organization?","workflowUserStories":"* As a CSM, I want to streamline and standardize the process of handing off customers between internal teams, such as Onboarding to Training, by using CTAs and playbooks to ensure seamless transitions and maintain customer satisfaction.","gettingStartedGuide":"* Identify the key handoff points between different internal teams\n* Create CTAs and playbooks to guide each team through the handoff process\n* Train team members on using the CTAs and playbooks for efficient handoffs","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-171","name":"Standardize the CSM Reassignment Process","maturity":"Walk","components":["CTAs","Playbooks","Email Assist"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Trigger a CTA to fire when the customer's CSM changes to guide the new CSM through defined steps to take over the account.","discoveryQuestions":"* Do you have a current account transition workflow in place today?\n* How do you ensure your customers information is shared and no knowledge is lost when a new CSM/Account Rep is taking over?\n* Do you have consistency of what account information is shared?","workflowUserStories":"* As a CSM who is handing over the account, I want to be reminded on what steps my organization wants me to take to transition the account successfully to my peer.\n* As a CSM who is receiving a new account from a fellow CSM, I want to make sure all the key account information is in the right place and the handover meeting is being scheduled in my calendar.","gettingStartedGuide":"* Create a CTA with a playbook of steps that need to be taken for the current CSM and new CSM\n* Included in that playbook: Account transition notes can either be created in Activity Timeline by following a pre-defined template and tagging relevant users OR Surveys can also be leveraged to ensure all non-Gainsight users can fill in the required transition information. Success Plans can be templatized/customized to ensure consistency across the teams. ","outcome":"Optimize Customer Journey,Increase Customer Facing Teams Impact","stream":"Standardize Best Practices"},{"id":"WF-172","name":"Standardize the Post-Sales Customer Handoff","maturity":"Walk","components":["Timeline","CTAs","Playbooks"],"valueDrivers":["Adoption","Scale","Expansion"],"setupEffort":"Low","enablementEffort":"Low","description":"Use Timeline templates to streamline the handoff of Sales-cycle knowledge around launch expectations, strategic goals, and key stakeholders.","discoveryQuestions":"* What is your current post-sales handoff process?\n* Which teams are involved in the post-sales handoff process? Which of those teams have GS licenses? \n* Are your teams currently using Timeline?","workflowUserStories":"* As a CSM , I want to ensure my customer's experience is efficient, seamless, and optimal","gettingStartedGuide":"* Outline what an ideal post-sales handoff should look like\n* Create a Timeline template with clearly defined post-sales handoff expectations for each team\n* Train cross-functional teams on new post-sales handoff process","outcome":"Optimize Customer Journey,Increase Customer Facing Teams Impact,Increase Expansion Velocity","stream":"Standardize Best Practices"},{"id":"WF-173","name":"New Customer Onboarding Survey","maturity":"Walk","components":["Surveys","Journey Orchestrator","Email Assist","CTAs","Playbooks"],"valueDrivers":["Adoption","Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Survey net-new Customers to confirm goals and technical data points not covered during the sales cycle.","discoveryQuestions":"1. How do you capture customer desired outcomes and key technical data points?\n2. What does the Sales \u2192 CS handover process look like and what data is included?\n3. Who has ownership of customer onboarding and are there any existing ent surveys focused around onboarding experience?","workflowUserStories":"* As a CSM, I want to understand new customers' experience during Onboarding to ensure they are maximizing their use of the Product and providing guidance when needed.","gettingStartedGuide":"Design\n\n1. Identify required data points to capture (i.e. goals and technical data points).\n2. Identify recipient persona and who it will be sent from.\n3. Create survey design and e-mail template (including elements of childlike joy).\n4. Confirm which areas of C360 should hold the data (i.e. Attributes).\n5. Create on-boarding Journey Orchestrator program, with associated rules.\n\n\n\nReporting & Insights\n\n1. Decide what CTAs will be created once survey is completed for closing the loop.\n2. Create report to summarise data captured and make available to internal stakeholders.\n3. Include survey completion as key milestone on Customer Journey timeline.\n\n\n\nCustomization Option 1\n\n* Journey Orchestrator can support segmentation of your customers.\n* Send emails based on their level of service (digital led has more self-serve content, high touch is more focused on the process flow and follow ups).\n\n\nCustomization Option 2\n\n* Chain together a welcome email package.\n* Send out future emails based on read/not read, timeline of onboarding, or adoption of the product.","outcome":"Optimize Customer Journey,Improve User Engagement and Experience,Increase Self-Service Engagement","stream":"Collect + Confirm Goals"},{"id":"WF-174","name":"New Customer Welcome Email (Manual)","maturity":"Crawl","components":["CTAs","Email Assist","Playbooks"],"valueDrivers":["Adoption","Adoption","Scale","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Manually welcome net-new customers with a pre-built Email Assist to set onboarding expectations and share resources.","discoveryQuestions":"What is your process to welcome a new customer to the onboarding process?\nHow are new customers informed of onboarding expectations and next steps?\nIs this process defined for internal teams and completed consistently?","workflowUserStories":"* As a CSM, I want welcome a new client and share relevant documentation and videos on How to Get Started\n* As a CS leader, I want new clients to know that I am an additional resource avaiable to help suppor their implementation.","gettingStartedGuide":"Custom fields\n \u2022 \u2018Closed\u2019 or \u2018Start\u2019 date type fields will work best\n \u2022 If account will have a CSM assigned, make sure that occurs before email is sent out\nEmail template\n \u2022 Create email template that is inviting (welcome image or video) but not overcrowded; make sure the important content is easy to see\n \u2022 Make sure reciepient understands the value they will receive (length or training, use cases they'll acomplish, etc)\n \u2022 Ideally, email send should come from a CS leader (Director, VP, CCO) but ensure that the CSM is CC'd as well","outcome":"Optimize Customer Journey,Improve User Engagement and Experience,Increase Lifecycle Automation,Increase Self-Service Engagement","stream":"Personalize Digital Experiences"},{"id":"WF-175","name":"New Customer Welcome Email (Automated)","maturity":"Walk","components":["Journey Orchestrator"],"valueDrivers":["Adoption","Adoption","Scale","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Welcome all (or a subset of) new customers with an automated email to set onboarding expectations and share resources.","discoveryQuestions":"* Do you have the data you need to trigger this automatically (it is in Gainsight and it is reliable/accurate) \n* Do you have a process upstream from this in sales to identify who the right contact is to send this email to? ","workflowUserStories":"* As a CSM, I want welcome a new client and share relevant documentation and videos on How to Get Started\n* As a CS leader, I want new clients to know that I am an additional resource avaiable to help suppor their implementation.","gettingStartedGuide":"* Define Customer Segmentation approach: will this be an automated email for all customer segments or will some customers not get this automation\n* Define target audience: is there a certain persona or role that should get this email and who is responsible for filling that info out upstream (sales, implementation leadership, the customer etc.) \n* Determine what data is needed to automatically trigger this email: Do you need to bring in customer stage or date from your CRM that needs to trigger this email? If a manual field needs to be populated to trigger this, define who is responsible for this step. \n* Who should the email come from? Ideally someone the receiver knows and ideally from a person \n* If there is a response to the email define who it should be routed to: if you have a pooled model ensure this get routed to the appropriate pool \n* Write content of the email and personalize using tokens in Gainsight: set expectations on what to expect next in the onboarding process, include how to reach out to support, identify training materials, any due dates and links out your community to encourage them to sign up, define escalation paths \n* Define what path you will take if the customer does not open the email or engage with the resources: Should this effect their health score, should you wait and send a reminder, if that does not work when do you need to engage a person to reach out? ","outcome":"Optimize Customer Journey,Improve User Engagement and Experience,Increase Lifecycle Automation,Increase Self-Service Engagement","stream":"Personalize Digital Experiences"},{"id":"WF-178","name":"Closed-Loop Survey Response (Non GS Surveys)","maturity":"Crawl","components":["Rules Engine","CTAs","Playbooks","Connectors"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Use NPS survey results recieved through other services to identify risks/opportunities with (semi)automated follow ups based on response.","discoveryQuestions":"* Is your team currently responsible for reaching out to NPS responders for more information?\n  * If so, are they reaching out to customers with all response types or just detractors? \n* Is there an existing prescribed process for closing the loop with detractors - or is based on the situation?\n* Is there an existing prescribed process for closing the loop with promoters - or is based on the situation?\n* Are teams outside of Customer Success aware of NPS? Are they typically interested in feedback relating to their function? Are they typically open to feedback and willing to collaborate to address any concerns or opportunities? ","workflowUserStories":"* As a CSM, I want to be able to track NPS results to better track risks and opportunities based on customer response.","gettingStartedGuide":"* Automate Customer Reach-Out for NPS survey results captured outside of Gainsight:\n    * Bring survey data into C360 pages so that results can easily be found within Gainsight. Data can also be displayed in dashboards for high level visibility into overall results and trends\n    * Create Playbooks for each response type - each should have a prescriptive outline of action items for the CSM reaching out\n      * Detractor playbook\n      * Neutral response playbook\n      * Promoter playbook\n    * Create a rule to kick-off CTAs to CSM with the appropriate playbook corresponding to the response type\n* Additional Considerations: \n  * Ensure playbooks include direction on where to best include additional customer feedback\n  * Ensure playbooks include direction on how to best close the loop on final feedback based on topics discussed. Examples:\n    * A call with Product Managers for a product feedback discussion\n    * Opportunities to celebrate advocates and ask them to share their feedback or leave a review","outcome":"Increase Advocacy / Advocates","stream":"Gather and Manage Customer Feedback"},{"id":"WF-182","name":"Survey Response Newsletter","maturity":"Run","components":["Journey Orchestrator"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Individual response follow-ups aren't always scalable; send periodic emails to share how recent feedback has influenced strategy.","discoveryQuestions":"","workflowUserStories":"* As a CSM, I want to send periodic emails to share how recent feedback has influenced strategy via a Survey Response Newsletter.","gettingStartedGuide":"","outcome":"Increase Advocacy / Advocates,Increase Lifecycle Automation","stream":"Gather and Manage Customer Feedback"},{"id":"WF-185","name":"Display Survey Results from Other Systems in Gainsight","maturity":"Crawl","components":["Reports","C360","Connectors"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Import survey data into the Gainsight, or reference survey data stored in Salesforce, to display results of 3rd party surveys in Gainsight.","discoveryQuestions":"\n\n* Do you conduct an NPS survey?\n* What tool do you use for NPS?","workflowUserStories":"* As a CSM , If my org is using other survey platforms , i can import this to Gainsight and view same at a combined place with Gainsight survey responses\n* As a CS leader, i can see an aggregated report of all the survey responses .","gettingStartedGuide":"\n\n* Find out where the NPS data is stored.\n* Determine method to add data to Gainsight (CSV load to survey action, integration with SurveyMonkey, load from SF etc.)? \n* Build an NPS Dashboard, pull into C360 (see examples in Sightline Vault) to display the data. ","outcome":"Improve User Engagement and Experience","stream":"Centralize Customer Data"},{"id":"WF-186","name":"Reflect Customer Sentiment in the Health Score","maturity":"Walk","components":["Rules Engine","Scorecard"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Medium","description":"Expand your Experience score to incorporate all inputs of customer sentiment by creating a measure for each sentiment type.","discoveryQuestions":"* Determine the customers preference in ease with option 2 or with detail in Option 1.\n* Encourage customer to set a reasonable cadence based on CSM segment and High/Low/Pooled touch","workflowUserStories":"* As a CSM, I want to be able to reflect customer sentiment in the health score.\n* As a CS leader, I want to be able to see customer sentiment to understand trends and overall customer satisfaction.","gettingStartedGuide":"* Create Sentiment Scorecard measure\n\nOption 1\n\n* Set a requirement to have CSMs manually update the sentiment via the Scorecard at a regular cadence or in the event of a sentiment change they uncover.\n\nOption 2\n\n* Add Sentiment Input field to Timeline Activities as a required field (could be included in all meetings/calls or could be it\u2019s own dedicated Activity type with this field depending on preference)\n* Possibility: Create Sentiment Reason custom field with common reasons as a picklist\n* Create Rule to push the update (R/Y/G) to the Sentiment Scorecard Measure","outcome":"Improve User Engagement and Experience","stream":"Gather and Manage Customer Feedback"},{"id":"WF-187","name":"Systematically Analyze Sentiment","maturity":"Walk","components":["CX Center","Dashboards","C360"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Analyze customer sentiment data across your base of business (BoB) by attributes such as Persona or Segment to identify trends and insights that can inform strategies for improving user engagement and experience.","discoveryQuestions":"* How is your organization currently analyzing customer sentiment data, if at all?\n* Which customer attributes (e.g., Persona, Segment) are most relevant for understanding sentiment trends in your business?\n* What are the main objectives or pain points you hope to address by analyzing customer sentiment?","workflowUserStories":"* As a CSM, I want to be able to analyze survey reponses by role and segment, which will help tailor future messaging and handling of accounts based off of this information\n* As a CS leader, I need to see further details pertaining to survey responses from participants, such as segment and persona.  This will give a holistic view of trends and themes that may arise around personas and segments.","gettingStartedGuide":"* Set up CX Center Dashboards and C360 to capture and analyze sentiment data\n* Define relevant attributes (e.g., Persona or Segment) for slicing and analyzing sentiment data\n* Regularly review and update sentiment analysis insights to inform ongoing strategies and initiatives","outcome":"Improve User Engagement and Experience","stream":"Capture insights to inform product developement"},{"id":"WF-188","name":"Display External Survey Data as Gainsight Survey Data","maturity":"Run","components":["Surveys","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Utilize Gainsight\u2019s objects associated with survey questions and answers to help create easily consumable information that can be shared cross functionality internally or externally (support, product, sales and executive leadership) ","discoveryQuestions":"Where is the companies biggest blindspot when it comes to capturing client feedback?","workflowUserStories":"* As a CSM, I need to see survey data within Gainsight and shared cross functionality internally or externally (support, product, sales and executive leadership).","gettingStartedGuide":"The Discovery question will help establish the \u201cgetting started Guide\u201d. Once the CSM understands the outcome or problem statement, then we can take the necessary steps to align on the following\nStep 1:  Cross functionally who needs visibility into this information, and where do they work? \nStep 2: Schedule larger conversation to understands all POV on the process and data points to drive the new workflow \nStep 3: Review current state of survey design and workflows - make updates based on changes needed\nStep 4: Review where data is stored on how to quickly access this information to quickly share \nStep 5: UAT the process ","outcome":"Improve User Engagement and Experience","stream":"Centralize Customer Data"},{"id":"WF-189","name":"Publish Survey Results Internally","maturity":"Run","components":["Sally Slackbot","Journey Orchestrator"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Make sure survey results are seen across your organization sharing new responses through external channels, like Slack or email.","discoveryQuestions":"* Which Surveys are currently in place? \n* Is there any other point in the customer journey where it would be beneficial collecting their sentiment or feedback?\n* How do you gather product feedback to improve your service / solution?\n* By which channels are surveys sent out?\n* On which channels are the responses collected and published?\n* Which impact does the survey has on other CS workflows? Which actions flow from those responses?","workflowUserStories":"* As a CSM, I want to make sure survey results are seen across the organization sharing new responses through external channels, like Slack or email.\n* As a CS leader, I want the ability to see survey results through external channels, like Slack or email.","gettingStartedGuide":"1. Understand which surveys are setup and if there\u2019s the need to establish new ones in other part of the customer journey.\n2. Know where the surveys results are published currently - who has access to that and what actions/triggers are set up.","outcome":"Improve User Engagement and Experience,Increase Customer Facing Teams Impact","stream":"Gather and Manage Customer Feedback"},{"id":"WF-190","name":"Systematically Analyze Product Feedback","maturity":"Run","components":["CX Center","Dashboards","C360"],"valueDrivers":["Adoption","Adoption"],"setupEffort":"High","enablementEffort":"Medium","description":"Slice and analyze product feedback across your Book of Business by attributes like Industry or Geo to understand broader trends in product sentiment.","discoveryQuestions":"* How do you collect feedback from your customers? In-App? Via a Community space? Via Email? In Customer Meetings?\n* Which questions do you use? Can you make it easier for your customers to give you feedback on your product and functionalities?\n* Who are you surveying?\n* Who does analyse the feedback received?\n* How do you incorporate and prioritise your product requests?\n* Who can see the product requests added to the roadmap?","workflowUserStories":"* As a CSM,  I want to systematically analyze aggregated product feedback within my Book of Business to improve user engagement and sentiment.","gettingStartedGuide":"1. Analyze the channels where you collect customer sentiment on your product. \n2. Identify the best contact that should give you the feedback, and when. \n3. Explore options for different teams to add product feedback coming from customers during their engagements.","outcome":"Improve User Engagement and Experience,Improve User Engagement and Experience","stream":"Capture insights to inform product developement"},{"id":"WF-191","name":"Surface Trends in External Sources of Feedback","maturity":"Run","components":["Sightline Vault","CX Center","Dashboards"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Operationalize public sentiment sources like product reviews and community post submissions.","discoveryQuestions":"What are you currently doing to capture public sentiment today? \nHow are you passing on the feedback of customer sentiment to your teams? \nWhich teams are involved capturing public sentiment? \n","workflowUserStories":"* As a CSM, I want to be able to surface trends in external sources of feedback and operationalize public sentiment sources like product reviews and community post submissions.","gettingStartedGuide":"1. Understand which sources are currently being used to capture customer sentiment\n2. If these sources are being managed by someone - understand which team manages this sources and how customer comments are being responded too and how customer feedback is being passed onto relevant teams \n3. Design a repeatable workflow that covers the following areas: Sources to capture public sentiment, how to reply to public sentiment, how to feedback sentiment to the right business areas + company as a whole. \n4. Visualise customer public sentiment in the c360 ","outcome":"Improve User Engagement and Experience","stream":"Capture insights to inform product developement"},{"id":"WF-192","name":"Conduct Proactive Interviews to Define your CS Roadmap","maturity":"Crawl","components":["Timeline"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Hold strategic customer interviews to better understand the perceived value of your CS model, and to help direct your future CS roadmap.","discoveryQuestions":"* What questions are your CSMs currently asking your customers about how your CS model is working for them?\n* Where is that information currently being captured?\n* How is that information being shared cross-functionally for collaborative action?","workflowUserStories":"* As a CSM, I want to lead the customer to greater success, by helping them shape the strategy of their CS org. So instead of leave them figure out the future of their org alone, I will help them create a CS road map that includes future use cases, features, and configurations in Gainsight that will support a meaningful and relevant CS strategy.","gettingStartedGuide":"* Design a set of questions that your CSMs will ask, to ensure a consistent experience for the customer, and to ensure consistent data input that can be used for benchmarking across your entire customer base.\n* Incorporate those questions into a CTA Playbook that will guide your CSMs to conduct customer interviews.\n* Train your CSMs to use the new CTA and associated Playbook to create a Timeline entry for each interview.\n* Consider sending questions to key customer stakeholders via a survey from Gainsight. After drafting your questions, collaborate with your Gainsight Admin to set up and send the survey out. ","outcome":"Improve User Engagement and Experience","stream":"Collect + Confirm Goals"},{"id":"WF-193","name":"Understand Your Customers' Business Landscape","maturity":"Crawl","components":["Timeline","CTAs","Playbooks"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Have high-touch CSMs deep dive into the business and revenue model, and unique concerns and priorities, of an account upon new CSM assignment.","discoveryQuestions":"1. What sources of customer/prospect information exists internally for a new CSM to reference? \n2. Is there a Sales\u2192 CSM handoff to go over key account information (if not, consider setting this up as a standard process)?\n3. Are there any key internet databases that your CSM should have access to to conduct customer research? ","workflowUserStories":"* As a CSM, I want guidance on the most efficient way to get up to speed on my new customer's business/revenue model, financial status, competior landscape, etc, so that I know exactly what I should be knowledgable about prior to my first engagement.\n* As a CS leader, I want to standardize the direction I am giving to CSMs who get assigned/inherit new customers, so that they are providing a consisent experience for the customer upon first interaction and demonstrating a high level of knowledge of their customer's unique business landscape.","gettingStartedGuide":"Create a CSM new customer checklist that includes: \n\n1. Internet research - Google the customer, go to their website and read about their business, follow them on LinkedIn (noting details like how many employees they have, if they are a public company (and if so, where their quarterly reports are published). Setup a Google alert to get notified whenever the company is in the news.  Search for podcasts by their leadership. Listen to Gong.io call recordings from their onboarding meetings. \n2. Internal research - Look at the opportunity record in the CRM, or ask the Sales rep that originally sold them questions such as \u201cwhy did they originally buy our solution?\u201d and \u201cwhat are they looking to achieve (their business outcome)?\u201d. Look at the Support tickets to see what their recent issues and questions are. Find out if they have any feature requests that are outstanding. Review the past email correspondence they\u2019ve had with your company and any major milestones \u2014 past contracts, renewals, QBRs, etc.","outcome":"Improve User Engagement and Experience","stream":"Guide Customers Towards Value"},{"id":"WF-194","name":"Customer Advisory Board","maturity":"Walk","components":["Timeline"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Invite a strategic subset of similar customers to a participatory workshop to better understand the CS needs of a specific customer profile.","discoveryQuestions":"* Does you CS and Product team work together and can organize events like this\n* Does the product embrace crowd sourced feedback from customers","workflowUserStories":"* As a CSM, I want to invite a strategic subset of similar customers to participate in a \"Customer Advisory Board\" to better understand the CS needs of a specific customer profile.\n* As a CS leader, I want to see all of the customers who have participated in the Customer Advisory Board and view details about the topics and outcomes discussed.","gettingStartedGuide":"Based on sentiment, NPS, product feature requests submissions","outcome":"Improve User Engagement and Experience,Prioritize R&D Effectively","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-195","name":"Conduct Chairside Interviews","maturity":"Walk","components":["Timeline"],"valueDrivers":["Adoption","Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Understand the ways that individual users operate within your solution(s) by conducting targeted \u201cchairside\u201d discovery sessions.","discoveryQuestions":"* Do you know how your customers utilize your product?\n* do you know the roadblocks the end users of your product face when trying to utilize your product?\n* How much do you know about your product\u2019s end user experience?\n* Are there \u201coutside of the box\u201d use cases your customers have discovered","workflowUserStories":"* As a CSM, I want to be able to understand from the end user perspective how the team utilizes our product so we as a team can help drive better user adoption and deliver the business values they are looking for. From the interview, we can discover any roadblocks the user team may have with the product.\n* As a CS leader, I want to be able to provide support to my team based on user feedback and escalate as needed.","gettingStartedGuide":"* Devise questions that provide insights into how your customers utilize your product\n* word he questions so they provide both positive feedback and constructive criticism of your products capabilities\n* Know your target market and channel the questions towards front line employees (BTL folks)\n* Create a cadence and audience for these questions as situations can change rapidly","outcome":"Improve User Engagement and Experience,Improve User Engagement and Experience","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-196","name":"Product Advisory Board","maturity":"Run","components":["Timeline"],"valueDrivers":["Adoption","Adoption","Scale"],"setupEffort":"High","enablementEffort":"High","description":"Invite a strategic subset of similar customers to a participatory workshop to better understand the product needs of that customer profile.","discoveryQuestions":"* Do you have a way to gather product feedback from customers and collaborate cross-functionally (i.e. productboard, Aha!, etc.)? \n* Are you identifying similar customer groups to be able to create subsets of customers to participate in a workshop to provide feedback?","workflowUserStories":"* As a CSM, I need the track my product usage to submit product requests to my advisory board.","gettingStartedGuide":"* Identify customer profiles or subset of customer groups \n* Send one to many outreach to subset of customers to participate in product advisory board with expectations for meeting. \n* Have somewhere to gather product feedback from workshop groups\n* Send one to many outreach following up with attendees that participated in the workshop and provide visibility into attendee list for CSMs","outcome":"Improve User Engagement and Experience,Improve User Engagement and Experience,Prioritize R&D Effectively","stream":"Capture insights to inform product developement"},{"id":"WF-197","name":"Increase Advocacy and Referencability","maturity":"Crawl","components":["Timeline","CTAs","Dashboards"],"valueDrivers":["Expansion"],"setupEffort":"Low","enablementEffort":"Low","description":"Use Timeline to nominate individuals who would be good advocates, along with the areas where their advocacy might focus.","discoveryQuestions":"* Are your customers looking for others to connect to?\n* How are you tracking advocates/references for your product?\n\n","workflowUserStories":"* As a CSM, I'd want to be able to identify all leads in one section or report to see how I can turn them into potentional opportunities.\n* As a Sales Partner, I'd want to receive the appropropiate lead assignment and see how I can convert to an Opp.","gettingStartedGuide":"* Define what fields you want to be able to track for advocates and make those required field types in Timeline when a CSM adds an advocate\n* Educate team on how to find advocates, reaching out to CSMs to make introductions, etc. Track in comments when an advocate has been used so that you can easily reference that in the future.","outcome":"Increase Growth Through Advocacy","stream":"Identify Potential Advocates"},{"id":"WF-198","name":"Track Advocacy at Individual + Customer Levels","maturity":"Crawl","components":["Custom Fields","Company Object","Person Object"],"valueDrivers":["Expansion"],"setupEffort":"","enablementEffort":"","description":"Companies don't advocate, people do. It\u2019s important to track advocacy potential and activities at both the Company level and Contact level.","discoveryQuestions":"","workflowUserStories":"* As a CSM, I want to track advocacy potential at the company and contact level.","gettingStartedGuide":"","outcome":"Increase Growth Through Advocacy","stream":"Identify Potential Advocates"},{"id":"WF-199","name":"Turn NPS Promoters into Advocates","maturity":"Walk","components":["CTAs","Playbooks"],"valueDrivers":["Expansion","Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Ensure that the closed-loop for promoter NPS responses includes steps to engage the promoter as an advocate.","discoveryQuestions":"* What is your current process for closing the loop for NPS responses?\n* What are you doing with the data?\n* How are CSMs notified of positive NPS scores and other advocacy opportunities?","workflowUserStories":"* As a CSM, I want to be able to easily action off of NPS promoter information in order to take advantage of all expansion opportunities as quickly as possible\n* As a CS leader, I want to enable my team to easily identify and action on expansion opportunities as soon as they occur.","gettingStartedGuide":"* Automated CTA for Promoter Response\n* Automated CTA for Passive Response to convert those into Promoters in the future\n* Create a Playbook for closing the loop: Use email assist and offer the CSM multiple options to garner feedback","outcome":"Increase Growth Through Advocacy,Increase Expansion Velocity","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-201","name":"Survey For and Publish Success Stories","maturity":"Run","components":["Journey Orchestrator","Surveys"],"valueDrivers":["Expansion","Scale","Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Survey willing advocates about their business model, use case, and recognized value; publish responses as single slide success stories.","discoveryQuestions":"* Are you tracking advocates today? If so, how?\n* Do you create case/success stories with your customers?\n* Do you ask NPS promoters to engage in advocacy events?","workflowUserStories":"* As a CSM, I want to survey willing advocates about their business model, use case, and recognized value; and publish responses as single slide success stories.","gettingStartedGuide":"1. Streamline the process of capturing survey responses\n* Categorize the survey responses , once a promoter response is captured define a Playbook with tasks and assign to CSM.\n* Create a Survey to understand the willingness of customer to participate in the advocacy \n\n2. Willingness to participate in advocacy \n\n* Create a program to invite promoters to fill testimonials through Journey orchestrator \n* Create email assist task to invite likely advocates to submit their testimonials using Cockpit\n\n3. Visualize advocacy tracking\n\nCreate Reports to track advocacy to track expansions,advocacy events, surveys and success stories","outcome":"Increase Growth Through Advocacy,Increase Lifecycle Automation,Increase Expansion Velocity","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-202","name":"End-to-End Reference Management for Sales","maturity":"Walk","components":["Rules Engine","CTAs w/ Linked Objects","Data Designer","Milestones"],"valueDrivers":["Expansion","Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Facilitate new business sales while attributing value to the customer advocates sourced by the CS team.","discoveryQuestions":"How do you track if a customer is referenceable today? \nWhat is the biggest issue you currently encounter with current ability to track references?","workflowUserStories":"* As a CSM, I need an easy way to indicate when a customer is reference-able. I also need a report that will show all of my referenceable customers to help me and my Sales counterparts in cross-sell, up-sell, and new business opportunities.\n* As a CS leader, I need an accurate list of current customers who are referenceable. I need a report that I know is current so that I can quickly set up reference interactions without having to ask the entire CS org in fire-drill fashion if/when a reference need arises.","gettingStartedGuide":"Step 1: Review the current or lack of current process \n\nStep 2: Align cross functionality to understand full scope of Advocacy needs \n\nStep 3: Define the starting point on how end users will capture reference-ability\n\n* Will users capture this in the CRM or in Gainsight? \n* If in Gainsight, here are some options for capturing referenceability: \n  * a) Indicate in a Company field directly on the customer360\n  * b) Indicate in a field on Timeline, then use Rules Engine to read the field and auto-populate corresponding fields on the company\n\nStep 4: Simplify requests type.. reduce sales jargon that is none essential to understanding need\n\nStep 5: Clean Contact Hygiene\n\nStep 6: Create reports that display all timeline activities and/or Company records that have the reference-ability fields populated\n\nStep 7: Socialize the reference-ability reports to all CSMs and everyone in the Sales org so that everyone can easily access the reports and identify customers who have agreed to be a reference\n\nStep 8: Include rules of engagement that dictate how often, and the means by which the customer will serve as a reference\n\n","outcome":"Increase Growth Through Advocacy,Increase Expansion Velocity","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-203","name":"Reflect Advocacy and Reference Activity in Scorecard","maturity":"Walk","components":["Rules Engine","Scorecard"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Score customers based on recent Advocacy and Reference activities logged to Timeline.","discoveryQuestions":"* Do you have any customers that are references for your company? If so, how are they identified? \n* If yes to the above, how often are these customers asked to do a reference activity?\n* How/where are reference and advocacy activities tracked?  Who has visibility to this?\n\n","workflowUserStories":"* As a CSM, I can identify where customers are advocates and available to be used across accounts when a reference is requested or a great user story to show the health of my customer.","gettingStartedGuide":"* Create an Advocacy/Reference activity type for Timeline\n* Investigate ways to automate logging reference/advocacy activities to Timeline\n* Create Scorecard measure based on the quantity of completed activities within the desired timeframe (last 6 months for example)\n* Create a hypothesis for what red/yellow/green health looks like for this measure and test","outcome":"Increase Growth Through Advocacy","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-204","name":"Customer to Customer Reference Request Process","maturity":"Run","components":["Rules Engine","CTAs w/ Linked Objects","Data Designer","Milestones"],"valueDrivers":["Expansion","Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Facilitate customer-to-customer reference requests while attributing value to the customer advocates sourced by the CS team.","discoveryQuestions":"* How do you currently track and capture customer advocates today?\n* Do you already have a database of customer advocates?\n* Do you already have a CSQA object/workflow in your GS instance?","workflowUserStories":"* As a CSM, I want to facilitate the process for customer-to-customer reference requests while attributing value to the customer advocates sourced by the CS team.","gettingStartedGuide":"* Create CSQA, triggering automated CTA that assigns CSQA to advocate\u2019s CSM, if any\n* Once interaction happens, document details of interaction and close out successful CSQA\n* If never connected, document details and close out unsuccessful CSQA","outcome":"Increase Growth Through Advocacy,Increase Expansion Velocity","stream":"Drive Advocacy Programs & Activities"},{"id":"WF-205","name":"Track Value/ROI","maturity":"Crawl","components":["Scorecard","Rules Engine","Timeline"],"valueDrivers":["Retention","Retention"],"setupEffort":"Medium","enablementEffort":"High","description":"Calculate a customer ROI score using Verified Outcomes logged to Timeline.","discoveryQuestions":"How do you prove ROI to your customers?\nWhere are value achievements tracked and documented?","workflowUserStories":"* As a CSM, I want to identify which companies have/haven't seen ROI with our product via the scorecard.\n* As a CS leader, I want to see a trend line of ROI over time-based on VO conversations.","gettingStartedGuide":"* Install Sightline Value Asset: Document Verified Outcomes.\n* Create a new automated measure for Verified Outcomes.\n* Add a weight to you measure. You might want to start of with a lower weight on this measure until you start to get some data into the system. \n* Create a rule that sets your measures score based on cadence and if a Verified Outcome was logged to Timeline for that Customer. (For example, this could be once per quarter or once per month)\n* Finally create a report that includes this new measure so you can evaluate, over time, if this measure is working for your team.\n\n\n\n ","outcome":"Improve Health Score Predictiveness,Improve Customer ROI","stream":"Track Goals and Communicate Value"},{"id":"WF-208","name":"Identify Usage Patterns with Monthly Active User Analysis","maturity":"Crawl","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Analyze login data across all customers to establish the threshold for an active license and store the count of Monthly Active Users at the company level, enabling insights into usage patterns and adoption trends.","discoveryQuestions":"* How does your organization currently track user engagement and product adoption?\n* What criteria are important for your organization when defining an active license?\n* How do you anticipate using Monthly Active User data to inform strategies for improving adoption depth and breadth?","workflowUserStories":"* As a CSM, I want to understand what is a \"typical\" monthly usage pattern for my type of accounts and identify the factors that could influence upwards/downward trend.","gettingStartedGuide":"* Set up Adoption Explorer and configure it to track login data for all customers\n* Define the threshold for an active license based on your organization's criteria\n* Create custom fields to store the count of Monthly Active Users at the company level and use Rules Engine to update these fields","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-209","name":"Compare Usage Across Companies by Normalizing Login Data","maturity":"Walk","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Analyze logins across all customers to set the threshold for a user to be Healthy, and store the count of Healthy Active Users on Company.","discoveryQuestions":"1. Are you able to track login data for your product? \n2. Do you have different types of users licences? ","workflowUserStories":"* As a CSM, I want to be able to determine expansion opportunity as well as possible churn risk by referencing other companies to determine a baseline for healthy usage","gettingStartedGuide":"1. Is there login data readily available for your product? Do you have different licence types?\n2. If yes to login data, determine what make a health active users (e.g logins per month) and unhealthy active users? \n3. Visualise this data within a report which is readily available for to your CSMs","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-210","name":"Refine Usage Analysis Across Companies","maturity":"Run","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Use past learnings and usage data trends to better pinpoint the threshold for a Healthy Active User.","discoveryQuestions":"* How do you currently measure and analyze product usage across different companies?\n* What insights have you gained from past usage data and customer interactions that could inform the criteria for Healthy Active Users?\n* Are there any gaps in your current approach to understanding and optimizing product adoption?","workflowUserStories":"* As a CSM, I want to be able to refine the usage analysis by company to identify how customers are utilizing different features and make recommendations related to poor adoption or white space to guide customers.","gettingStartedGuide":"* Gather and analyze historical usage data across companies to identify trends and patterns\n* Determine the criteria and thresholds for a Healthy Active User based on the collected data\n* Configure Adoption Explorer Rules Engine and Custom Fields to monitor and track usage against the defined criteria","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-211","name":"Identify Usage Patterns by License Type with Monthly Active User Analysis","maturity":"Walk","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Analyze logins across all customers to set the threshold for a license type to be Active, and calculate counts of Active Users per Type.","discoveryQuestions":"* Prerequisite: Does telemetry data exists within Gainsight today?","workflowUserStories":"* As a CSM, I can see the usage data for MAU by license type, with will help me see risk or potential opportunity of an upsell.","gettingStartedGuide":"* Prerequisite: Confirm telemetry data exists within Gainsight\n* CSMs see logins in one place: provide a report of logins over time within the C360 and allow drill downs of who is logging in\n* Have a POV on Healthy Active User: Measure the number of Healthy Active Users over time ","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-212","name":"Compare Usage Across Companies by Normalizing Login Data by License Type","maturity":"Run","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Analyze logins across all customers to set the threshold for a license type to be Healthy, and calculate counts of Healthy Users per Type.","discoveryQuestions":"* What do you do to ensure that your customers are adopting your product?\n* What steps do you take when you realize that a customer is underutilizing your product? \n* Would it be helpful to have proactive alerts when customers are underutilizing your product?","workflowUserStories":"* As a CSM, I want to be able to understand if the number of healthy users of the companies in my portfolio or normal or if there are adoption risks I need to address.\n* As a CS leader, I want to understand what the healthy threshold is of healthy active users across our different customer segments so I can alight health scoring and risk identification accordingly.","gettingStartedGuide":"* Have the CS and Product team collaborate to brainstorm how many logins should make a user a healthy user\n* Capture login data using Adoption Explorer and ensure it is properly tracked\n* Review a small group of customers that are \u201chealthy\u201d and \u201crisky\u201d to determine a healthy active user threshold","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-213","name":"Compare Usage Across Companies by Normalizing Login Data by Customer Attribute","maturity":"Run","components":["Adoption Explorer","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Analyze logins across customer attributes (like Segment or Vertical) to set thresholds for Healthy Usage among similar customers.","discoveryQuestions":"* Do you have access to log in data?\n* What do you think good usage/login data is for each of your segments?\n* What do CSM\u2019s do when they identify low log in data?","workflowUserStories":"* As a CSM, I need a quick way to know when one of my customers is at risk due to usage drops and that varies by segment/vertical.\n* As a CS leader, I need to see at-risk customers from my CSM's portfolios when usage is low to both coach the CSM and find trends for Product.","gettingStartedGuide":"* Segment customers if they are not already\n* Identify any log in trends and assign thresholds for their scorecards","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-214","name":"Make Login and Page View Data Accessible and Actionable in the C360","maturity":"Crawl","components":["Adoption Explorer","Reports","C360","Dashboards"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"High","description":"Capturing Usage Data is only one part of understanding Adoption; make it actionable by embedding Usage reports on the C360 and Dashboards.","discoveryQuestions":"Is usage and adoption information important for your team to see on a granular customer level","workflowUserStories":"* As a CSM, I would like to view Login and Page View Data within the C360 and have it be actionable by embedding Usage reports on the C360 and Dashboards.","gettingStartedGuide":"* audit data sources\n* define visibility needs - what needs to be seen and how should it be visualized","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-215","name":"Make User Action Data Accessible and Actionable in the C360","maturity":"Walk","components":["Adoption Explorer","Reports","C360","Dashboards"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Make sure that new reports are added to existing views when new features or actions are added to Usage tracking.","discoveryQuestions":"* What systems do you use to get a holistic view of the customer? \n* Explain how a single system of truth can provide relevant customer insights to drive efficiency.\n* How do you know where the underlying risks/opportunities are within an account that is using multiple products and/or business units engaged with you?","workflowUserStories":"* As a CSM, I can ensure that reports are added to existing views when new features or actions are added to usage tracking. This saves time and increases efficiency by having a centralized view, which also creates a better customer experience.","gettingStartedGuide":"* Determine the key information CSM\u2019s an CS leaders each need at their fingertips.\n* Clearly define how you want Timeline to be used by CSM\u2019s, and perhaps create templates to assist.\n* Determine and create the key reports and dashboards that would bring the most value to CSM\u2019s and CS leaders.","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-216","name":"Visualize Provisioned Licenses vs Purchased with a Deployment Health Score","maturity":"Crawl","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Set your Deployment Health Score by dividing the count of provisioned licenses by total available.","discoveryQuestions":"* Does your software follow a traditional SaaS licensing model of 1 license\u2192 1 User/Employee\n* What are the different types of licenses that you offer?\n* Do you have insight into how your licenses are being provisioned and to whom?\n* CSM needs to understand what kind of \u201clicense\u201d environment their customer inhabits.  Not all SaaS platforms work off of a traditional license model.  The CSM should understand their customer\u2019s model and react accordingly.","workflowUserStories":"* As a CSM , this is helpful to indicate if my customer are under or over utilizing the license .\n* As. aCS leader, I can easily pull a report of red accounts on basis of licenses and make a startegy .","gettingStartedGuide":"* Create a rule to pull adoption data from your platform\n* SaaS or cloud is best, but manual inputs can be created for On Prem solutions\n* create a rule to trigger a CTA for low/no adoption, missed adoption thresholds, and license overaged\n* Create playbooks based off the type of activity triggering the above CTA\n* Make sure all these actions create a closed loop, reportable system","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-217","name":"Visualize Provisioned Licenses vs Purchased with a Deployment Health Score per License Type","maturity":"Walk","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Set one Deployment Health Score per License Type by dividing the count of provisioned licenses by total available, per Type.","discoveryQuestions":"* Are you capturing deployment information today? How? (Consider different methods such devices activated, number of downloads, etc for different models)\n* Is this represented in health score today?","workflowUserStories":"* As a CSM, I would like to view provisioned licenses vs purchased within a deployment health score per license type to help mitigate risk by monitoring those customers who are low deployed and qualify potential expansion opportunities for fully deployed/over deployed customers.","gettingStartedGuide":"1. Add new fields to Company object:\n  1. Assigned Licenses \n  2. Provisioned Licenses  \n  3. Deployment % = Assigned Licenses / Provisioned Licenses\n2. Set up Rule Rule \u201cCH: Set Scorecard: Outcome Health - Deployment\u201d that will use these fields to set score for Deployment measure (see screeenshot)","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-218","name":"Visualize Active vs Provisioned Licenses with a Depth of Adoption Health Score","maturity":"Crawl","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Set your Depth of Adoption Score by dividing the count of Users who meet the Active criteria by total provisioned.","discoveryQuestions":"* Do you have visibility into deployment/adoption data?\n* Are you bringing that data into Gainsight? Why or why not?\n* Is it actionable?","workflowUserStories":"* As a CSM, I want to see actual data comparing entitlements to deployed and to usage in order to determine the customer's usage patterns and the depth of adoption.","gettingStartedGuide":"* Bring Deployment data into Gainsight via connector or S3 Bucket\n* Determine what level of deployment is considered healthy: Define Green, Yellow, Red\n* Configure Health Score accordingly","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-219","name":"Visualize Healthy vs Provisioned Licenses with a Depth of Adoption Health Score","maturity":"Walk","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Low","enablementEffort":"Low","description":"Set your Depth of Adoption Score by dividing the count of users who meet the healthy criteria by total provisioned licenses.","discoveryQuestions":"* Can you measure number of licenses purchased and provisioned?\n* Have you identified what healthy adoption is?","workflowUserStories":"* As a CSM ,I want to see depth of adoption score and detail information on healthy vs provisioned license to determin if the score resonates with all users or its just for 1 or 2 user actively working .","gettingStartedGuide":"* Identify how many licenses have been purchased\n* Of those purchased, identify how many licenses have been provisioned\n* Specify what healthy adoption (usage) looks like\n* Measure # of licenses deemed healthy as a percentage of total provisioned","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-220","name":"Visualize Active vs Provisioned Licenses with a Depth of Adoption Health Score per License Type","maturity":"Walk","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Set one Depth of Adoption Score per License Type by dividing the license count that meets the Active criteria by total provisioned, by Type.","discoveryQuestions":"* How do you currently monitor and manage license utilization and adoption within your organization?\n* What are the different license types your organization uses, and how do you define an \"Active\" license?\n* What are the specific data points that let me know the specific license types, how many provisioned licenses an account has, and how many active licenses they have assigned?\n* Are there any specific challenges or pain points related to license management and adoption depth that you'd like to address?","workflowUserStories":"* As a CSM, I need to quickly see health data for a customer's Depth of Adoption by license type, as this will indicate if my customer is using our product in a health manner.\n* As a CS leader, I need to quickly see an account's Depth of Adoption health score based on their Provisioned vs Active licenses by type - indicating if this customer is utilizing the product.  I want to see this information by CSM also, to identify any trends in my team's book of business","gettingStartedGuide":"* Identify the criteria for an \"Active\" license and the different license types within your organization\n* Configure the Scorecard Rules Engine to calculate the Depth of Adoption Health Score per license type\n* Develop visualizations to display the relationship between active and provisioned licenses for each license type","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-221","name":"Visualize Healthy vs Provisioned Licenses with a Depth of Adoption Health Score per License Type","maturity":"Run","components":["Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"High","description":"Set one Depth of Adoption Score per License Type by dividing the license count that meets the Healthy criteria by total provisioned, by Type","discoveryQuestions":"* Do you capture Usage data for your platform to determine healthy usage?\n* If yes, do CSMs have visibility of it and how do they leverage this information\n* Is improving adoption part of key objectives for your CS org?","workflowUserStories":"* As a CSM, I need to be able to see Healthy vs Provisioned Licenses with a Depth of Adoption Health Score per License Type to identify early possible red flags or risk,  adoption trend and/or power users.","gettingStartedGuide":"* Bringing is Usage data\n* Set criteria as per # of users that have logged in over different time periods \u2013 daily vs weekly vs monthly per type\n* # hours logged in system, normalized to average customer usage","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-222","name":"Use a Basic Breadth of Adoption Score to Gauge the Degree of Active Usage of a Single Feature","maturity":"Crawl","components":["Adoption Explorer","Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Use Usage data to set three thresholds for healthy use of one top feature, then set a Breadth of Adoption score based on the threshold met.","discoveryQuestions":"1. Do you have product level usage data?\n2. Are you able to tie usage data to a specific user and account? ","workflowUserStories":"* As a CSM, I need visibility into the depth and breadth of Adoption for my customers.","gettingStartedGuide":"1. Determine the total number of users or customers who have access to the feature.\n2. Identify the number of users or customers who have used the feature at least once.\n3. Calculate the percentage of users or customers who have used the feature by dividing the number of users who have used the feature by the total number of users who have access to the feature and multiplying the result by 100.","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-223","name":"Measure Breadth of Adoption Across a Limited Set of Features to Better Visualize Active Usage","maturity":"Walk","components":["Adoption Explorer","Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"Low","description":"Use Usage data to set three thresholds for healthy use of three top features, then use to set a Breadth of Adoption score per feature.","discoveryQuestions":"* Does your company have your product\u2019s top features clearly defined? If so, is the usage data being tracked for the top features?\n* Is the usage data for key features within Gainsight? If not, how long does it take to find key feature usage data for a customer?","workflowUserStories":"* As a CSM, I need systematic insights into the depth and breadth of adoption across the top three features for my customers.","gettingStartedGuide":"* Bring usage data of top three key features into Adoption Center\n* Collaborate with Product team to set thresholds for top three key feature usage data that would be in red, yellow, and green categories\n* Create a Breadth of Adoption measure in the scorecard that is determined by the key feature usage data ","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-224","name":"Refine Breadth of Adoption Calculations with More Granularity or for More Features","maturity":"Run","components":["Adoption Explorer","Scorecard","Rules Engine"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Mature your Breadth of Adoption score: add new Features to Adoption Breadth calculations, or add more granularity to existing calculations. This is the full extent of the solution being used in a healthy manner (e.g., are the right set of features actively leveraged).","discoveryQuestions":"* What do you do to ensure that your customers are adopting your product?\n* What steps do you take when you realize that a customer is underutilizing your product? \n* Would it be helpful to have proactive alerts when customers are underutilizing your product?\n* Under what circumstances what you like a proactive alert about customer adoption?\n\n","workflowUserStories":"* As a CSM, I want to understand which features or activities in the product provide highest value and identify where and how users are struggling within the product.","gettingStartedGuide":"* Conducting chairsides can inform which features or activities bring the most value. \n* Begin capturing usage data and feed that information into your scorecard. \n* Use weekly breadth measurements as leading indicators for GRR, NRR, and Expansion rate lagging outcomes. ","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-225","name":"Calculate Breadth of Adoption Across a Set of Features to Better Measure and Track Healthy Feature Usage","maturity":"Run","components":["Adoption Explorer","Scorecard","Rules Engine","Custom Fields"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"Medium","description":"Calculate Breadth of Adoption per feature by dividing the count of Healthy Active Users of that feature by total Provisioned Licenses.","discoveryQuestions":"* Important to learn if the customer has an on-prem product. If the customer has an on-prem product, 90% of the time they will not have access to the feature/product usage analytics.\n* Do you have product analytics available per product either through PX or through similar functionality?\n* Do you have an established point of view on how each individual feature\u2019s adoption should be viewed relative to other features? Relative to the entire portfolio? This will help guide your initial measures of what \u201chealthy\u201d feature adoption behavior looks like and you can measure on. ","workflowUserStories":"* As a CSM, I want to understand how my customer is leveraging the different features they purchased, so that I can quickly highlight areas of poor product adoption and guide the customer to focusing on why certain features may be underleveraged relative to others.\n* As a CS leader, I want to provide my CSMs insight into their customer's specific product feature adoption so that they can be proactive in their enagements; providing the customer valuable insights into how their user base is or isn't performing relative to an established view of \"successful\" adoption.","gettingStartedGuide":"* Important to learn if the customer has an on-prem product. If the customer has an on-prem product, 90% of the time they will not have access to the feature/product usage analytics.\n* Do you have product analytics available per product either through PX or through similar functionality?\n* Do you have a way to determine which features are being used and by how many users? If not, which products are currently instrumented (let\u2019s start with that)?\n* Do you have different organizations using your products differently? For example, if you are selling to product organization and services organization, will these two organizations use the product differently and should be measured independently?\n* Do you have different licenses and does the product usage differ by license?\n* Provided you have a way to track individual product feature usage, establish a threshold/measure of what \u201chealthy\u201d is; what would a \u201cpoor\u201d or \u201cconcerning\u201d level of feature adoption look like relative to the full portfolio of features? Is this threshold consistent for all customers or unique by customer segment or other distinguishing criteria? \n* Create a scorecard measure/group in your Customer Scorecard to tie the health thresholding above into the overall healthscore \u2014 how heavily should this be weighed relative to other measures of health? ","outcome":"Improve Adoption Depth and Breadth","stream":"Promote Feature Utilization"},{"id":"WF-231","name":"Enhance Customer Meetings with Point-in-Time Adoption Metrics","maturity":"Crawl","components":["Adoption Explorer","Dashboards"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Proactively discuss product adoption during customer interactions with a basic view of usage data filtered for a single customer.","discoveryQuestions":"* Do you know how your customers are using your product?  \n* Where does this information live?\n* How long does it take a CSM to find and understand adoption data?\n* Do your customers have easy access to their own adoption data?","workflowUserStories":"* I'd want to be able to discuss real time adoption metrics using PX or other and speak to areas most visited, least visited, etc.","gettingStartedGuide":"* Bring usage data into Gainsight\n* Create Adoption Explorer reports focused on top/high value features","outcome":"Improve User Engagement and Experience","stream":"Increase User Engagement"},{"id":"WF-232","name":"Deepen Customer Dialogue with Trending Adoption Insights","maturity":"Walk","components":["Adoption Explorer","Dashboards"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Be prepared to discuss progress towards product adoption goals with trending views of usage data filtered for a single customer.","discoveryQuestions":"* How often do you engage with your customer to gather feedback on your product/service?\n* Have you identified any trends in your customer\u2019s adoption?\n* Have you noticed any changes in customer usage behavior or preferences\n* Do you have process in place to for analyzing customer feedback and identifying trends?","workflowUserStories":"* As a CSM, I want to more easily discuss product adoption with supporting data for my customers.","gettingStartedGuide":"* Analyze data collected to identify trends & Patterns to gain insights of user behavior, preferences and needs\n* Engage in Two way communication: Responding to their feedback and keeping customer updated on any enhancements made as a result of their input\n* Use Technology - share weekly adoption reports with holistic insights through journey orchestrator to customers based on adoption goals\n* Personalize experience - By sharing best practices and helping customer suit the workflows as per their org\u2019s usecases and needs","outcome":"Improve User Engagement and Experience","stream":"Increase User Engagement"},{"id":"WF-233","name":"Automatically Embed Trending Adoption Data in Customer-Facing Emails and Presentations","maturity":"Run","components":["Adoption Explorer","Reports","Success Snapshots","Journey Orchestrator"],"valueDrivers":["Adoption"],"setupEffort":"High","enablementEffort":"Medium","description":"Make the sharing of adoption data automatic by embedding reports into Success Snapshots and emails sent through Journey Orchestrator.","discoveryQuestions":"* Do we have adoption data readily available in Gainsight reports that we can share with customers?\n* Do we know what adoption data would be meaningful to share with customers?","workflowUserStories":"* As a CSM, I would like the ability to automatically embed trending adoption data in customer-facing emails and presentations to measure the impact to feature adoption rate as a result of implementing the processes defined in this workflow.","gettingStartedGuide":"* Adoption data should be readily available to report off of within Gainsight. Native connectors can be configured or the S3 bucket can be leveraged to ingest external usage data to be stored in Gainsight\u2019s MDA\n* Once adoption data is reliably being pushed into Gainsight at a regular cadence the creation of desired adoption reports should be created via the report builder or adoption explorer\n* Once desired adoption reports are created, they can be embedded in a Success Snapshot template to be shared with customers in a PPT or Google Drive presentation format.  The reports can also be embedded within an email template to be regularly sent to customers in an automated fashion at a standardized cadence via Journey Orchestrator","outcome":"Improve User Engagement and Experience","stream":"Promote Feature Utilization"},{"id":"WF-246","name":"Analyze Support Tickets for Product Feedback trends","maturity":"Crawl","components":["Reports","Dashboards"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Tag tickets by feature and request type to assist regular analysis to understand where enablement or product UX improvement is needed.","discoveryQuestions":"* Are you currently bringing ticket data into Gainsight? \n* If not, where is current ticket data stored and what would it entail to bring in ticket data into Gainsight (i.e. any internal resources on the client\u2019s side)? \n* If ticket data is currently within Gainsight, what fields are included in the ingest of ticket data, specifically are they able to tag tickets by feature and request type? \n* If ticket data is currently within Gainsight,  how are they leveraging the data to gather insights? For example, are there reports built to show the volume of tickets by feature to provide insights from the ticket data?","workflowUserStories":"* As a CSM, I need a consolidated view for Support tickets to understand product feedback insights and trends.","gettingStartedGuide":"* Bring in ticket data. Compile all ticket data in Gainsight with common methods including S3 Bucket, Gainsight\u2019s Zendesk integration, tickets stored in Salesforce (Salesforce case or populated by apps like Zendesk\u2019s Salesforce app), etc. \n* Recommended fields include Status, Priority, Type of Question, Product, Feature, Includes a bug?, includes feature enhancement request?, and bug expected fix date. \n* Turning data into insights with reports and dashboards. Leverage reports within Gainsight to see volume of tickets by feature, average time to close ticket by feature, etc.  ","outcome":"Improve User Engagement and Experience,Prioritize R&D Effectively","stream":"Capture insights to inform product developement"},{"id":"WF-249","name":"Help Customers Self-Correct Adoption Issues by Sharing Usage Trends","maturity":"Walk","components":["Journey Orchestrator","Reports","Shared360"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Enable customers to self-correct adoption issues by giving them views into their usage trends.","discoveryQuestions":"* Are you able to tell compelling stories with your usage data that can help customers better adopt high value features?\n* How do you share usage data with your customers today?\n* What usage data do you currently have access to? If limited today, is there additional data that can be utilized? ","workflowUserStories":"* As a CSM, I want to increase transparency and self-service with customers by being able to share usage and adoption data through reports or dashboards.","gettingStartedGuide":"* Pre-req: Make sure usage data is available through PX or some other data capture tool\n* Determine what data is useful: such as what features are more likely to be widely adopted vs limited in implementation; are there black out periods where trends may be skewed; or has there been a major change to a feature that would make older data irrelevant?\n* Create reports and dashboards that allow trends to be analyzed\n* Enable ways that this data can be shared, such as through Share 360, sending reports via JO, etc.","outcome":"Improve Adoption Depth and Breadth","stream":"Identify Adoption Gaps and Challenges"},{"id":"WF-250","name":"CSMs Can Access GS Action Items Wherever Work Happens","maturity":"Crawl","components":["Calendar Integration","Sally Slackbot","Mobile App"],"valueDrivers":["Scale"],"setupEffort":"Low","enablementEffort":"Medium","description":"Push CTAs to CSM's web calendars and Slack, and give them access to view update Gainsight on-the-go via the Mobile App.","discoveryQuestions":"Do you use calendar integration? (NXT only)\nDo you use the mobile app?\nDo you use Slack integration?","workflowUserStories":"* As a CSM, I want to be able to leave Customer Timeline notes while outside the office, so that I can ensure any/all pertinent updates are being captured wherever I am.\n* As a CS Executive, I want to quickly understand any open activity or risks present for a customer on my mobile device, so that I can have the latest information at my disposal at a moments notice, whevever I am.","gettingStartedGuide":"CTAs\n\n \u2022 Create CTA for every action you do with a customer\n\n \u2022 Assign due date to prioritize CTAs\n\n \u2022 Create custom fields on CTAs to track different data for each type of CTA\n\nSummarize discussions & action items during/after a call or meeting\n\n \u2022 Log your notes as an Activity\n\n \u2022 Add follow-up tasks in the Timeline entry; those will be visible in Cockpit\n\nDashboards\n\n \u2022 Have a CSM dashboard to get a quick view of your portfolio to prioritize actions\n\n \u2022 Set-up customized reports to be viewable on Dashboard\n\nSlack Notifications\n\n \u2022 Subscribe for Slack notifications when a CTA assigned/updated/someone tagged you in Timeline\n\n \u2022 Set-up/customize notification preferences\n\nSalesforce\n\n* Ensure sync settings for CTA/Playbook tasks are enabled if CSMs wish to also see/manage tasks in Salesforce. ","outcome":"Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-251","name":"CSMs Can Access Common Email Templates from their Email Inbox","maturity":"Crawl","components":["Gainsight Assist"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Use Gainsight Assist to bring the editable email Templates CSMs use today with Email Assist, directly into their Gmail or O365 inbox.","discoveryQuestions":"Do you use Gmail or Office 365?\nDo you use Email Assist?\nWhat common types of email templates are used regularly?","workflowUserStories":"* As a CSM, I want to quickly access relevant and common email templates to send to clients to increase my day to day efficiency\n* As a CS Leader, I want to quickly access relevant and common email templates to check in with clients from the leadership persona","gettingStartedGuide":"GS Email Assist Plugin\n \u2022 Install GS Assist Chrome Plug-in from Chrome Web Store\n \u2022 After installing, refresh your Gmail account to view Gainsight logo in the sidebar\nRecommendations\n \u2022 Customize Email templates before sending to ensure only relevant information & links are included\n \u2022 Optional: check \"Log to Timeline\" box which will automatically log the email in the customer's Timeline\n \u2022 Quickly search for the appropriate email template to leverage using the search functionality in the Gainsight Email Assist plugin","outcome":"Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-252","name":"Streamline and Consolidate your \u201cSpreadsheet\u201d Initiatives","maturity":"Walk","components":["CTAs w/ Linked Objects","Playbooks","Low Volume Objects"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"High","description":"Use a Low Volume object and CTAs to centralize initiatives tracked in a spreadsheet (like Product changes) into Gainsight.","discoveryQuestions":"* Does your team or other teams use spreadsheets to track any processes? If so, is this information needed by other teams?\n* How much time does it take to find key customer information from other teammates?","workflowUserStories":"* As a CSM , I want to have a single place to maintain my initiative for the customer , this will give me a good day to day taqsk view and increase my efficiency.\n* As a CS Leader, i can see open initiateves of my reportees and drive it . Also i can standardize the plans.","gettingStartedGuide":"* Review which spreadsheets contain critical processes where visibility is crucial for multiple teams/teammates\n* Create low volume object to bring data into Gainsight. Create a report to visualize the incoming data\n* Create CTAs based on crucial data changes reflected in report","outcome":"Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-253","name":"Update Customer Records and Scorecards from a Dashboard","maturity":"Walk","components":["Dashboards","Scorecard Mass Edit","Gainsight Home"],"valueDrivers":["Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Enable CSMs to update customer attributes and Scorecard notes from Gainsight Home, or from a centralized Dashboard.","discoveryQuestions":"* How do you run your internal meetings i.e. your risk meetings and where do you record updates ? \n* How many tools do you need to use in order to access and / or update customer attributes ? \n* How do you currently make real-time updates on health score measures? \n* Do changes made to any report field need to write back to source CRM? Where is the source of truth?\n\n","workflowUserStories":"* As a CSM, I need one place to update multiple customer's manual scorecard measures and certain data fields to save time and be more efficient.\n* As a CS Leader, I need to improve operational efficiency for my team and having a dedicated page to update records and manual measures for their book of business would satisfy this need.","gettingStartedGuide":"* Identify what relevant customer attributes require high visibility and updates to be made \n* Identify what scorecard measures require manual updates and notes to be added for additional context i.e. Engagement, Adoption, CSM sentiment measure etc. \n* Identify what type of end-users are should make updates to customer attributes and/or scorecard measures\n* Identify what Dashboard the scorecard or customer attribute reports need to be included in and who require access / visibility to these Dashboards?\n* Identify what internal processes or meetings require end-users to update customer attributes or scorecard measures i.e. Bi-weekly Risk Meeting or 1:1s ","outcome":"Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-254","name":"Personalized Home for CSMs","maturity":"Crawl","components":["Gainsight Home"],"valueDrivers":["Scale","Scale"],"setupEffort":"Low","enablementEffort":"Medium","description":"Dynamic landing page that provides access to everything CSMs need to do their jobs in one place. CSMs can also further customize to meet their individual needs.","discoveryQuestions":"How much time does it take CSMs to access the relevant customer data they need to effectively prep for a customer interaction?\nWhere do CSMs access data to access the overall state of their portfolio? (Which accounts coming up for renewal, at risk, etc?)","workflowUserStories":"* As a CSM, I want a single place to access important information about my portfolio of customers that is customized based on my needs.\n* As a CS Leader I want a single place to access important information about my portfolio of customers that is customized based on my needs.","gettingStartedGuide":"Use Cockpit as central location for all to-do items\n \u2022 Add CTA's from Cockpit or Tasks from Timeline\n \u2022 Assign realistic due dates to keep yourself on track\n \u2022 Create CTA templates for common activities (used for repeatable actions, ensures consistent set of actions)\nCustomize Cockpit layout in a way that serves up tasks and CTAs in a view that is most relevant you (CSM)\n \u2022 Drag and drop columns to rearrange cockpit view\n \u2022 Remove unnecessary columns/add new columns that are relevant\nCollaborate by assigning CTA's or Tasks to teammates\n \u2022 Assign CTA or individual tasks to others by updating the \"Owner\" field\n \u2022 Allows for collaboration and visibility into completed tasks","outcome":"Increase Customer Facing Teams Impact,Increase Customer Facing Teams Impact","stream":"Enhance Productivity"},{"id":"WF-255","name":"Track EBR Compliance with a Health Score Measure","maturity":"Crawl","components":["Scorecard","Rules Engine","Timeline"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Track compliance to a segment-defined EBR cadence using your Scorecard.","discoveryQuestions":"Where/how are EBRs tracked to ensure compliance with defined cadence?\nHow easy/difficult is it for you to identify customers that are out of compliance? \nIs this information easily accessible to CSMs/CS leaders?","workflowUserStories":"* As a CSM, I want to be able to easily validate my EBRs have been delivered and are within compliance.\n* As a CS Leader, I want to be able to track EBR compliance and quickly be able to see if a customer's EBR is overdue.","gettingStartedGuide":"Track all EBRs in Timeline for Global visibility\n \u2022 Use Gainsight Assist or BCC to Timline to log every EBR to Timeline\n \u2022 Include important attachments when logging to document full scope of the EBR\nAssign ownership of tasks\n \u2022 Use Tasks associated with Timeline entries to assign ownership of related action items\nReports/Dashboards\n \u2022 Create reports to track for visibility on when the last EBR occured\nInfluence customer health\n \u2022 Based on when an EBR occured, influence Customer Health Measure accordingly","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-256","name":"Track Exec Engagement Compliance with a Health Score Measure","maturity":"Crawl","components":["Scorecard","Rules Engine","Timeline"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Track compliance to a segment-defined Exec Engagement cadence using your Scorecard.","discoveryQuestions":"Where/how are Exec Engagements tracked to ensure compliance with defined cadence and is there a standardized cadence?\nHow easy/difficult is it for you to identify customers that are out of compliance? \nIs this information easily accessible to CSMs/CS leaders?","workflowUserStories":"* As a CSM, I want to be able to link a customer's Executive Engagement compliance with their account's health and then act upon the results\n* As a CS Leader, I want to be able to track compliance with Executive Engagement and correlate Executive Engagement with portfolio risk and health","gettingStartedGuide":"Track all Exec Engagements in Timeline for Global visibility\n\n \u2022 Use Gainsight Assist or BCC to Timeline to log every Exec Engagement to Timeline\n\n* Include important attachments when logging to document full scope of the interaction\n\n \u2022 Utilize Timeline Activity Templates to facilitate standardization in activity logging\n\nAssign ownership of Engagement follow-on tasks\n\n \u2022 Use Tasks associated with Timeline entries to assign ownership of related action items\n\nSet up Health Score Measure Automation\n\n \u2022 Create a Health Score Measure for \u201cExecutive Engagement\u201d to add to your Scorecard\n\n \u2022 Set up rule that sets Customer Health Measure for Executive Engagement based on when the most recent Executive Engagement Activity occurred relative to target cadence/dates\n\n \u2022 Set up follow-on rule that creates a CTA for CSM to engage executives if the health score drops due to non-compliance\n\nReports/Dashboards\n\n \u2022 Create reports to track for visibility on when the last Exec Engagements occurred, if those Activities were in compliance, and target dates for upcoming Engagements\n\n \u2022 Create additional reports showing Health Score trends over time relative to Executive Engagement Timeline Activities to help prove correlation between CS activities and Health\n\n","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-257","name":"Track CSM Meeting Compliance with a Health Score Measure","maturity":"Crawl","components":["Scorecard","Rules Engine","Timeline"],"valueDrivers":["Adoption"],"setupEffort":"Medium","enablementEffort":"Low","description":"Track compliance to a segment-defined CSM Meeting cadence using your Scorecard.","discoveryQuestions":"Where/how are regular CSM meetings tracked to ensure compliance with defined cadence?\nHow easy/difficult is it for you to identify customers that are out of compliance? \nIs this information easily accessible to CSMs/CS leaders?","workflowUserStories":"* As a CSM, I want to be alerted if I have not held imporant meetings any of my customers in the time prescribed for an optimal customer experience. I can clearly see how not adhering to the meeting cadence impacts the health of my customer, and can see clearly what I need to do to make the customer healthy again.\n* As a CS Leader, I want to be alerted if any of my CSMs have not held imporant meetings any customers in their portfolio, in the time prescribed for an optimal customer experience. I can clearly see how not adhering to the meeting cadence has impacted the health of thier customer(s), and can see clearly what can be done to make the customer healthy again.","gettingStartedGuide":"Meeting Compliance by Type:\n\n* Decide how CSMs will indicate specific types of meetings and configure your Timeline functionally accordingly. For example, consider a field on the Activity Timeline layout where the CSM can select \u201cEBR\u201d when they hold an EBR with the customer. Or for events that are important enough, some customers have a unique activity Type for that.\n* Decide which activity types should influence the meeting cadence score. And decide the frequency that would result in good, medium, or poor health. Think through and document these business rules.\n* Finally, a rule in Rules Engine will be required to read the various events in the Activity Timeline, then derive and populate the appropriate score on the scorecard. So be ready to have your admin create a rule once the timeline configuration is complete, and CSMs have started logging activities accordingly.\n\n\n\nActivity Frequency: \n\n\u2022 Use Gainsight Assist or BCC to Timeline to log every customer meeting to Timeline\n\n\u2022 Include important attachments when logging to document full scope of the interaction\n\nAssign ownership of tasks\n\n\u2022 Use Tasks associated with Timeline entries to assign ownership of related action items\n\nReports/Dashboards\n\n\u2022 Create reports to track for visibility on when the last customer meeting occurred\n\nInfluence customer health\n\n\u2022 Based on when a customer meeting occurred, influence Customer Health Measure accordingly","outcome":"Optimize Customer Journey","stream":"Standardize Best Practices"},{"id":"WF-258","name":"Display Customer Entitlements in the C360","maturity":"Crawl","components":["Reports","C360"],"valueDrivers":["Expansion","Scale","Expansion"],"setupEffort":"High","enablementEffort":"Low","description":"Make it easy to understand what services and products each customer has paid for by embedding entitlement reports in the C360. A Journey Orchestrator program could also be added to distribute communication such as Product Release notes and customer use cases to help educate customers of potential features and benefits","discoveryQuestions":"How do you keep track of the products or services a customer has purchased?\nIs this info easily accessible to internal teams?","workflowUserStories":"* As a CSM, I want to have a clear undertanding of what all products & services the customer has purchased and be able to identify upsell opportunities based on products not listed/purchased.","gettingStartedGuide":"Create Reports to easily identify which entitlements your customer has purchased\n\n \u2022 Include Product/Services/Offerings the client has and has NOT purchased using a table with one row for each unpurchased feature at each customer\n\n \u2022 Cell values within tables should list out current spend, license count, utilization %, and whether or not they have access/purchased the feature\n\nCreate Journey Orchestrator program to notify customers of current product capabilities and Customer use cases\n\n* Include Product features white papers or product release notes to educate existing customers of possible product features they already have as well as those not currently utilized/purchased","outcome":"Reduce Revenue Leakage,Increase Customer Facing Teams Impact,Reduce Revenue Leakage","stream":"Centralize Customer Data"},{"id":"WF-259","name":"Display Whitespace Reports in the C360","maturity":"Walk","components":["C360","Reports","Data Designer"],"valueDrivers":["Expansion","Expansion"],"setupEffort":"High","enablementEffort":"Low","description":"Clearly display the products and services customers have, and have not, purchased in the C360.","discoveryQuestions":"* Do you current have a source of truth of Customer Entitlements within your data? \n* Is that data already flowing into Gainsight or can you get it to?","workflowUserStories":"* As a CSM, I would like toclearly see the products and services customers have, and have not, purchased in the C360.","gettingStartedGuide":"* Ensure the necessary Entitlements data is available within Gainsight\n* Build an Entitlements report in Horizon Analytics to display what is and is not currently purchased by the customer\n* Create a new Report tab in the C360 layout that includes that Entitlements report","outcome":"Reduce Revenue Leakage,Reduce Revenue Leakage","stream":"Centralize Customer Data"},{"id":"WF-260","name":"Proactive Whitespace Research","maturity":"Run","components":["Reports","Low Volume Objects","CTAs w/ Linked Objects"],"valueDrivers":["Expansion"],"setupEffort":"High","enablementEffort":"Medium","description":"Do targeted, customer-level research into the whitespace of a specific product, feature or service; share results with Sales.","discoveryQuestions":"Does your team know where to go to understand what a Customer is licensed for? \nWhere is this information held? \nHow much time/effort does this take? \nHow do they relay that information to their sales partner when opportunity arises?\n","workflowUserStories":"* As a CSM, I would like to do targeted, customer-level research into the whitespace of a specific product, feature or service to share results with Sales.","gettingStartedGuide":"1) Create a table on the C360 that displays all available entitlements\n2) Display indicator on which entitlements customers currently are licensed (Yes/No, Most Recent contract Start/End date)\n3) Ability to filter out (yes) from reporting or create two tables:\n-Current entitlements\n-Not licensed \n4) If opportunity comes up, CSM to create CSQL","outcome":"Reduce Revenue Leakage","stream":""},{"id":"WF-262","name":"Portfolio Whitespace Dashboard","maturity":"Walk","components":["Reports","Dashboards","Data Designer"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Display portfolio-level whitespace insights on a Dashboard.","discoveryQuestions":"1. What are the most common ways that your customers expand with you? Rank in priority order to determine where you will have the most success with whitespace reporting. \n2. What customer information do you have access to that could be used to drive whitespace reporting (examples: Employee size, industry, ARR, major use cases, # of business units, company acquisition information). \n3. What usage data do you have access to that could be used to drive whitespace reporting (examples: # of support tickets for identification of Premium Support Package upsell, # of licenses purchased vs. % used, etc.)","workflowUserStories":"* As a CSM, I need to understand whitespace opportunity within my customer portfolio to help with identifying upsell opportunities.","gettingStartedGuide":"1. Identify important metrics to understand upsell potential (examples include: scorecard metrics, % customer penetration (# of licenses compared to # of employees), Premium Support Opportunity due to 5+ High severity Support tickets). \n2. Evaluate how to use health scoring to determine if a customer is \u201cripe\u201d for expansion. \n3. Build reports of \u201csimilar customers\u201d to identify missing opportunities for up-sell/cross-sell. (examples: enterprise customers without professional services engagements)","outcome":"Reduce Revenue Leakage","stream":""},{"id":"WF-263","name":"Basic Account Planning","maturity":"Crawl","components":["Timeline"],"valueDrivers":["Expansion"],"setupEffort":"Low","enablementEffort":"Low","description":"Use a custom Timeline entry to document internal Account Planning conversations with Sales.","discoveryQuestions":"How do your CS and Sales currently collaborate on joint accounts?","workflowUserStories":"* As a CSM, I need to efficiently document collaboration with other internal teams.","gettingStartedGuide":"Setup Timeline Templates with Account Plan information","outcome":"Increase Expansion Velocity","stream":"Standardize Best Practices"},{"id":"WF-264","name":"Comprehensive Account Planning","maturity":"Walk","components":["Success Plans"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Develop a thorough account planning process that ties Success Plan Objectives to un-purchased products and un-met customer needs, while fostering regular collaboration with the Account team to track progress and drive account growth.","discoveryQuestions":"* How does your organization currently approach account planning and expansion opportunities?\n* What challenges, if any, have you faced in aligning your Customer Success and Account teams for account planning?\n* Are there any un-purchased products or un-met customer needs that you\u2019d like to address through a more comprehensive account planning process?","workflowUserStories":"* As a CSM, I need a thorough account planning process that ties Success Plan Objectives to un-purchased products and un-met customer needs, while fostering regular collaboration with the Account team to track progress and drive account growth.","gettingStartedGuide":"* Identify un-purchased products and un-met customer needs that can be tied to Success Plan Objectives\n* Establish a regular meeting cadence with the Account team to review progress and discuss account planning\n* Utilize Success Plans to track objectives, milestones, and progress for each account","outcome":"Increase Expansion Velocity","stream":"Use Customer Signals to Generate Pipeline"},{"id":"WF-265","name":"Manual Review of Closed Lost/Won Expansion Opportunities","maturity":"Crawl","components":["CTAs (Manual)","Timeline"],"valueDrivers":["Scale"],"setupEffort":"Low","enablementEffort":"Low","description":"Retroactively review all Expansion deals after they close, whether or not they were Closed Won, and document and distribute findings.","discoveryQuestions":"1.) Do you have a sync between Gainsight and your CRM?\n2.) Do you have a separate team that runs the expansion opportunities for your current customers?","workflowUserStories":"* As a CSM, I want to be able to have visibility into expansion opportunity status (closed lost/won), so that I can be knowledgable on the customer's interaction with my Sales organization (or whoever is managing the Opportunities, if not CS) and best support my customer regardless of the outcome.\n* As a CS Leader, I want my CSMs to have the ability to view/research opportunity data from within Gainsight, so they can have the most current customer info in one place without having to toggle between systems, therefore enabling them with the necessary information to best serve their customers.","gettingStartedGuide":"1.) Setup a CTA to fire when opportunities close in the CRM. Have a playbook for both Closed Won and Closed Lost opportunities \n2.) CSM can take any notes/findings and document it in Timeline for future reference\n3.) Create 360 reporting on related Opportunities, providing high level opp details from within Gainsight to review. ","outcome":"Prioritize R&D Effectively","stream":"Account planning for expansion"},{"id":"WF-266","name":"Expansion Closed Lost/Won Survey","maturity":"Walk","components":["Surveys"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Survey both Sales and Customer after a deal is marked as Closed (whether or not it was Closed Won) to better understand the factors that influenced the outcome.","discoveryQuestions":"* Does the team handling expansions review previous closed deals to improve the process/strategy?\n* Are you involved with upsell/cross sell opportunities? If so, how? \n* How do you collaborate with Sales for expansions?","workflowUserStories":"* As a CSM, I want to review a report showing insights into why clients Closed Won or Closed Lost o better increase Closed Won opportunities.","gettingStartedGuide":"* Create survey in Gainsight to send to Customer and Sales member after a deal is closed to understand why the customer did or did not expand\n* Create CTA that is triggered when the customer survey is submitted in order to review their response\n* Sales team to connect and discuss what worked well and what may need improvement during the deal process","outcome":"Prioritize R&D Effectively","stream":"Orchestrate Expansion Campaigns & Initiatives"},{"id":"WF-267","name":"Systematically Share Expansion Trends Internally","maturity":"Walk","components":["Dashboards","Journey Orchestrator"],"valueDrivers":["Scale"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Surface trends found from Expansion deal analysis to internal groups.","discoveryQuestions":"How do you determine which customers are candidates for additional deployment or products? What playbooks or execution plans do you follow when approaching expansion opportunities? What reports do you use to view progress, opportunities, or current CSQLs out there? ","workflowUserStories":"* As a CSM, I'd want to understand why customers don't expand but also understand the trends behind customers that do renew or expand.","gettingStartedGuide":"Implement processes to identify and act on upsell and cross-sell potential within your existing customer base. How? \nProvide Reports and CTAs to Sales and Customer Success teams to identify customers whose data demonstrates maximum deployment or product whitespace. Use Journey Orchestrator to engage low-touch customers. Leverage Playbooks to execute best practice expansion motions. Build reports to provide visibility into expansion values. Operational Metrics\nCTAs (open and closed)\nLeading Indicators\nOpportunities created (count and $$)\nDeployment score\nAdoption score\nLagging Outcomes\nExpansion\nRetention\n","outcome":"Prioritize R&D Effectively","stream":"Use customer signals to generate pipeline"},{"id":"WF-268","name":"Proactive Targeted Whitespace Emails to Sales","maturity":"Run","components":["Journey Orchestrator"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Distribute whitespace research & analysis back to Sales via automated emails.","discoveryQuestions":"* How are you identifying potential expansion candidates?\n* Does Sales have visibility to whitespace?","workflowUserStories":"* As a CSM, I want to easily be able to engage the appropriate sales team member on potential up/cross-sell opportunities.","gettingStartedGuide":"* Create Journey Orchestrator program to regularly send potential expansion candidates to appropriate sales team member","outcome":"Reduce Revenue Leakage","stream":""},{"id":"WF-269","name":"Use Whitespace Data to Drive Targeted Cross-Sell Campaigns","maturity":"Run","components":["Journey Orchestrator"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Target customers for automated cross-sell email campaigns based on data trends, products they haven\u2019t purchased, and other customer attributes (like industry).","discoveryQuestions":"* How do you evaluate whitespace?\n* How are you tracking expansion today?\n* How long does it take for customers to expand?\n* What expansion opportunities are available at your company?","workflowUserStories":"* As a CSM, I need to be able to easily identify any whitespace opportunities so I can either pursue the cross-sell myself or direct my team mates to any potential cross-sells in my book of buisness.\n* As a CS Leader, I need to be able to have my team identify, communicate, and action on any cross-sell opportunities. This will help to prove my team's ongoing value to the organization.","gettingStartedGuide":"* Create purchased vs. non-purchased customer asset reports for identifying whitespace and surface them on C360 and Dashboards\n* Identify customers who have a propensity to expand: Use Adoption Data + Customer Health Scores to identify strong cross-sell opportunities \n* Journey Orchestrator emails customers to gauge interest in additional products: Refer to \u201cProduct Cross-Sell Survey\u201d Solution in Sightline Vault for best practices and downloadable assets\n* Use Survey Responses to create CSQLs for action\n* Survey customers that did not expand. Analyze results of failure to expand survey and run a closed loop process to address the reasons","outcome":"Reduce Revenue Leakage","stream":""},{"id":"WF-270","name":"Use Customer Data to Drive Targeted Upsell Campaigns","maturity":"Run","components":["Journey Orchestrator"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Target customers to increase an existing entitlement with automated emails driven by customer data.","discoveryQuestions":"* How are your CSMs incentivized to identify expansion opportunities?\n* How do AEs and CSMs collaborate today to manage expansion opportunities?\n* What kind of usage data are you capturing that you could leverage to engage with customers about potential expansion?","workflowUserStories":"* As a CSM, I would like to use customer data to increase an existing entitlement through automated emails driven by customer data.","gettingStartedGuide":"* Agree on how you want to identify expansion opportunities (telelmetry, CSM meeting notes, etc.)\n* Define the conversation mechanism(s) - Email templates based on data gathered, for example\n* Integrate with your CRM system to turn CSQL\u2019s into Leads or Opportunities","outcome":"Increase Expansion Pipeline","stream":""},{"id":"WF-271","name":"Begin Documenting Customer Org Hierarchies During the Sales Process","maturity":"Run","components":["People Maps"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Medium","description":"Have the Sales team begin building out a customer People Maps during the Sales process, so that all key contacts and relationships are documented for onboarding.","discoveryQuestions":"* Does your sales team have licenses (without a valid license type, the sales team will not be able to make changes to the people map)?","workflowUserStories":"* As a CSM, I would like to view documented customer org hierarchies within People Maps that were captured during the sales process so that all key contacts and relationships are documented for onboarding.","gettingStartedGuide":"* Do you have the contacts in Salesforce or other CRM?\n* Are you bringing those contacts into Gainsight person object? (you can also check SFDC connectors in order to answer that)\n* How many customers does your sales person have and how do they prioritize these (if the sales person has 100s of customers, people maps is not a viable option unless they are prioritizing top 20)\n* How does your sales person keep track of different players in the customer\u2019s organization?","outcome":"Increase Expansion Velocity","stream":"Centralize Customer Data"},{"id":"WF-272","name":"Bring Existing Usage Data into Gainsight","maturity":"Crawl","components":["Connectors","Reports","C360"],"valueDrivers":["Adoption","Scale"],"setupEffort":"Medium","enablementEffort":"Low","description":"Import usage data into Gainsight, or reference usage data stored in Salesforce, to utilize all existing usage data in Gainsight.","discoveryQuestions":"Where do CSMs access usage data?\nHow effective are you at identifying adoption trends or low usage patterns?","workflowUserStories":"* As a CSM, I want to have a centralized location where I can access all existing usage data to determine my clients adoption and utilization","gettingStartedGuide":"CRM Connector\n \u2022 Pull key usage data into GS from your other system where this info exists\n \u2022 Identify data inputs to bring over \u2022 not recommended to bring all data over at once. Use CSM feedback to iterate on which data should be pulled into Gainsight\nReports\n \u2022 Centralize CRM, Support, and Usage data and reports at the account level in C360, and across multiple accounts on the CSM Dashboard","outcome":"Improve Adoption Depth and Breadth,Increase Customer Facing Teams Impact","stream":"Centralize Customer Data"},{"id":"WF-273","name":"Send CSQLs (CS Qualified Leads) to Sales","maturity":"Crawl","components":["Timeline"],"valueDrivers":["Expansion"],"setupEffort":"Medium","enablementEffort":"Low","description":"Identify and share leads with the Sales team directly from Customer360 in Gainsight","discoveryQuestions":"* How does your team identify new upsells and expansion opportunities? \n* What is the process after a new upsell or expansion opportunity is identified?\n* How do you quantify the impact the CS team has on revenue?","workflowUserStories":"* As a CSM, because I am engaged with my customer and their evolving needs I can identify when a lead for cross sell or upsell arises. I want to easily report this lead to Sales so that we can take advantage of the opportunity, but also would like to receive credit for having sourced the lead.\n* As a CS leader, I want to help my organization not only by making our renewal number, but also by creating opportunities for our Sales team to win more business. When my CSMs do identify such opportunities i want an easy way for them to capture the lead, and I also need a way for the lead to be attributed to my organization so that everyone can clearly see the additional value that we are providing.","gettingStartedGuide":"* Add the Leads section to C360 Layouts, you can create Leads from the Company page\n* CSQLs can be configured to store leads only in Gainsight, synchronize with Salesforce\u2019s lead object, or use Rules Engine to send CSQLs to other objects or CRMs","outcome":"Increase Expansion Pipeline","stream":""},{"id":"WF-274","name":"Attribute Value to CSQLs","maturity":"Walk","components":["CTAs (Manual)","Timeline","CTAs w/ Linked Objects","Data Designer"],"valueDrivers":["Expansion"],"setupEffort":"Low","enablementEffort":"Medium","description":"Link Expansion opportunities to CTAs using Linked Objects to accurately track the value of leads sent to Sales.","discoveryQuestions":"* How do your CSMs pass leads to sales today?\n* Do your CSMs have the product knowledge and discovery training on all your products to find opportunities for crossell? \n* Do you have any variable comp associated with lead generation? ","workflowUserStories":"* As a CSM, I want to link Expansion opportunities to CTAs using Linked Objects so I can accurately track the value of leads that are sent to Sales.","gettingStartedGuide":"* Determine if you need to connect this to leads or opportunities in Salesforce\n* Align with your sales partners on this new lead source and expectations of their follow up \n* Define success criteria and KPIs for launching this - are you looking for X number of leads? X ARR in pipeline? higher close rates due to quality of leads? \n* If possible align incentives to CSQLs for any that close to drive this behavior ","outcome":"Increase Expansion Pipeline","stream":"Account planning for expansion"}];

const state = { path:null, vd:[], components:[], maturity:[], setup:[], enable:[] };
let favView = 'all'; // 'all' | 'fav'

// ── Favourites (localStorage) ──────────────────────────────────────────
function getFavs() {
  try { return new Set(JSON.parse(localStorage.getItem('gs_o2_favs') || '[]')); }
  catch(e) { return new Set(); }
}
function saveFavs(set) {
  try { localStorage.setItem('gs_o2_favs', JSON.stringify([...set])); } catch(e) {}
}
function toggleFav(wfId, btn) {
  const favs = getFavs();
  if (favs.has(wfId)) { favs.delete(wfId); btn.classList.remove('starred'); btn.title = 'Add to favourites'; }
  else                 { favs.add(wfId);    btn.classList.add('starred');    btn.title = 'Remove from favourites'; }
  saveFavs(favs);
  updateFavCount();
}
function updateFavCount() {
  const n = getFavs().size;
  const el = document.getElementById('favCount');
  if (el) el.textContent = n;
}
function switchFavTab(tab) {
  favView = tab;
  document.getElementById('tabAll').classList.toggle('active', tab === 'all');
  document.getElementById('tabFav').classList.toggle('active', tab === 'fav');
  renderResults();
}
const ALL_COMPONENTS = [
  "CTAs","Scorecard","Timeline","Rules Engine","Journey Orchestrator",
  "Dashboards","C360","Success Plans","Surveys","Renewal Center",
  "Adoption Explorer","Connectors","People Maps","Customer Stages",
  "Email Assist","Reports"
];
const FEATURE_LABELS = {
  "CTAs":"CTAs","Scorecard":"Scorecard","Timeline":"Timeline",
  "Rules Engine":"Rules Engine","Journey Orchestrator":"Journey Orchestrator",
  "Dashboards":"Dashboards","C360":"Customer 360","Success Plans":"Success Plans",
  "Surveys":"Surveys","Renewal Center":"Renewal Center",
  "Adoption Explorer":"Adoption Explorer","Connectors":"Connectors",
  "People Maps":"People Maps","Customer Stages":"Customer Stages",
  "Email Assist":"Email Assist","Reports":"Reports"
};
const FEATURE_DESCS = {
  "CTAs":"Calls to Action / playbooks","Scorecard":"Health scoring",
  "Timeline":"Customer interaction logs","Rules Engine":"Automated triggers",
  "Journey Orchestrator":"Automated email programs","Dashboards":"Reports and views",
  "C360":"C360 layout and sections","Success Plans":"Goal tracking with customers",
  "Surveys":"NPS, CSAT, custom surveys","Renewal Center":"Renewal pipeline management",
  "Adoption Explorer":"Usage and login tracking","Connectors":"CRM and data integrations",
  "People Maps":"Stakeholder org charts","Customer Stages":"Lifecycle stage tracking",
  "Email Assist":"Templated email tools","Reports":"Report builder"
};
const VD_COLORS = {Retention:'#ef4444',Adoption:'#3b82f6',Scale:'#8b5cf6',Expansion:'#22c55e'};
const VD_ICONS  = {Retention:'🔒',Adoption:'📈',Scale:'🚀',Expansion:'🌱'};
const MAT_ORD   = {Crawl:0,Walk:1,Run:2};
const EFF_ORD   = {Low:0,Medium:1,High:2};

document.addEventListener('DOMContentLoaded', () => {
  const grid = document.getElementById('compGrid');
  grid.innerHTML = ALL_COMPONENTS.map(c =>
    `<div class="comp-chip" onclick="toggleComp(this,'${c.replace(/'/g,"\\'")}')">${c}</div>`
  ).join('');
});

function toggle(el, key, val) {
  el.classList.toggle('selected');
  const arr = state[key];
  const i = arr.indexOf(val);
  if (i===-1) arr.push(val); else arr.splice(i,1);
  updateButtons();
}
function toggleComp(el, val) {
  el.classList.toggle('selected');
  const i = state.components.indexOf(val);
  if (i===-1) state.components.push(val); else state.components.splice(i,1);
  updateButtons();
}
function updateButtons() {
  document.getElementById('btn1').disabled = !state.path;
  const b2v = document.getElementById('btn2v'); if(b2v) b2v.disabled = state.vd.length===0;
  const b2f = document.getElementById('btn2f'); if(b2f) b2f.disabled = state.components.length===0;
}

function selectPath(p) {
  state.path = p;
  document.getElementById('pathValue').classList.toggle('selected', p==='value');
  document.getElementById('pathFeature').classList.toggle('selected', p==='feature');
  updateButtons();
}

function goToStep1() { hide(['screen2value','screen2feature','screen3','screen4']); show('screen1'); setStep(1); }
function goToStep2() {
  hide(['screen1','screen3','screen4','screen2value','screen2feature']);
  show(state.path==='value'?'screen2value':'screen2feature');
  setStep(2);
}
function goToStep3() { hide(['screen2value','screen2feature','screen1','screen4']); show('screen3'); setStep(3); }
function showResults() { hide(['screen1','screen2value','screen2feature','screen3']); show('screen4'); setStep(4); favView='all'; document.getElementById('tabAll').classList.add('active'); document.getElementById('tabFav').classList.remove('active'); updateFavCount(); renderResults(); }
function startOver() {
  state.path=null; state.vd=[]; state.components=[]; state.maturity=[]; state.setup=[]; state.enable=[];
  document.querySelectorAll('.opt-chip.selected,.comp-chip.selected,.path-card.selected').forEach(e=>e.classList.remove('selected'));
  goToStep1();
}
function hide(ids) { ids.forEach(id=>document.getElementById(id)?.classList.add('hidden')); }
function show(id)  { document.getElementById(id)?.classList.remove('hidden'); }
function setStep(n) {
  for(let i=1;i<=4;i++){
    const el=document.getElementById('step'+i);
    el.classList.remove('active','done');
    if(i<n) el.classList.add('done'); else if(i===n) el.classList.add('active');
  }
  for(let i=1;i<=3;i++) document.getElementById('line'+i).classList.toggle('done',i<n);
}

function getFiltered() {
  return WORKFLOW_DATA.filter(wf=>{
    if(state.path==='value' && state.vd.length>0 && !state.vd.some(v=>wf.valueDrivers.includes(v))) return false;
    if(state.path==='feature' && state.components.length>0) {
      const match = state.components.some(sel => {
        if(sel==='CTAs') return wf.components.some(c=>c.startsWith('CTA'));
        if(sel==='C360') return wf.components.includes('C360');
        return wf.components.includes(sel);
      });
      if(!match) return false;
    }
    if(state.maturity.length>0 && !state.maturity.includes(wf.maturity)) return false;
    if(state.setup.length>0 && !state.setup.includes(wf.setupEffort)) return false;
    if(state.enable.length>0 && !state.enable.includes(wf.enablementEffort)) return false;
    return true;
  });
}

function renderResults() {
  const search = document.getElementById('searchInput').value.toLowerCase();
  const sort   = document.getElementById('sortSelect').value;
  let wfs = getFiltered();
  const favs = getFavs();

  // Favourites view
  if (favView === 'fav') {
    if (favs.size === 0) {
      document.getElementById('resultsContainer').innerHTML = `
        <div class="fav-empty">
          <div class="fav-empty-icon">⭐</div>
          <div class="fav-empty-title">No favourites yet</div>
          <div class="fav-empty-sub">Click the ★ star on any workflow to save it here.<br>Your favourites persist even after closing the page.</div>
        </div>`;
      return;
    }
    wfs = WORKFLOW_DATA.filter(w => favs.has(w.id));
  }
  if(search) wfs = wfs.filter(w=>
    w.name.toLowerCase().includes(search)||
    w.description.toLowerCase().includes(search)||
    w.stream.toLowerCase().includes(search)
  );
  wfs.sort((a,b)=>{
    if(sort==='maturity') return (MAT_ORD[a.maturity]||0)-(MAT_ORD[b.maturity]||0);
    if(sort==='name')     return a.name.localeCompare(b.name);
    if(sort==='setup')    return (EFF_ORD[a.setupEffort]||0)-(EFF_ORD[b.setupEffort]||0);
    if(sort==='enable')   return (EFF_ORD[a.enablementEffort]||0)-(EFF_ORD[b.enablementEffort]||0);
    return 0;
  });

  const pathLabel = state.path==='value'?'Value Oriented':'Feature Oriented';
  const selLabel  = state.path==='value'
    ? (state.vd.join(', ')||'All Drivers')
    : (state.components.slice(0,3).join(', ')+(state.components.length>3?' +more':''));
  document.getElementById('resultsHeader').innerHTML = `
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:14px">
      <div>
        <div style="font-size:12px;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px">${pathLabel}</div>
        <h2>${wfs.length} Matching Workflow${wfs.length!==1?'s':''}</h2>
        <div style="color:rgba(255,255,255,0.55);font-size:13px;margin-top:3px">${selLabel}</div>
      </div>
      <div class="meta-pills">
        ${state.maturity.length?`<div class="meta-pill">Maturity: <strong>${state.maturity.join(', ')}</strong></div>`:''}
        ${state.setup.length?`<div class="meta-pill">Setup: <strong>${state.setup.join(', ')}</strong></div>`:''}
        ${state.enable.length?`<div class="meta-pill">Enablement: <strong>${state.enable.join(', ')}</strong></div>`:''}
      </div>
    </div>`;

  const container = document.getElementById('resultsContainer');
  if(!wfs.length){
    container.innerHTML=`<div class="empty"><div class="empty-icon">🔍</div><div>No workflows match your filters.</div><div style="font-size:13px;margin-top:6px">Try broadening your selections.</div></div>`;
    return;
  }

  // Group
  let groups = {};
  if(state.path==='value'){
    const drivers = state.vd.length>0 ? state.vd : ['Retention','Adoption','Scale','Expansion'];
    drivers.forEach(vd=>{ const g=wfs.filter(w=>w.valueDrivers.includes(vd)); if(g.length) groups[vd]=g; });
    const used=new Set(Object.values(groups).flat().map(w=>w.id));
    const rest=wfs.filter(w=>!used.has(w.id)); if(rest.length) groups['Other']=rest;
  } else {
    state.components.forEach(c=>{ const g=wfs.filter(w=>w.components.includes(c)); if(g.length) groups[c]=g; });
    const used=new Set(Object.values(groups).flat().map(w=>w.id));
    const rest=wfs.filter(w=>!used.has(w.id)); if(rest.length) groups['Other']=rest;
  }

  container.innerHTML = Object.entries(groups).map(([grp,items])=>{
    const color = VD_COLORS[grp]||'#64748b';
    const icon  = VD_ICONS[grp]||'⚙️';
    return `
    <div class="vd-section">
      <div class="vd-header" onclick="toggleSection(this)">
        <div class="vd-dot" style="background:${color}"></div>
        <div class="vd-title">${icon} ${grp}</div>
        <div class="vd-count">${items.length} workflow${items.length!==1?'s':''}</div>
        <div class="vd-chevron open">▼</div>
      </div>
      <div class="vd-body open">${items.map(renderWF).join('')}</div>
    </div>`;
  }).join('');
}

function toggleSection(hdr){
  const body=hdr.nextElementSibling;
  body.classList.toggle('open');
  hdr.querySelector('.vd-chevron').classList.toggle('open');
}

function renderWF(wf){
  const sid = wf.id.replace('-','_');
  const esc = s => (s||'').replace(/`/g,"'").replace(/\\/g,'\\\\');

  const overviewHTML = `
    <div class="detail-section">
      <div class="detail-section-title"><span>📋 Overview</span></div>
      <div class="detail-meta-grid">
        <div class="detail-meta-item"><label>Maturity</label><span class="maturity-badge ${wf.maturity} val">${wf.maturity}</span></div>
        <div class="detail-meta-item"><label>Setup Effort</label><div class="val">${wf.setupEffort||'—'}</div></div>
        <div class="detail-meta-item"><label>Enablement Effort</label><div class="val">${wf.enablementEffort||'—'}</div></div>
        <div class="detail-meta-item"><label>Value Drivers</label><div class="val" style="font-size:12px">${wf.valueDrivers.join(', ')||'—'}</div></div>
      </div>
      <div class="detail-text">${wf.description||'<span class="detail-empty">No description available.</span>'}</div>
      ${wf.components.length?`<div style="margin-top:12px;font-size:10px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px">Features Needed</div><div class="comp-tags">${wf.components.map(c=>`<span class="comp-tag">${c}</span>`).join('')}</div>`:''}
    </div>`;

  const discHTML = wf.discoveryQuestions
    ? `<div class="detail-section"><div class="detail-section-title"><span>🔍 Discovery Questions</span></div><div class="detail-text">${wf.discoveryQuestions.replace(/</g,'&lt;')}</div></div>`
    : '';

  const storiesHTML = wf.workflowUserStories
    ? `<div class="detail-section"><div class="detail-section-title"><span>👤 Workflow User Stories</span></div><div class="detail-text">${wf.workflowUserStories.replace(/</g,'&lt;')}</div></div>`
    : '';

  const guideHTML = wf.gettingStartedGuide
    ? `<div class="detail-section"><div class="detail-section-title"><span>🚀 Getting Started Guide</span></div><div class="detail-text">${wf.gettingStartedGuide.replace(/</g,'&lt;')}</div></div>`
    : '';

  return `
  <div class="wf-item">
    <div class="wf-row" onclick="toggleWF('${sid}')">
      <div class="wf-id">${wf.id}</div>
      <div class="wf-name">${wf.name}</div>
      <div class="maturity-badge ${wf.maturity}">${wf.maturity}</div>
      <div class="effort-badge">Setup: ${wf.setupEffort||'—'}</div>
      <div class="effort-badge">CS: ${wf.enablementEffort||'—'}</div>
      <button class="star-btn ${getFavs().has(wf.id)?'starred':''}" id="star_${sid}" title="${getFavs().has(wf.id)?'Remove from favourites':'Add to favourites'}" onclick="event.stopPropagation();toggleFav('${wf.id}',this)">★</button>
      <div class="expand-arrow" id="arr_${sid}">▶</div>
    </div>
    <div class="wf-detail" id="det_${sid}">
      ${overviewHTML}${discHTML}${storiesHTML}${guideHTML}
    </div>
  </div>`;
}

function toggleWF(sid){
  document.getElementById('det_'+sid).classList.toggle('open');
  document.getElementById('arr_'+sid).classList.toggle('open');
}
</script>
</body>
</html>
